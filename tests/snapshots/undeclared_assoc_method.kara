// Surfaced 2026-05-22 building the kata-91 bench mirror: `String.from_utf8`
// is spec'd in design.md but not implemented in `runtime/stdlib/`. The
// typechecker used to silently accept the call (`Type::Error` sentinel),
// then `parsed.unwrap()` exploded in codegen with a misleading
// "no handler for method 'unwrap' on variable 'parsed'" — sending future
// debuggers chasing a phantom codegen bug. This snapshot pins the
// improved diagnostic: typecheck rejects the call cleanly, and
// `Pipeline::has_fatal_errors` stops the build before codegen runs.
fn main() {
    let buf: Vec[u8] = Vec.new();
    let parsed = String.from_utf8(buf);
    let _ = parsed;
}

// runtime/stdlib/column.kara
//
// `Column[T]` â€” nullable 1-D column with Apache Arrow layout (Phase 11
// data-science stdlib; design.md Â§ Memory Layout Commitments, Q5).
// Interpreter MVP surface so far: constructors (`new` / `with_capacity`
// / `from_vec` / `from_iter_nullable`), append (`push` / `push_null`),
// the null/validity accessors (`len` / `null_count` / `valid_count` /
// `is_null`), positional indexing `c[i] -> Option[T]` (Some for a valid
// slot, None for a null), the nullable iterators (`iter` ->
// `Vec[Option[T]]`, `iter_valid` -> `Vec[T]`), and the null-handling
// transforms (`fillna` / `dropna`).
//
// **Codegen (Arrow-buffer lowering).** The native LLVM lowering
// (`src/codegen/column.rs`) ships the real bit-packed Apache Arrow
// layout â€” a control block `{ data, null_bitmap, len, capacity }` with a
// separate values buffer and a 1-bit-per-element validity bitmap â€” for:
// all four constructors (`new` / `with_capacity` / `from_vec` /
// `from_iter_nullable`), `push` / `push_null`, `len` / `null_count` /
// `valid_count` / `is_null`, `c[i] -> Option[T]` indexing, the
// Column-returning transforms `fillna` / `dropna`, the Vec-returning
// iterators (`iter` -> `Vec[Option[T]]`, `iter_valid` -> `Vec[T]`), and
// the SQL-null three-valued element-wise operators (`+ - * /` /
// comparisons / unary `-`, with null propagation). `fillna`'s
// `treat_nan_as_null` float flag is lowered on both surfaces too â€”
// tracker at `phase-11-stdlib-longtail.md Â§ Data types â€” Arrow commitment`.
//
// **Dispatch.** Constructors fire through `eval_call.rs`'s
// `"Column.new"` / `"Column.with_capacity"` / `"Column.from_vec"` /
// `"Column.from_iter_nullable"` path-string arms; the `push` /
// `push_null` / `len` / `null_count` / `valid_count` / `is_null` /
// `iter` / `iter_valid` / `fillna` / `dropna` instance methods through
// `try_eval_column_method` (`src/interpreter/method_call_column.rs`),
// which intercepts before these `#[compiler_builtin]` bodies (their
// bodies are surface-only stubs). Positional indexing is intercepted at
// the interpreter's index sites and typed at the typechecker's index
// site (returning `Option[T]`), since the `[]` operator has no method
// signature to dispatch through.
//
// **Representation.** The interpreter holds a `Value::Column` with a
// `data` element buffer plus a parallel `valid` validity bitmap (one
// bool per slot â€” `false` is a SQL null). The two stay the same length
// (the Arrow invariant): `push_null` appends a never-read placeholder to
// `data`. The struct body below is an opaque surface-only declaration
// (the handle field is never read), mirroring `Tensor` / `Pool[T]`.
//
// **Element-type note.** The tree-walk interpreter is dynamically typed,
// so `Column.new()` / `with_capacity()` carry no element values until a
// `push` / `from_vec` supplies them â€” `T` is recovered from the binding
// annotation / call-site inference exactly as for `Vec.new()`. `is_null`
// / `len` / `null_count` / `valid_count` are element-type agnostic.

struct Column[=T] {
    // Opaque â€” interpreter intercepts all construction and access.
    handle_id: i64,
}

impl[T] Column[T] {
    // Fresh empty column. The element type `T` comes from the binding
    // annotation / call-site inference: `let c: Column[i64] = Column.new();`.
    #[compiler_builtin]
    fn new() -> Column[T] {
        Column { handle_id: 0 }
    }

    // Fresh empty column with a capacity hint (advisory â€” the
    // interpreter MVP ignores it; the codegen Arrow buffer will honor it).
    #[compiler_builtin]
    fn with_capacity(cap: i64) -> Column[T] {
        Column { handle_id: 0 }
    }

    // Column from a `Vec[T]`, every slot valid (no nulls).
    #[compiler_builtin]
    fn from_vec(values: Vec[T]) -> Column[T] {
        Column { handle_id: 0 }
    }

    // Column from a `Vec[Option[T]]` â€” `Some(v)` becomes a valid slot,
    // `None` becomes a SQL null.
    #[compiler_builtin]
    fn from_iter_nullable(values: Vec[Option[T]]) -> Column[T] {
        Column { handle_id: 0 }
    }

    // Append a valid value.
    #[compiler_builtin]
    fn push(mut ref self, value: T) {}

    // Append a SQL null (a non-valid slot).
    #[compiler_builtin]
    fn push_null(mut ref self) {}

    // Number of slots (valid + null).
    #[compiler_builtin]
    fn len(ref self) -> i64 {
        0
    }

    // Number of null (non-valid) slots.
    #[compiler_builtin]
    fn null_count(ref self) -> i64 {
        0
    }

    // Number of valid (non-null) slots â€” `len() - null_count()`.
    #[compiler_builtin]
    fn valid_count(ref self) -> i64 {
        0
    }

    // Whether slot `i` is a SQL null. Out-of-range `i` is a runtime error.
    #[compiler_builtin]
    fn is_null(ref self, i: i64) -> bool {
        false
    }

    // Every slot as an `Option[T]` (Some for a valid slot, None for a
    // null), in order â€” a Vec of copies, directly `for`-iterable. (Eager
    // copy; a lazy view type is v1.5+, mirroring `Tensor.iter_axis`.)
    #[compiler_builtin]
    fn iter(ref self) -> Vec[Option[T]] {
        Vec.new()
    }

    // The valid slots only, unwrapped, in order â€” nulls skipped.
    #[compiler_builtin]
    fn iter_valid(ref self) -> Vec[T] {
        Vec.new()
    }

    // Replace every null slot with `value`, yielding an all-valid column
    // (a copy; the receiver is unchanged). With `treat_nan_as_null = true`
    // a float column's NaN slots (which are bitmap-valid, not null) are
    // also replaced â€” the opt-in NaNâ†’null normalization (design.md Â§ Data
    // types). The flag is a no-op for non-float element types.
    #[compiler_builtin]
    fn fillna(ref self, value: T, treat_nan_as_null: bool = false) -> Column[T] {
        Column { handle_id: 0 }
    }

    // Drop the null slots, yielding an all-valid column of the valid
    // values in order (a copy; the receiver is unchanged).
    #[compiler_builtin]
    fn dropna(ref self) -> Column[T] {
        Column { handle_id: 0 }
    }

    // --- Statistical reductions (phase-11 stats). All operate on the
    // valid (non-null) slots only â€” SQL/pandas aggregate semantics. An
    // empty valid set is a runtime error (no identity for min/max; the
    // float-result forms divide by zero). `sum`/`min`/`max` preserve the
    // element type; `mean`/`var`/`std`/`median`/`quantile` always yield
    // `f64`. The result-type / numeric-element checks are an interpreter
    // and typechecker intercept (baked generic dispatch can't bind `T`
    // from the receiver) â€” these bodies are surface-only stubs.

    // Sum of the valid slots (overflow traps as for scalar `+`).
    #[compiler_builtin]
    fn sum(ref self) -> T {
        loop {}
    }

    // Arithmetic mean of the valid slots, always `f64`.
    #[compiler_builtin]
    fn mean(ref self) -> f64 {
        0.0
    }

    // Smallest valid slot (NaN neither displaces nor is taken).
    #[compiler_builtin]
    fn min(ref self) -> T {
        loop {}
    }

    // Largest valid slot.
    #[compiler_builtin]
    fn max(ref self) -> T {
        loop {}
    }

    // **Sample** variance of the valid slots (Bessel `n-1`; the
    // pandas-Series / SQL-`stddev` default). Requires â‰¥ 2 valid values.
    #[compiler_builtin]
    fn var(ref self) -> f64 {
        0.0
    }

    // Sample standard deviation â€” `sqrt(var())`.
    #[compiler_builtin]
    fn std(ref self) -> f64 {
        0.0
    }

    // Median of the valid slots (mean of the two middle values for an
    // even count), always `f64`.
    #[compiler_builtin]
    fn median(ref self) -> f64 {
        0.0
    }

    // The `q`-quantile (`q` in `[0, 1]`) of the valid slots via linear
    // interpolation (NumPy / pandas default), always `f64`.
    #[compiler_builtin]
    fn quantile(ref self, q: f64) -> f64 {
        0.0
    }

    // Pearson correlation with another equal-length `Column[f64]`, over
    // the pairwise-valid slots (â‰¥ 2 required). A zero-variance operand
    // yields `NaN`. Only defined on `Column[f64]`.
    #[compiler_builtin]
    fn corr(ref self, other: Column[f64]) -> f64 {
        0.0
    }
}

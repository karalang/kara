// runtime/stdlib/tls.kara
//
// Phase 6 line 236 slice 2 â€” TLS / HTTPS server-side stdlib types.
// Composes through slice 1's `runtime/src/tls.rs` FFI surface to give
// kara source `TlsListener.bind_tls(...)` / `.accept()` / `TlsStream.read`
// / `.write` / `.write_all` â€” same shape as `TcpListener` / `TcpStream`
// from `runtime/stdlib/tcp.kara` so swapping a server from `ws://` to
// `wss://` is a single bind-line edit.
//
// **v1 surface:**
//   - `TlsListener.bind_tls(addr: String, cert_pem: String, key_pem: String) -> TlsListener`
//     binds a TCP listener via `karac_runtime_tls_listener_bind` and
//     attaches a freshly-built `*mut TlsConfig` (from
//     `karac_runtime_tls_config_new(cert.bytes, key.bytes)`) for use at
//     each accept. Prints `BOUND_PORT=<n>\n` on `:0` (same convention
//     as `TcpListener.bind`).
//   - `TlsListener.accept(ref self) -> Result[TlsStream, TlsError]` â€”
//     parks via `karac_park_on_fd(self.fd, 0u8)`, runs raw `accept(2)`,
//     then synchronously drives the TLS handshake against the new
//     connection. `Ok(stream)` wraps the post-handshake fd; on failure
//     (raw-accept or handshake) returns `Err(TlsError.Protocol(-1))`.
//   - `TlsStream.read(ref self, buf: mut Slice[u8]) -> Result[i64, TlsError]`
//     parks on read-readiness, then pumps `karac_runtime_tls_read`
//     until at least one decrypted plaintext byte is available.
//     `Ok(n)` (n=0 is clean EOF); `Err(TlsError)` on syscall or
//     rustls-detected protocol error.
//   - `TlsStream.write(ref self, buf: Slice[u8]) -> Result[i64, TlsError]`
//     parks on write-readiness; rustls's writer never short-writes so
//     the byte count returned always equals `buf.len()` on success.
//   - `TlsStream.write_all(ref self, buf: Slice[u8]) -> Result[i64, TlsError]`
//     symmetric with the TCP variant â€” same retry-on-EINTR loop.
//
// **Error type â€” `TlsError`** (Phase-8 line 24, 2026-05-29). Three
// variants distinguish the actionable failure classes the audit
// requires:
//   - `Interrupted` â€” EINTR; retry without backoff (same semantics as
//     `TcpError.Interrupted`).
//   - `Other(errno)` â€” underlying socket syscall failure (EPIPE,
//     ECONNRESET, EAGAIN, etc.).
//   - `Protocol(code)` â€” rustls-detected fault: handshake failure,
//     cert verification failure, peer-misbehavior, attempted
//     renegotiation (rustls 0.23 rejects), truncation attack. rustls
//     0.23 does NOT distinguish these at the API surface (handshake /
//     cert-verify / renegotiation all collapse to opaque errors at
//     `complete_io` / `process_new_packets`), so v1 folds them under
//     one variant; `code` is reserved for future finer-grained
//     classification if rustls grows a richer error API.
//
// v1 quirk: a runtime `n == -1` return that originated from
// `io_err_to_neg` with EPERM (errno=1) is currently mis-classified as
// `Protocol(-1)` rather than `Other(1)` â€” EPERM during a TLS socket
// read/write is exceedingly rare in practice (it usually means a bad
// fd was passed). A runtime sentinel rework that disambiguates lands
// when a real workload surfaces the case.
//
// **TlsConfig opacity.** `TlsConfig` is an empty kara struct standing
// in for the rustls `ServerConfig` allocation owned by the runtime.
// Users never construct or inspect it â€” `TlsListener.bind_tls` is the
// only call that materialises one (via the FFI) and `Drop for
// TlsListener` is the only call that frees it (via
// `karac_runtime_tls_config_free`). The kara-side struct has no
// fields; the type is needed only so `*mut TlsConfig` is a nameable
// type for the `TlsListener` field.
//
// **Drop semantics.** Both `TlsListener` and `TlsStream` `impl Drop`
// at the bottom of this file. `TlsListener.drop` frees the config
// pointer (`karac_runtime_tls_config_free(self.config)`) and closes
// the listener fd (`karac_runtime_tls_close(self.fd)`). `TlsStream.drop`
// closes the connection fd (`karac_runtime_tls_close(self.fd)` â€”
// also removes the session entry from the runtime-side registry).
// Both bodies are hand-rolled in codegen (mirrors `TcpListener.drop`
// from slice 9d of phase-6 line 17).

// Phase-8 line 24 â€” TLS-specific error type for `TlsStream.read` /
// `.write` / `.write_all`. Three variants give the audit-required
// actionable distinctions without inventing variants rustls 0.23 can't
// actually surface (see file-header **Error type** block):
//   - `Interrupted` â€” EINTR retry signal (same meaning as
//     `TcpError.Interrupted`).
//   - `Other(errno)` â€” underlying socket syscall failure; the i32
//     payload is the raw errno (EPIPE / ECONNRESET / EAGAIN / etc.).
//   - `Protocol(code)` â€” rustls-detected fault. Catch-all for
//     handshake error, cert verification failure, peer-misbehavior,
//     renegotiation attempt, truncation. rustls 0.23 surfaces these
//     opaquely; `code` is currently always `-1` and reserved for
//     finer-grained classification if a future rustls release distin-
//     guishes them.
//
// Same 2-word `{ tag, payload }` layout as `TcpError` (the codegen
// `wrap_tls_io_result` mirrors `wrap_tcp_io_result` modulo the
// `-1` â†’ `Protocol(-1)` branch). The `i32` payload on `Other` /
// `Protocol` is widened to i64 in the lowered struct.
enum TlsError {
    Interrupted,
    Other(i32),
    Protocol(i32),
    // Construction-error variants (phase-8 line 74) â€” mirror of
    // `TcpError`'s. The TCP-connect leg of `TlsStream.connect` and the
    // bind leg (delegated to `karac_runtime_tcp_bind`) surface these;
    // rustls handshake / protocol faults remain `Protocol(code)`.
    AddrInUse,
    ConnectionRefused,
    PermissionDenied,
}

// Opaque marker type â€” see file-header `TlsConfig opacity` block.
// Field-list intentionally empty: the runtime owns the underlying
// `rustls::ServerConfig` allocation and the `*mut TlsConfig` pointer
// here is just a heap address kara source can carry but never
// dereference.
struct TlsConfig {}

// `TlsListener` carries the bound listener's fd plus the
// `*mut TlsConfig` returned by `karac_runtime_tls_config_new` at
// bind-time. Codegen reads field 0 (`fd`) at every `accept` to feed
// `karac_park_on_fd` + `karac_runtime_tls_accept`; field 1 (`config`)
// is forwarded to the accept FFI so each connection's
// `ServerConnection` clones the right config. Both fields are
// freed/closed at scope exit via `impl Drop`.
struct TlsListener {
    fd: i32,
    config: *mut TlsConfig,
}

// `TlsStream` wraps a post-handshake connection fd. The TLS session
// state itself lives in the runtime-side `SESSIONS` registry keyed by
// this fd (see `runtime/src/tls.rs` `## Session storage`); the kara
// struct only carries the fd lookup key. Same single-i32-field
// shape as `TcpStream` so the LLVM struct ABI arm in
// `types_lowering.rs::llvm_type_for_name` can group the two under
// the same `{ i32 }` pattern.
struct TlsStream {
    fd: i32,
}

impl TlsListener {
    // Bind on `addr` (e.g. `"127.0.0.1:0"` for ephemeral, `"0.0.0.0:8443"`
    // for fixed) using `cert_pem` + `key_pem` as the server identity.
    // Both PEM strings are the raw textual PEM bytes â€” typically
    // loaded from disk via `std.file.read_to_string`. Returns
    // `Ok(listener)` carrying the bound fd and the runtime-side config
    // handle on success (see the `Result` contract two paragraphs
    // below), or `Err(TlsError)` on parse / bind failure.
    //
    // **BOUND_PORT convention.** When the requested address ends in
    // `:0`, the runtime prints `BOUND_PORT=<port>\n` to stdout before
    // returning so smoke tests can read back the assigned ephemeral
    // port.
    //
    // Returns `Result[TlsListener, TlsError]` (phase-8 line 64 audit:
    // construction methods return `Result`, not an `fd: -1` sentinel):
    // `Ok(listener)` on success, `Err(TlsError.Protocol(-1))` on PEM-parse
    // / bind failure (the failure path also frees the freshly-built rustls
    // config so it does not leak â€” the old sentinel relied on `Drop` for
    // that). Stub body never executes â€” codegen replaces via
    // `lower_tls_listener_bind_tls` (see `src/codegen/tls.rs`).
    #[compiler_builtin]
    fn bind_tls(addr: String, cert_pem: String, key_pem: String) -> Result[TlsListener, TlsError] {
        Result.Err(TlsError.Protocol(-1))
    }

    // Wait for the listener to become readable, then accept the next
    // pending connection, run the TLS handshake against it
    // synchronously, and return `Ok(stream)` wrapping the
    // post-handshake fd. Returns `Err(TlsError.Protocol(-1))` on
    // raw-accept failure or handshake failure (peer sent invalid TLS,
    // cert validation failed on the wire, etc.).
    //
    // **Parking convention.** Codegen emits a `karac_park_on_fd(self.fd, 0u8)`
    // invocation BEFORE the raw `karac_runtime_tls_accept` so the
    // yield happens at the kara state-machine level â€” same shape as
    // `TcpListener.accept` (see `runtime/stdlib/tcp.kara` line 142).
    //
    // **Synchronous handshake (v1).** Once the parking primitive
    // returns Ready, the FFI runs `rustls::ServerConnection::complete_io`
    // against the new connection's blocking socket surface. This
    // occupies the worker thread until the client completes the TLS
    // round-trip â€” fine for Demo 1's correctness check; the M1
    // 100K-conn target will need a re-park-between-rounds variant if
    // measurement shows handshake throughput dominates.
    //
    // **Availability note â€” you own the accept loop.** Because the
    // handshake is synchronous, a single stalled or malicious peer that
    // completes the TCP connect but never finishes the TLS handshake
    // will block THIS call â€” and therefore the entire accept loop you
    // build around it â€” until that peer gives up. This is by-design for
    // a low-level blocking primitive (it mirrors Go's
    // `tls.Conn.Handshake()`); `accept` deliberately does not impose its
    // own handshake timeout or concurrency cap, because the loop, and
    // thus the accept policy, is yours. If you serve untrusted /
    // internet-facing clients, spawn a task per accepted connection
    // and/or apply your own handshake timeout so one slow peer cannot
    // starve the rest. (The managed `Server.serve` / `serve_tls` paths
    // do this hardening internally â€” see phase-8 line 124.)
    #[compiler_builtin]
    fn accept(ref self) -> Result[TlsStream, TlsError] with sends(Network) receives(Network) {
        Result.Err(TlsError.Protocol(-1))
    }
}

impl TlsStream {
    // Phase-8 line 22 â€” client-side connect + synchronous handshake.
    // Open a TCP connection to `addr` (e.g. `"127.0.0.1:8443"` or a
    // hostname:port resolved before this call), build a rustls
    // `ClientConfig` whose root store trusts the certs in `roots_pem`,
    // negotiate against `server_name` for SNI + cert verification, run
    // the TLS handshake synchronously, and return a `TlsStream`
    // wrapping the post-handshake fd. The returned stream is
    // interchangeable with one from `TlsListener.accept` â€” same
    // single-i32-field shape, same per-fd session map, same
    // `read` / `write` / `write_all` / `Drop` paths.
    //
    // Trust posture: only the certs in `roots_pem` are trusted; there
    // is no fallback to system roots / webpki-roots at v1. Callers
    // that need public-CA trust (e.g. `Client.get("https://...")`)
    // must supply the relevant root CA PEM(s). Same minimal posture as
    // `TlsListener.bind_tls`'s "explicit PEM only".
    //
    // Returns `Err(TlsError)` on any failure (addr / name / PEM parse,
    // TCP connect, rustls config build, handshake): the TCP-connect leg
    // surfaces branchable causes (`ConnectionRefused` / `AddrInUse` /
    // `PermissionDenied`, phase-8 line 74), handshake / protocol faults
    // stay `Protocol(-1)`. Stub body never executes â€” codegen replaces
    // via `lower_tls_stream_connect`.
    #[compiler_builtin]
    fn connect(addr: String, server_name: String, roots_pem: String) -> Result[TlsStream, TlsError]
        with sends(Network) receives(Network)
    {
        Result.Err(TlsError.Protocol(-1))
    }

    // Park on read-readiness of `self.fd`, then pump rustls's inbound
    // packet processor until at least one decrypted plaintext byte is
    // available. The FFI returns the byte count (>= 0; 0 = clean EOF
    // including close_notify), `-errno` for socket errors, or `-1`
    // for rustls-detected protocol errors and session-lookup misses.
    // Codegen wraps via `wrap_tls_io_result` into `Ok(n)` /
    // `Err(TlsError)` â€” see the file-header **Error type** block for
    // the variant semantics.
    //
    // The park step uses `direction = 0u8` (Read). Stub body never
    // executes â€” codegen replaces via `lower_tls_stream_read`.
    #[compiler_builtin]
    fn read(ref self, buf: mut Slice[u8]) -> Result[i64, TlsError]
        with sends(Network) receives(Network)
    {
        Result.Err(TlsError.Protocol(-1))
    }

    // Park on write-readiness of `self.fd`, then push plaintext into
    // rustls's writer and flush the resulting ciphertext to the
    // socket. rustls's writer never short-writes so the byte count
    // returned always equals `buf.len()` on success. Same
    // `wrap_tls_io_result` wrapping as `read` â€” `Ok(n)` / `Err(TlsError)`.
    //
    // The park step uses `direction = 1u8` (Write). Stub body never
    // executes â€” codegen replaces via `lower_tls_stream_write`.
    #[compiler_builtin]
    fn write(ref self, buf: Slice[u8]) -> Result[i64, TlsError]
        with sends(Network) receives(Network)
    {
        Result.Err(TlsError.Protocol(-1))
    }

    // Loop `write` until all `buf.len()` bytes have been pushed (or
    // an unrecoverable error fires). Absorbs partial writes â€” though
    // rustls's writer doesn't currently short-write, the wrapper is
    // structurally identical to `TcpStream.write_all` so future
    // partial-write behaviour at the rustls layer composes through
    // unchanged. Retries on `TlsError.Interrupted` (EINTR).
    //
    // Stub body never executes â€” codegen replaces via
    // `lower_tls_stream_write_all`.
    #[compiler_builtin]
    fn write_all(ref self, buf: Slice[u8]) -> Result[i64, TlsError]
        with sends(Network) receives(Network)
    {
        Result.Err(TlsError.Protocol(-1))
    }
}

// Phase 6 line 236 slice 2 â€” close-on-drop. Both `TlsListener` and
// `TlsStream` register here so `TypeCheckResult.drop_method_keys`
// recognises them; the codegen wrapper-synth pass emits
// `karac_drop_TlsListener` / `karac_drop_TlsStream`. The scope-exit
// drain (`CleanupAction::UserDrop`) fires the wrappers.
//
// `TlsListener.drop` body (hand-rolled in codegen): frees the config
// via `karac_runtime_tls_config_free(self.config)` then closes the
// listener fd via `karac_runtime_tls_close(self.fd)`. The config
// free is idempotent for null per the FFI contract.
//
// `TlsStream.drop` body (hand-rolled in codegen): closes the
// connection fd via `karac_runtime_tls_close(self.fd)` â€” same FFI
// call also removes the per-fd entry from the runtime-side
// `SESSIONS` registry (so the `ServerConnection` allocation is
// released).
//
// Both stub bodies below never execute. When the codegen-compiles-
// stdlib gap closes they become real pure-kara bodies of the shape
// `unsafe { karac_runtime_tls_config_free(self.config); karac_runtime_tls_close(self.fd); }`.

// Drop-skip-sound: skipping this Drop leaks the listener fd + the
// rustls server-config allocation; no UB, no type-system violation.
// Soundness derives from the type system; this destructor only runs
// cleanup (design.md Â§ Drop > Destructors are NOT soundness
// mechanisms).
impl Drop for TlsListener {
    #[compiler_builtin]
    fn drop(mut ref self) {}
}

// Drop-skip-sound: skipping this Drop leaks the connection fd + its
// runtime-side `SESSIONS` registry entry (the `ServerConnection`
// allocation); no UB, no type-system violation. Soundness derives
// from the type system; this destructor only runs cleanup.
impl Drop for TlsStream {
    #[compiler_builtin]
    fn drop(mut ref self) {}
}

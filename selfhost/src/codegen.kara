// codegen.kara — a self-hosted LLVM-IR emitter for the Kāra compiler
// (Phase 12, Codegen port Slice 1). Depends on span + ast + (at the driver
// level) parser.
//
// This is the FIRST slice of the backend port. The feasibility spike
// (docs/spikes/selfhost-backend-feasibility.md) proved a Kāra program can emit
// runnable LLVM IR text against the real runtime ABI — `println` lowers to libc
// `fwrite` over the `@stdout` global. This module turns that from a hardcoded
// string into an AST WALK: `emit_program(items)` consumes the parser's
// `Vec[Item]`, finds `main`, and emits IR for its body.
//
// Slice 1 surface: a `main` whose body is a sequence of `println("literal")`
// calls (statement or tail position). Everything else is skipped (emitted as
// nothing) — the emitter grows construct-by-construct, each step verified
// BEHAVIORALLY (compile the emitted IR + run it, diff its stdout against the
// seed's `karac run` on the same source). Unlike the front-end oracles, IR text
// is not byte-reproducible (SSA numbering / block labels are
// construction-order artifacts), so the gate is program-output parity, not an
// exact diff.
//
// The emitter is compiled by the REAL `karac` (not the self-hosted parser), so
// it uses full Kāra — `as` casts, `String.bytes()`, `.to_string()` — none of
// which the selfhost front-end parses yet.

import span.Span;
import ast.{
    Item,
    FnDefNode,
    FnParamNode,
    ImplBlockNode,
    SelfMode,
    PatInt,
    FloatLit,
    CharLit,
    ByteLit,
    TypeExpr,
    PathType,
    Block,
    Stmt,
    LetStmt,
    AssignStmt,
    ExprStmt,
    Expr,
    CallExpr,
    CallArg,
    IdentExpr,
    StrLit,
    IntLit,
    BoolLit,
    BinaryExpr,
    BinOp,
    UnaryExpr,
    UnaryOp,
    MethodCallExpr,
    IfExpr,
    WhileExpr,
    ReturnExpr,
    StructLitExpr,
    StructLitField,
    FieldAccessExpr,
    IndexExpr,
    PathExpr,
    MatchExpr,
    MatchArm,
    ForExpr,
    WrapType,
    TupleVariantPattern,
    EnumDefNode,
    VariantNode,
    Pattern,
    BindingPattern,
};

// An emitted VALUE: the LLVM operand text plus its type KIND — 0 = `i64`,
// 1 = `i1` (bool), 2 = string, a first-class `{ ptr, i64 }` aggregate
// (pointer + byte length; literal-backed, so no heap yet — Slice 7).
struct Val {
    op: String,
    kind: i64,
    // True iff this value OWNS a fresh heap buffer (a concat result) that its
    // consumer must arrange to free (Slice 9). Ident loads are borrows —
    // ownership stays with the original binder, which frees at scope exit;
    // seed-valid programs never use a moved-out binding again, so
    // binder-frees-once is exactly-once by construction.
    heap: bool,
}

// Accumulates the module's string-literal GLOBALS and the `main` BODY
// separately (globals must precede the function definition), plus monotonic
// counters for unique string-global names (`@.strN`) and SSA temporaries
// (`%tN`).
struct Emitter {
    globals: String,
    // Finished function DEFINITIONS (Slice 6): each `emit_fn` appends its
    // assembled `define …` here; `body` is per-function scratch.
    funcs: String,
    body: String,
    nstr: i64,
    ntmp: i64,
    // Local INTEGER variables (Slice 3): `locals[i]` is the name of the i-th
    // `let` binding; its stack slot is `%v<i>` (an i64 alloca). Flat Vec +
    // linear scan (newest-first, so shadowing rebinds); no scoping yet — Slice 3
    // main bodies are a single flat block.
    locals: Vec[String],
    // Parallel to `locals`: the slot's value kind (0 i64, 1 i1, 2 string —
    // Slice 7 typed slots; earlier slices stored everything as i64).
    locals_kind: Vec[i64],
    // Parallel to `locals`: true iff the slot currently OWNS a heap buffer
    // (Slice 9) — freed on reassignment (old value) and at scope exit.
    // Compile-time approximation: seed-valid move discipline makes
    // binder-frees-once exact; mid-fn `return`s run the same scope frees as
    // the epilogue (Slice 22), and a loop-body re-`let` frees the prior copy
    // at the let site (Slice 17).
    locals_heap: Vec[bool],
    // Monotonic basic-block label id (Slice 4: `if`/`else` control flow).
    nlbl: i64,
    // True while emitting `main` (Slice 6): a `return` there is `ret i32 0`,
    // in a user fn `ret i64 <v>`.
    in_main: bool,
    // Signature table (Slice 10) — collected over all items BEFORE any body is
    // emitted so call sites know param/return kinds regardless of declaration
    // order. Parallel vecs keyed by fn index; param kinds are FLATTENED
    // (`sig_par_kinds[sig_par_off[i] .. +sig_par_cnt[i]]`) — no Vec[Vec].
    sig_names: Vec[String],
    // Return kind: -1 unit, 0 i64, 2 string (bool returns unsupported).
    sig_ret: Vec[i64],
    sig_par_kinds: Vec[i64],
    sig_par_ref: Vec[bool],
    sig_par_mut: Vec[bool],
    sig_par_off: Vec[i64],
    sig_par_cnt: Vec[i64],
    // Parallel to `sig_names` (Slice 27): the receiver mode (-1 free fn /
    // 0 owned self / 1 ref self / 2 mut ref self) and the receiver's value
    // kind (-1 for free fns). Method sig names are "<Type>.<method>" —
    // dots can't appear in call idents, so free-fn lookups never collide.
    sig_self_mode: Vec[i64],
    sig_self_kind: Vec[i64],
    // The CURRENT fn's return kind (drives the `return` arm's ret type).
    cur_ret: i64,
    // Struct table (Slice 12) — POD structs (i64/bool fields) as first-class
    // LLVM aggregates. Kind scheme: `10 + index`. Field names/kinds are
    // FLATTENED (`st_field_*[st_off[i] .. +st_cnt[i]]`). The LLVM aggregate
    // type text is REBUILT on demand (`ty_text`) — returning a stored
    // `Vec[String]` element from a method double-freed under AOT
    // (run-vs-build; see the Slice 12 checklist note).
    st_names: Vec[String],
    st_field_names: Vec[String],
    st_field_kinds: Vec[i64],
    st_off: Vec[i64],
    st_cnt: Vec[i64],
    // Enum table (Slice 14) — variants with 0 or 1 i64 payload; a value is a
    // `{ i64, i64 }` (tag, payload) aggregate, kind `1000 + index`. Variant
    // names/payload-arity FLATTENED like the struct tables. The tag is the
    // DECLARATION index — internal to the emitted program, so seed tag parity
    // is not required (output parity only).
    // Per-fn ENTRY-BLOCK alloca text (Slice 17): `let` slots are allocated +
    // zero-initialized ONCE at fn entry, so a `let` inside a loop body reuses
    // its slot across iterations — the let site frees the slot's previous
    // value (free(null)-safe on the first pass) instead of leaking it, and
    // repeated allocas no longer grow the stack per iteration.
    entry_allocas: String,
    en_names: Vec[String],
    en_var_names: Vec[String],
    en_var_pl: Vec[i64],
    // Parallel to `en_var_pl` (Slice 35): the SECOND payload's kind for
    // two-payload variants (`Integer(i64, String)`), -1 otherwise. Payloads
    // route by KIND into the widened layout — i64 → slot 1, String → slot 2 —
    // so (i64,String) and (String,i64) both work; same-kind pairs are out of
    // surface (slot collision).
    en_var_pl2: Vec[i64],
    // Per-ENUM (parallel to `en_names`, Slice 39): the single STRUCT payload
    // kind (10+si) any variant of this enum carries, -1 if none. An enum with
    // a struct payload lays out as { tag, i64, { ptr, i64 }, <struct> } —
    // the always-widened base plus one struct slot (slot 3). One distinct
    // struct payload type per enum (corpus discipline).
    en_extra: Vec[i64],
    en_off: Vec[i64],
    en_cnt: Vec[i64],
}

// Emit a whole program as LLVM IR text. Walks the items, emits `main`'s body
// (Slice 1: `println` of string literals), and assembles the module —
// datalayout / triple / the `@stdout` extern / a shared `@.nl` newline / the
// `@fwrite` declare / the collected string globals / `define i32 @main`.
pub fn emit_program(items: Vec[Item]) -> String with panics {
    let mut e = Emitter {
        globals: "".to_string(),
        funcs: "".to_string(),
        body: "".to_string(),
        nstr: 0,
        ntmp: 0,
        locals: Vec.new(),
        locals_kind: Vec.new(),
        locals_heap: Vec.new(),
        nlbl: 0,
        in_main: false,
        sig_names: Vec.new(),
        sig_ret: Vec.new(),
        sig_par_kinds: Vec.new(),
        sig_par_ref: Vec.new(),
        sig_par_mut: Vec.new(),
        sig_par_off: Vec.new(),
        sig_par_cnt: Vec.new(),
        sig_self_mode: Vec.new(),
        sig_self_kind: Vec.new(),
        cur_ret: -1,
        st_names: Vec.new(),
        st_field_names: Vec.new(),
        st_field_kinds: Vec.new(),
        st_off: Vec.new(),
        st_cnt: Vec.new(),
        entry_allocas: "".to_string(),
        en_names: Vec.new(),
        en_var_names: Vec.new(),
        en_var_pl: Vec.new(),
        en_var_pl2: Vec.new(),
        en_extra: Vec.new(),
        en_off: Vec.new(),
        en_cnt: Vec.new(),
    };
    e.collect_sigs(items);
    for it in items {
        match it {
            Func(f) => {
                let FnDefNode {
                    is_pub,
                    name,
                    generics,
                    self_mode,
                    params,
                    ret,
                    body,
                    attributes,
                    doc,
                    span,
                } = f;
                let rk = match ret {
                    Some(t) => e.kind_of_ty(t),
                    None => 0 - 1,
                };
                e.emit_fn(name, params, rk, body, 0 - 1, 0 - 1);
            }
            Impl(ib) => {
                // Inherent impl methods (Slice 27): each method emits as the
                // mangled free fn `u_<Type>_m_<name>` with the receiver as
                // arg 0 (mode-dependent — value or slot pointer).
                let ImplBlockNode {
                    generics: ig,
                    trait_ty,
                    target_ty,
                    methods,
                    attributes: iattrs,
                    span: isp,
                } = ib;
                let tk = e.kind_of_ty(target_ty);
                if (tk >= 10 and tk < 1000) or (tk >= 1000 and tk < 2000) {
                    let mut tn = "".to_string();
                    if tk < 1000 {
                        tn = e.st_names[tk - 10];
                    } else {
                        tn = e.en_names[tk - 1000];
                    }
                    for m in methods {
                        let FnDefNode {
                            is_pub,
                            name,
                            generics,
                            self_mode,
                            params,
                            ret,
                            body,
                            attributes,
                            doc,
                            span,
                        } = m;
                        let rk = match ret {
                            Some(t) => e.kind_of_ty(t),
                            None => 0 - 1,
                        };
                        let sm = match self_mode {
                            OwnedSelf => 0,
                            RefSelf => 1,
                            MutRefSelf => 2,
                            NoSelf => 0 - 1,
                        };
                        e.emit_fn(tn.clone() + "_m_" + name, params, rk, body, tk, sm);
                    }
                }
            }
            _ => {}
        }
    }
    let Emitter { globals, funcs, body, nstr, ntmp, locals, locals_kind, locals_heap, nlbl, in_main, sig_names, sig_ret, sig_par_kinds, sig_par_ref, sig_par_mut, sig_par_off, sig_par_cnt, sig_self_mode, sig_self_kind, cur_ret, st_names, st_field_names, st_field_kinds, st_off, st_cnt, entry_allocas, en_names, en_var_names, en_var_pl, en_var_pl2, en_extra, en_off, en_cnt } = e;
    let mut out = "".to_string();
    out = out
        + "target datalayout = \"e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128\"\n";
    out = out + "target triple = \"x86_64-pc-linux-gnu\"\n";
    out = out + "@stdout = external global ptr\n";
    out = out + "@.nl = internal constant [2 x i8] c\"\\0A\\00\"\n";
    out = out + "declare i64 @fwrite(ptr, i64, i64, ptr)\n";
    out = out + "declare i32 @snprintf(ptr, i64, ptr, ...)\n";
    out = out + "declare ptr @malloc(i64)\n";
    out = out + "declare ptr @memcpy(ptr, ptr, i64)\n";
    out = out + "declare void @free(ptr)\n";
    out = out + "declare ptr @realloc(ptr, i64)\n";
    out = out + "declare i32 @memcmp(ptr, ptr, i64)\n";
    out = out + "declare i64 @karac_runtime_f64_to_str(double, ptr, i64)\n";
    // Spawn-site metadata stubs (Slice 36): the runtime references these
    // externs from cgus that some runtime calls (e.g. f64_to_str) drag in at
    // link time; the seed's AOT plants them in every object. LEN=0 means the
    // entry array is never dereferenced.
    out = out + "@KARAC_SPAWN_SITES_ENABLED = global i8 0\n";
    out = out + "@KARAC_SPAWN_SITES_LEN = global i32 0\n";
    out = out + "@KARAC_SPAWN_SITES = global [0 x i8] zeroinitializer\n";
    out = out + "@.fmt_i = internal constant [5 x i8] c\"%lld\\00\"\n";
    out = out + "@.true = internal constant [5 x i8] c\"true\\00\"\n";
    out = out + "@.false = internal constant [6 x i8] c\"false\\00\"\n";
    out = out + globals;
    out = out + funcs;
    out
}

impl Emitter {
    // Signature COLLECT pass (Slice 10) — borrows `items` (the emit loop then
    // consumes them; same two-pass shape as the typechecker's Slice 5). Field
    // reads through the `ref` (`f.name`, `f.params`, `f.ret`) are owned
    // deep-copies; the `Option[TypeExpr]` is matched INLINE (never passed by
    // value to a helper — B-2026-07-11-37).
    fn collect_sigs(mut ref self, items: ref Vec[Item]) {
        // SYNTHETIC Option enums (Slice 29) — registered FIRST, before any
        // user enum, as ordinary entries in the en_ tables: Option$i =
        // Option[i64] (Some payload kind 0), Option$s = Option[String]
        // (Some payload kind 2, so en_has_heap widens the layout and the
        // whole tag-conditional ownership machinery applies verbatim). The
        // "$" names can never collide with user idents; tag 0 = None,
        // tag 1 = Some — matching declaration order.
        self.en_names.push("Option$i".to_string());
        self.en_off.push(0);
        self.en_var_names.push("None".to_string());
        self.en_var_pl.push(0 - 1);
        self.en_var_names.push("Some".to_string());
        self.en_var_pl.push(0);
        self.en_cnt.push(2);
        self.en_names.push("Option$s".to_string());
        self.en_off.push(2);
        self.en_var_names.push("None".to_string());
        self.en_var_pl.push(0 - 1);
        self.en_var_names.push("Some".to_string());
        self.en_var_pl.push(2);
        self.en_cnt.push(2);
        // SYNTHETIC Result enums (Slice 30) at FIXED kinds 1002..1005 —
        // one per {i64,String}² payload combination (Ok kind, Err kind);
        // tag 0 = Ok, tag 1 = Err. All four share the WIDENED layout (see
        // ty_text) so an Ok(x)/Err(e) construction is layout-valid for
        // every instantiation and a context-resolved sentinel works.
        self.en_names.push("Result$ii".to_string());
        self.en_off.push(4);
        self.en_var_names.push("Ok".to_string());
        self.en_var_pl.push(0);
        self.en_var_names.push("Err".to_string());
        self.en_var_pl.push(0);
        self.en_cnt.push(2);
        self.en_names.push("Result$is".to_string());
        self.en_off.push(6);
        self.en_var_names.push("Ok".to_string());
        self.en_var_pl.push(0);
        self.en_var_names.push("Err".to_string());
        self.en_var_pl.push(2);
        self.en_cnt.push(2);
        self.en_names.push("Result$si".to_string());
        self.en_off.push(8);
        self.en_var_names.push("Ok".to_string());
        self.en_var_pl.push(2);
        self.en_var_names.push("Err".to_string());
        self.en_var_pl.push(0);
        self.en_cnt.push(2);
        self.en_names.push("Result$ss".to_string());
        self.en_off.push(10);
        self.en_var_names.push("Ok".to_string());
        self.en_var_pl.push(2);
        self.en_var_names.push("Err".to_string());
        self.en_var_pl.push(2);
        self.en_cnt.push(2);
        // Backfill the second-payload table for all synthetics (Slice 35):
        // Option/Result variants are single-payload.
        while self.en_var_pl2.len() < self.en_var_pl.len() {
            self.en_var_pl2.push(0 - 1);
        }
        while self.en_extra.len() < self.en_names.len() {
            self.en_extra.push(0 - 1);
        }
        // Pass A — struct defs (Slice 12), BEFORE fn signatures so a param /
        // return type can name any struct regardless of order. Indexed reads
        // through the ref (`sd.fields[i].ty` — the proven idiom; whole-Vec
        // field copies through a borrowed enum payload are B-2026-07-17-20).
        for it in items {
            match it {
                Struct(sd) => {
                    self.st_names.push(sd.name);
                    let off = self.st_field_names.len();
                    self.st_off.push(off);
                    let cnt = sd.fields.len();
                    let mut fi = 0;
                    while fi < cnt {
                        self.st_field_names.push(sd.fields[fi].name);
                        let fk = self.kind_of_ty(sd.fields[fi].ty);
                        self.st_field_kinds.push(fk);
                        fi = fi + 1;
                    }
                    self.st_cnt.push(cnt);
                }
                Enum(ed) => {
                    // Slice 14: variant names; Slice 23: `en_var_pl` stores the
                    // payload KIND (-1 none, 0 i64, 2 String — from the first
                    // tuple type; wider payloads are out of surface). NOTE:
                    // structs collect BEFORE enums in this same loop iteration
                    // order, so a struct-payload kind would resolve — but only
                    // i64/String payloads are supported downstream.
                    self.en_names.push(ed.name);
                    let off = self.en_var_names.len();
                    self.en_off.push(off);
                    let cnt = ed.variants.len();
                    let mut vi = 0;
                    while vi < cnt {
                        self.en_var_names.push(ed.variants[vi].name);
                        if ed.variants[vi].tuple_types.len() == 0 {
                            self.en_var_pl.push(0 - 1);
                        } else {
                            let pk4 = self.kind_of_ty(ed.variants[vi].tuple_types[0]);
                            self.en_var_pl.push(pk4);
                        }
                        if ed.variants[vi].tuple_types.len() >= 2 {
                            // Two-payload variant (Slice 35).
                            let pk5 = self.kind_of_ty(ed.variants[vi].tuple_types[1]);
                            self.en_var_pl2.push(pk5);
                        } else {
                            self.en_var_pl2.push(0 - 1);
                        }
                        vi = vi + 1;
                    }
                    self.en_cnt.push(cnt);
                    // Struct payload slot (Slice 39): record the single
                    // distinct struct payload kind, if any.
                    let eoff2 = self.en_off[self.en_names.len() - 1];
                    let mut ex = 0 - 1;
                    let mut vj = 0;
                    while vj < cnt {
                        let p1 = self.en_var_pl[eoff2 + vj];
                        if p1 >= 10 and p1 < 1000 {
                            ex = p1;
                        }
                        vj = vj + 1;
                    }
                    self.en_extra.push(ex);
                }
                _ => {}
            }
        }
        for it in items {
            match it {
                Func(f) => {
                    self.sig_names.push(f.name);
                    let rk = match f.ret {
                        Some(t) => self.kind_of_ty(t),
                        None => 0 - 1,
                    };
                    self.sig_ret.push(rk);
                    let off = self.sig_par_kinds.len();
                    self.sig_par_off.push(off);
                    let cnt = f.params.len();
                    let mut pi2 = 0;
                    while pi2 < cnt {
                        let rk2 = self.peel_ref(f.params[pi2].ty);
                        let RefKind { kind: pk, is_ref: pr, is_mut: pm } = rk2;
                        self.sig_par_kinds.push(pk);
                        self.sig_par_ref.push(pr);
                        self.sig_par_mut.push(pm);
                        pi2 = pi2 + 1;
                    }
                    self.sig_par_cnt.push(cnt);
                    self.sig_self_mode.push(0 - 1);
                    self.sig_self_kind.push(0 - 1);
                }
                Impl(ib) => {
                    // Inherent impl methods (Slice 27; ENUM receivers Slice
                    // 31): each method signs in as "<Type>.<name>" with its
                    // receiver mode + kind. All reads are INDEXED through the
                    // borrowed payload (the B-2026-07-17-20 discipline).
                    let tk = self.kind_of_ty(ib.target_ty);
                    if (tk >= 10 and tk < 1000) or (tk >= 1000 and tk < 2000) {
                        let mut tn = "".to_string();
                        if tk < 1000 {
                            tn = self.st_names[tk - 10];
                        } else {
                            tn = self.en_names[tk - 1000];
                        }
                        let mcnt = ib.methods.len();
                        let mut mi = 0;
                        while mi < mcnt {
                            self.sig_names.push(tn.clone() + "." + ib.methods[mi].name);
                            let mrk = match ib.methods[mi].ret {
                                Some(t) => self.kind_of_ty(t),
                                None => 0 - 1,
                            };
                            self.sig_ret.push(mrk);
                            let off2 = self.sig_par_kinds.len();
                            self.sig_par_off.push(off2);
                            let pcnt = ib.methods[mi].params.len();
                            let mut pj = 0;
                            while pj < pcnt {
                                let rk3 = self.peel_ref(ib.methods[mi].params[pj].ty);
                                let RefKind { kind: pk2, is_ref: pr2, is_mut: pm2 } = rk3;
                                self.sig_par_kinds.push(pk2);
                                self.sig_par_ref.push(pr2);
                                self.sig_par_mut.push(pm2);
                                pj = pj + 1;
                            }
                            self.sig_par_cnt.push(pcnt);
                            let sm = match ib.methods[mi].self_mode {
                                OwnedSelf => 0,
                                RefSelf => 1,
                                MutRefSelf => 2,
                                NoSelf => 0 - 1,
                            };
                            self.sig_self_mode.push(sm);
                            if sm >= 0 {
                                self.sig_self_kind.push(tk);
                            } else {
                                self.sig_self_kind.push(0 - 1);
                            }
                            mi = mi + 1;
                        }
                    }
                }
                _ => {}
            }
        }
    }

    // Map a DECLARED type to a value kind (Slice 10; struct-aware Slice 12):
    // String → 2, bool → 1, a registered struct → 10+index, else 0.
    fn kind_of_ty(ref self, t: TypeExpr) -> i64 {
        match t {
            PathTy(p) => {
                let PathType { segments, generics, span } = p;
                if segments.len() == 0 {
                    return 0;
                }
                if segments[0] == "String" {
                    return 2;
                }
                if segments[0] == "bool" {
                    return 1;
                }
                if segments[0] == "f64" {
                    // f64 (Slice 36).
                    return 5;
                }
                if segments[0] == "Option" {
                    // Option[i64] / Option[String] (Slice 29): the synthetic
                    // enums registered first in collect_sigs — indexes 0/1
                    // by construction.
                    if generics.len() == 1 {
                        let gk2 = self.kind_of_ty(generics[0]);
                        if gk2 == 2 {
                            return 1001;
                        }
                    }
                    return 1000;
                }
                if segments[0] == "Result" {
                    // Result[T, E] over {i64,String}² (Slice 30): fixed
                    // synthetic kinds 1002..1005 by payload combination.
                    if generics.len() == 2 {
                        let ok2 = self.kind_of_ty(generics[0]);
                        let ek2 = self.kind_of_ty(generics[1]);
                        let mut rkk = 1002;
                        if ok2 == 2 {
                            rkk = rkk + 2;
                        }
                        if ek2 == 2 {
                            rkk = rkk + 1;
                        }
                        return rkk;
                    }
                    return 1002;
                }
                if segments[0] == "Vec" {
                    // Slice 16: Vec[String] (kind 4, {ptr,i64} elements) vs
                    // Vec[i64] (kind 3); Slice 18: Vec[<struct>] (kind
                    // 2000+si). The element kind comes from the annotation —
                    // the single-pass emitter cannot infer it from later
                    // pushes.
                    if generics.len() == 1 {
                        let gk = self.kind_of_ty(generics[0]);
                        if gk == 2 {
                            return 4;
                        }
                        if gk >= 10 and gk < 1000 {
                            return 2000 + (gk - 10);
                        }
                        if gk >= 1000 and gk < 2000 {
                            // Vec[<enum>] (Slice 32): kind space 4000+ei.
                            return 4000 + (gk - 1000);
                        }
                    }
                    return 3;
                }
                let mut i = 0;
                while i < self.st_names.len() {
                    if self.st_names[i] == segments[0] {
                        return 10 + i;
                    }
                    i = i + 1;
                }
                let mut j = 0;
                while j < self.en_names.len() {
                    if self.en_names[j] == segments[0] {
                        return 1000 + j;
                    }
                    j = j + 1;
                }
                0
            }
            _ => 0,
        }
    }

    // Peel a `ref T` parameter type to (inner kind, is_ref) — Slice 19. A
    // ref param passes the same aggregate BY VALUE as a BORROW: the caller
    // skips materialization, the callee skips the epilogue free.
    fn peel_ref(ref self, t: TypeExpr) -> RefKind {
        match t {
            RefTy(w) => {
                let WrapType { inner, span } = w;
                RefKind {
                    kind: self.kind_of_ty(inner),
                    is_ref: true,
                    is_mut: false,
                }
            }
            MutRefTy(w) => {
                // `mut ref T` (Slice 20): a true BY-REFERENCE param — the
                // callee receives a POINTER to the caller's slot.
                let WrapType { inner, span } = w;
                RefKind {
                    kind: self.kind_of_ty(inner),
                    is_ref: true,
                    is_mut: true,
                }
            }
            other => RefKind {
                kind: self.kind_of_ty(other),
                is_ref: false,
                is_mut: false,
            },
        }
    }

    // The LLVM type text for a value kind, struct-aware (Slice 12). The
    // struct text is REBUILT from field kinds on each call — returning a
    // stored Vec[String] element from a method is an AOT double-free.
    fn ty_text(ref self, kind: i64) -> String {
        if kind >= 2000 {
            return "{ ptr, i64, i64 }".to_string();
        }
        if kind >= 1000 {
            // A str-enum (Slice 23: any variant carries a String payload)
            // widens to { tag, i64 payload, String payload }; pure-i64 enums
            // keep the two-slot layout. The four synthetic Result kinds
            // (Slice 30) are ALWAYS widened — even Result$ii — so every
            // instantiation shares one layout and Ok/Err construction is
            // context-free. A STRUCT-payload enum (Slice 39) appends the
            // struct as slot 3 to the widened base.
            if self.en_extra[kind - 1000] >= 0 {
                return "{ i64, i64, { ptr, i64 }, ".to_string()
                    + self.ty_text(self.en_extra[kind - 1000])
                    + " }";
            }
            if kind >= 1002 and kind <= 1005 {
                return "{ i64, i64, { ptr, i64 } }".to_string();
            }
            if self.en_has_heap(kind - 1000) {
                return "{ i64, i64, { ptr, i64 } }".to_string();
            }
            return "{ i64, i64 }".to_string();
        }
        if kind >= 10 {
            let si = kind - 10;
            let off = self.st_off[si];
            let cnt = self.st_cnt[si];
            let mut ty = "{ ".to_string();
            let mut fi = 0;
            while fi < cnt {
                if fi > 0 {
                    ty = ty + ", ";
                }
                // RECURSIVE (Slice 33): a nested struct/enum field renders
                // its own aggregate type text.
                ty = ty + self.ty_text(self.st_field_kinds[off + fi]);
                fi = fi + 1;
            }
            return ty + " }";
        }
        kind_ty(kind)
    }

    // The emitted-symbol form of a sig name (Slice 27): a method/associated
    // sig "Type.name" mangles its dot to "_m_"; a free-fn name passes through.
    fn sym_of(ref self, cname: ref String) -> String {
        let n = cname.len();
        let mut i = 0;
        while i < n {
            if cname.substring(i, i + 1) == "." {
                return cname.substring(0, i) + "_m_" + cname.substring(i + 1, n);
            }
            i = i + 1;
        }
        cname.clone()
    }

    // Index of struct `name` in the struct table, -1 if unknown.
    fn st_index(ref self, name: ref String) -> i64 {
        let mut i = 0;
        while i < self.st_names.len() {
            if self.st_names[i] == name {
                return i;
            }
            i = i + 1;
        }
        0 - 1
    }

    // Index of fn `name` in the signature table, -1 if unknown.
    fn sig_index(ref self, name: ref String) -> i64 {
        let mut i = 0;
        while i < self.sig_names.len() {
            if self.sig_names[i] == name {
                return i;
            }
            i = i + 1;
        }
        0 - 1
    }

    // Index of enum `name` in the enum table, -1 if unknown.
    fn en_index(ref self, name: ref String) -> i64 {
        let mut i = 0;
        while i < self.en_names.len() {
            if self.en_names[i] == name {
                return i;
            }
            i = i + 1;
        }
        0 - 1
    }

    // Tag (declaration index) of `vname` within enum `ei`, -1 if not a variant.
    fn en_variant_tag(ref self, ei: i64, vname: ref String) -> i64 {
        let off = self.en_off[ei];
        let cnt = self.en_cnt[ei];
        let mut vi = 0;
        while vi < cnt {
            if self.en_var_names[off + vi] == vname {
                return vi;
            }
            vi = vi + 1;
        }
        0 - 1
    }

    // Emit ONE function definition (Slice 6). Per-fn state (`body`, `locals`)
    // resets; `ntmp`/`nlbl` keep counting (registers/labels are function-scoped
    // in LLVM, so uniqueness across fns is merely convenient). Each parameter
    // gets a stack slot (`alloca` + store of the incoming `%aN`), so params
    // behave exactly like `let` locals. `main` becomes `define i32 @main`
    // (always `ret i32 0`); a user fn becomes `define i64 @u_<name>` (the
    // `u_` prefix keeps user names clear of libc/runtime symbols) whose tail
    // expression is its return value (default 0). Everything is i64.
    fn emit_fn(
        mut ref self,
        name: String,
        params: Vec[FnParamNode],
        rk: i64,
        b: Block,
        self_kind: i64,
        self_mode: i64,
    ) {
        self.body = "".to_string();
        self.entry_allocas = "".to_string();
        self.locals = Vec.new();
        self.locals_kind = Vec.new();
        self.locals_heap = Vec.new();
        let is_main = name == "main";
        self.in_main = is_main;
        self.cur_ret = rk;
        let mut sig = "".to_string();
        let mut pre = "".to_string();
        let mut pi = 0;
        if self_mode >= 0 {
            // The RECEIVER (Slice 27) is arg 0, registered as the slot named
            // "self" — the same three modes as ordinary params: owned self
            // moves in (callee frees a heap-bearing receiver at epilogue),
            // `ref self` is a borrow bit-copy, `mut ref self` is a pointer
            // to the caller's slot aliased to the canonical %v name.
            let sty2 = self.ty_text(self_kind);
            let sidx = self.locals.len();
            self.locals.push("self".to_string());
            self.locals_kind.push(self_kind);
            let mut sowns = false;
            if self_mode == 0 {
                if self_kind >= 10 and self_kind < 1000 {
                    sowns = self.st_has_heap(self_kind - 10);
                }
                if self_kind >= 1000 and self_kind < 2000 {
                    // Owned enum self (Slice 31).
                    sowns = self.en_has_heap(self_kind - 1000);
                }
            }
            self.locals_heap.push(sowns);
            if self_mode == 2 {
                sig = "ptr %a0".to_string();
                pre = pre
                    + "  %v"
                    + sidx.to_string()
                    + " = getelementptr i8, ptr %a0, i64 0\n";
            } else {
                sig = sty2.clone() + " %a0";
                pre = pre + "  %v" + sidx.to_string() + " = alloca " + sty2.clone() + ", align 8\n";
                pre = pre
                    + "  store "
                    + sty2
                    + " %a0, ptr %v"
                    + sidx.to_string()
                    + ", align 8\n";
            }
            pi = 1;
        }
        for p in params {
            let FnParamNode { name: pn, ty, span } = p;
            // Typed params (Slice 10): the declared type picks the slot kind;
            // a String param arrives as an OWNED `{ ptr, i64 }` aggregate the
            // callee frees at its epilogue (args move in — the caller passes
            // an owned copy or transfers a temp).
            let rk3 = self.peel_ref(ty);
            let RefKind { kind: pk, is_ref: pref, is_mut: pmut } = rk3;
            let pty = self.ty_text(pk);
            let idx = self.locals.len();
            self.locals.push(pn);
            self.locals_kind.push(pk);
            // A `ref` param is a BORROW (Slice 19): the callee never frees it.
            let mut owns = pk == 2 or pk == 3 or pk == 4 or pk >= 2000;
            if pk >= 10 and pk < 1000 {
                owns = self.st_has_heap(pk - 10);
            }
            if pk >= 1000 and pk < 2000 {
                owns = self.en_has_heap(pk - 1000);
            }
            if pref {
                owns = false;
            }
            self.locals_heap.push(owns);
            if pi > 0 {
                sig = sig + ", ";
            }
            if pmut {
                // `mut ref` (Slice 20): the param IS a pointer to the caller's
                // slot. A no-op GEP gives it the canonical `%v<idx>` slot name
                // so every existing slot-addressing site works unchanged —
                // loads/stores/pushes through it hit the caller's storage.
                sig = sig + "ptr %a" + pi.to_string();
                pre = pre
                    + "  %v"
                    + idx.to_string()
                    + " = getelementptr i8, ptr %a"
                    + pi.to_string()
                    + ", i64 0\n";
            } else {
                sig = sig + pty.clone() + " %a" + pi.to_string();
                pre = pre + "  %v" + idx.to_string() + " = alloca " + pty.clone() + ", align 8\n";
                pre = pre
                    + "  store "
                    + pty
                    + " %a"
                    + pi.to_string()
                    + ", ptr %v"
                    + idx.to_string()
                    + ", align 8\n";
            }
            pi = pi + 1;
        }
        let Block { stmts, tail, span: bsp } = b;
        for st in stmts {
            self.emit_stmt(st);
        }
        // A VALUE-returning fn's tail is its return value; a UNIT fn's tail
        // (main, or any fn without `-> T`) is a side-effect expression (e.g. a
        // trailing `println`) — walked as a statement. A STRING return value
        // that is a BORROW (a returned param/local — freed by this fn's own
        // epilogue) is MATERIALIZED into an owned copy the caller receives.
        let use_val = rk >= 0 and not is_main;
        let mut tv = "0".to_string();
        if rk == 1 {
            tv = "false".to_string();
        }
        if rk == 2 or rk == 3 or rk == 4 or rk >= 10 {
            tv = "zeroinitializer".to_string();
        }
        if rk == 5 {
            tv = "0.0".to_string();
        }
        match tail {
            Some(e) => {
                if use_val {
                    let v = self.emit_value(e);
                    let Val { op, kind, heap } = v;
                    if rk == 2 {
                        if kind == 2 {
                            if heap {
                                tv = op;
                            } else {
                                let mv = self.emit_materialize(op);
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                tv = mop;
                            }
                        }
                    } else {
                        if kind == rk {
                            tv = op;
                            if rk >= 10 and rk < 1000 and not heap {
                                // A returned BORROW of a heap-bearing struct
                                // (Slice 15): the caller receives an owned
                                // deep copy; the epilogue frees the original.
                                if self.st_has_heap(rk - 10) {
                                    let mv = self.emit_materialize_struct(tv.clone(), rk - 10);
                                    let Val { op: mop, kind: mk, heap: mh } = mv;
                                    tv = mop;
                                }
                            }
                            if rk >= 1000 and rk < 2000 and not heap {
                                // A returned str-enum BORROW (Slice 23).
                                if self.en_has_heap(rk - 1000) {
                                    let mv = self.emit_materialize_enum(tv.clone(), rk - 1000);
                                    let Val { op: mop, kind: mk, heap: mh } = mv;
                                    tv = mop;
                                }
                            }
                            if (rk == 3 or rk == 4 or rk >= 2000) and not heap {
                                // A returned vec BORROW (Slice 24): the caller
                                // receives an owned deep copy; the epilogue
                                // frees the original.
                                let mv = self.emit_materialize_vec(tv.clone(), rk);
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                tv = mop;
                            }
                        }
                        if kind == 0 - 9 or kind == 0 - 10 {
                            // A sentinel-kinded None/Ok/Err tail (Slices
                            // 29/30): the value is layout-valid for the
                            // declared return kind as-is.
                            tv = op;
                        }
                    }
                } else {
                    self.emit_expr(e);
                }
            }
            None => {}
        }
        // Scope-exit epilogue (Slice 9): free every slot that still OWNS a
        // heap buffer. Runs before the default ret; mid-fn `return`s emit the
        // same frees before their own ret (Slice 22).
        self.emit_scope_frees();
        if is_main {
            self.funcs = self.funcs
                + "define i32 @main() {\nentry:\n"
                + pre
                + self.entry_allocas.clone()
                + self.body.clone()
                + "  ret i32 0\n}\n";
        } else {
            let mut rty = "i64".to_string();
            if rk == 1 or rk == 2 or rk == 3 or rk == 4 or rk == 5 or rk >= 10 {
                rty = self.ty_text(rk);
            }
            self.funcs = self.funcs
                + "define "
                + rty.clone()
                + " @u_"
                + name
                + "("
                + sig
                + ") {\nentry:\n"
                + pre
                + self.entry_allocas.clone()
                + self.body.clone()
                + "  ret "
                + rty
                + " "
                + tv
                + "\n}\n";
        }
    }

    // Free every slot that still OWNS a heap buffer — the fn-exit epilogue.
    // Safe to run at ANY exit point (including a mid-fn `return` before later
    // `let`s have executed): every slot is an entry-block alloca zero-
    // initialized upfront, so an unexecuted let's slot holds zeroinit and its
    // free is a no-op (free(null)). Slots registered after the exit point at
    // WALK time aren't in locals_heap yet, but on that dynamic path they hold
    // zeroinit anyway — nothing to free.
    fn emit_scope_frees(mut ref self) {
        let mut fi = 0;
        while fi < self.locals_heap.len() {
            if self.locals_heap[fi] {
                self.emit_free_slot(fi);
            }
            fi = fi + 1;
        }
    }

    // Walk a block and return its TAIL value (0 if none) — the value-position
    // sibling of `emit_block` (Slice 6: if-as-value branches).
    fn emit_block_value(mut ref self, b: Block) -> Val {
        let Block { stmts, tail, span } = b;
        for st in stmts {
            self.emit_stmt(st);
        }
        let mut v = Val { op: "0".to_string(), kind: 0, heap: false };
        match tail {
            Some(e) => {
                v = self.emit_value(e);
            }
            None => {}
        }
        v
    }

    // Walk a block: every statement, then the tail expression if present.
    fn emit_block(mut ref self, b: Block) {
        let Block { stmts, tail, span } = b;
        for st in stmts {
            self.emit_stmt(st);
        }
        match tail {
            Some(e) => {
                self.emit_expr(e);
            }
            None => {}
        }
    }

    // Expression statements (Slice 1), `let` bindings and assignments (Slice 3).
    fn emit_stmt(mut ref self, st: Stmt) {
        match st {
            Exp(es) => {
                let ExprStmt { expr, span } = es;
                self.emit_expr(expr);
            }
            Let(ls) => {
                // `let [mut] name = <int-expr>`: register the binding, alloca an
                // i64 slot `%v<idx>`, evaluate the initializer, store. Only a
                // plain binding pattern is handled; the annotation is ignored
                // (everything is i64 in the Slice-3 surface).
                let LetStmt { is_mut, pattern, ty, value, span } = ls;
                match pattern {
                    BindingPat(bp) => {
                        let BindingPattern { name, span: bsp } = bp;
                        let v1 = self.emit_value(value);
                        let Val { op: v0op, kind: vk, heap: v0h } = v1;
                        let mut v = v0op;
                        let mut vh = v0h;
                        if vk == 2 and not vh {
                            let mv = self.emit_materialize(v.clone());
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            v = mop;
                            vh = true;
                        }
                        if vk >= 10 and vk < 1000 and not vh {
                            // A borrowed heap-bearing struct (Slice 15): the
                            // binding owns a deep copy of its String fields.
                            if self.st_has_heap(vk - 10) {
                                let mv = self.emit_materialize_struct(v.clone(), vk - 10);
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                v = mop;
                                vh = true;
                            }
                        }
                        if vk >= 1000 and vk < 2000 and not vh {
                            // A borrowed str-enum (Slice 23): tag-conditional
                            // payload deep copy.
                            if self.en_has_heap(vk - 1000) {
                                let mv = self.emit_materialize_enum(v.clone(), vk - 1000);
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                v = mop;
                                vh = true;
                            }
                        }
                        if (vk == 3 or vk == 4 or vk >= 2000) and not vh {
                            // A borrowed vec (Slice 24): the binding owns a
                            // deep copy — elements included.
                            let mv = self.emit_materialize_vec(v.clone(), vk);
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            v = mop;
                            vh = true;
                        }
                        let mut vk2 = vk;
                        if vk == 3 {
                            // `let mut v: Vec[String] = Vec.new()` (Slice 16):
                            // the annotation retypes the zeroinit vec to kind 4
                            // (bit-identical empty header, different element
                            // discipline from here on).
                            match ty {
                                Some(t) => {
                                    let dk = self.kind_of_ty(t);
                                    if dk == 4 or dk >= 2000 {
                                        vk2 = dk;
                                    }
                                }
                                None => {}
                            }
                        }
                        if vk == 0 - 9 or vk == 0 - 10 {
                            // `let x: Option[T] = None` / `let r: Result[T,E]
                            // = Ok(x)` (Slices 29/30): the annotation supplies
                            // the concrete kind; unannotated defaults are
                            // Option[i64] / Result[i64,i64]. A heap-bearing
                            // resolved kind marks the slot OWNING — the frees
                            // are tag-conditional, so this is safe for any
                            // runtime tag.
                            vk2 = 1000;
                            if vk == 0 - 10 {
                                vk2 = 1002;
                            }
                            match ty {
                                Some(t) => {
                                    let dk2 = self.kind_of_ty(t);
                                    if dk2 >= 1000 and dk2 < 2000 {
                                        vk2 = dk2;
                                    }
                                }
                                None => {}
                            }
                            if self.en_has_heap(vk2 - 1000) {
                                vh = true;
                            }
                        }
                        let vk = vk2;
                        let idx = self.locals.len();
                        self.locals.push(name);
                        self.locals_kind.push(vk);
                        self.locals_heap.push(vh);
                        let ty = self.ty_text(vk);
                        let slot = "%v" + idx.to_string();
                        // Slot lives in the ENTRY block, zeroed once — a `let`
                        // in a loop body re-executes into the same slot, so
                        // free the previous value first (null-safe on pass 1).
                        self.entry_allocas = self.entry_allocas
                            + "  "
                            + slot.clone()
                            + " = alloca "
                            + ty.clone()
                            + ", align 8\n";
                        let mut zi = "zeroinitializer".to_string();
                        if vk == 0 {
                            zi = "0".to_string();
                        }
                        if vk == 1 {
                            zi = "false".to_string();
                        }
                        if vk == 5 {
                            // Scalar double: zeroinitializer is aggregate-only.
                            zi = "0.0".to_string();
                        }
                        self.entry_allocas = self.entry_allocas
                            + "  store "
                            + ty.clone()
                            + " "
                            + zi
                            + ", ptr "
                            + slot.clone()
                            + ", align 8\n";
                        if vh {
                            self.emit_free_slot(idx);
                        }
                        self.body = self.body
                            + "  store "
                            + ty
                            + " "
                            + v
                            + ", ptr "
                            + slot
                            + ", align 8\n";
                    }
                    _ => {}
                }
            }
            Assign(asn) => {
                // `name = <int-expr>`: evaluate, store into the existing slot.
                let AssignStmt { target, value, span } = asn;
                match target {
                    Field(fa2) => {
                        // FIELD assignment `p.x = v` (Slice 21): GEP the
                        // struct slot's field and store — works identically
                        // through a `mut ref` struct param (the aliased slot
                        // pointer). A String field frees its OLD buffer after
                        // the RHS evaluates and materializes a borrowed RHS in.
                        let FieldAccessExpr { object: fobj, field: fname2, span: fsp2 } = fa2;
                        let mut sidx = 0 - 1;
                        match fobj {
                            Ident(fie) => {
                                let IdentExpr { name: fon, span: fosp } = fie;
                                sidx = self.local_slot(fon);
                            }
                            SelfVal(sn3) => {
                                // `self.x = v` in a method body (Slice 27).
                                let sname2 = "self".to_string();
                                sidx = self.local_slot(sname2);
                            }
                            _ => {}
                        }
                        if sidx >= 0 {
                            let sk3 = self.locals_kind[sidx];
                            if sk3 >= 10 and sk3 < 1000 {
                                let esi = sk3 - 10;
                                let off = self.st_off[esi];
                                let cnt = self.st_cnt[esi];
                                let mut fi2 = 0;
                                let mut fidx = 0 - 1;
                                let mut fkind = 0;
                                while fi2 < cnt {
                                    if self.st_field_names[off + fi2] == fname2 {
                                        fidx = fi2;
                                        fkind = self.st_field_kinds[off + fi2];
                                    }
                                    fi2 = fi2 + 1;
                                }
                                if fidx >= 0 {
                                    let v2 = self.emit_value(value);
                                    let Val { op: fv0, kind: fvk, heap: fvh } = v2;
                                    let mut fv = fv0;
                                    if fkind == 2 and fvk == 2 and not fvh {
                                        let mv = self.emit_materialize(fv.clone());
                                        let Val { op: mop, kind: mk, heap: mh } = mv;
                                        fv = mop;
                                    }
                                    let sty = self.ty_text(sk3);
                                    let fp = self.fresh();
                                    self.body = self.body
                                        + "  "
                                        + fp.clone()
                                        + " = getelementptr "
                                        + sty
                                        + ", ptr %v"
                                        + sidx.to_string()
                                        + ", i32 0, i32 "
                                        + fidx.to_string()
                                        + "\n";
                                    if fkind == 2 {
                                        let oldv = self.fresh();
                                        self.body = self.body
                                            + "  "
                                            + oldv.clone()
                                            + " = load { ptr, i64 }, ptr "
                                            + fp.clone()
                                            + ", align 8\n";
                                        self.emit_free_val(oldv);
                                    }
                                    self.body = self.body
                                        + "  store "
                                        + kind_ty(fkind)
                                        + " "
                                        + fv
                                        + ", ptr "
                                        + fp
                                        + ", align 8\n";
                                }
                            }
                        }
                    }
                    Ident(ie) => {
                        let IdentExpr { name, span: isp } = ie;
                        let idx = self.local_slot(name);
                        if idx >= 0 {
                            let v1 = self.emit_value(value);
                            let Val { op: v0op, kind: vk0, heap: v0h } = v1;
                            let mut vk = vk0;
                            if vk == 0 - 9 or vk == 0 - 10 {
                                // A sentinel-kinded None/Ok/Err RHS (Slices
                                // 29/30) takes the SLOT's concrete kind — the
                                // value layout is context-free by design.
                                vk = self.locals_kind[idx];
                            }
                            let mut v = v0op;
                            let mut vh = v0h;
                            if vk == 2 and not vh {
                                let mv = self.emit_materialize(v.clone());
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                v = mop;
                                vh = true;
                            }
                            if vk >= 10 and vk < 1000 and not vh {
                                if self.st_has_heap(vk - 10) {
                                    let mv = self.emit_materialize_struct(v.clone(), vk - 10);
                                    let Val { op: mop, kind: mk, heap: mh } = mv;
                                    v = mop;
                                    vh = true;
                                }
                            }
                            if vk >= 1000 and vk < 2000 and not vh {
                                if self.en_has_heap(vk - 1000) {
                                    let mv = self.emit_materialize_enum(v.clone(), vk - 1000);
                                    let Val { op: mop, kind: mk, heap: mh } = mv;
                                    v = mop;
                                    vh = true;
                                }
                            }
                            if (vk == 3 or vk == 4 or vk >= 2000) and not vh {
                                let mv = self.emit_materialize_vec(v.clone(), vk);
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                v = mop;
                                vh = true;
                            }
                            // Free the slot's OLD owned buffer after the RHS
                            // evaluated (the RHS may read it — `s = s + "x"`)
                            // and before the store repoints the slot (Slice 9).
                            if self.locals_heap[idx] {
                                self.emit_free_slot(idx);
                            }
                            self.locals_heap[idx] = vh;
                            let ty = self.ty_text(vk);
                            self.body = self.body
                                + "  store "
                                + ty
                                + " "
                                + v
                                + ", ptr %v"
                                + idx.to_string()
                                + ", align 8\n";
                        }
                    }
                    _ => {}
                }
            }
        }
    }

    // The slot index of local `name` (NEWEST-first scan, so a shadowing `let`
    // wins), or -1 if unbound.
    fn local_slot(ref self, name: ref String) -> i64 {
        let mut i = self.locals.len() - 1;
        loop {
            if i < 0 {
                return -1;
            }
            if self.locals[i] == name {
                return i;
            }
            i = i - 1;
        }
    }

    // Slice 1 handles only `println(<string literal>)`. The callee is matched
    // inline (an `Ident` named `println`); each string-literal argument is
    // emitted, anything else is skipped.
    fn emit_expr(mut ref self, e: Expr) {
        match e {
            Call(n) => {
                let CallExpr { callee, args, span } = n;
                let mut cname = "".to_string();
                match callee {
                    Ident(ie) => {
                        let IdentExpr { name, span: isp } = ie;
                        cname = name;
                    }
                    _ => {}
                }
                if cname == "println" {
                    // Every arg shape routes through `emit_value` and a
                    // kind-dispatch print (Slice 7): a literal keeps its fast
                    // path; `<expr>.to_string()` prints the OBJECT's value
                    // (formatting happens at print time — the identity holds
                    // because to_string only feeds println in this surface);
                    // any other expr (a string local, a computed value) prints
                    // by its emitted kind.
                    for a in args {
                        let CallArg { label, mut_marker, value, span: asp } = a;
                        match value {
                            Str(sl) => {
                                let StrLit { value: sv, span: ssp } = sl;
                                self.emit_println_str(sv);
                            }
                            MethodCall(mc) => {
                                // Destructure ONCE and dispatch on the parts
                                // (Slice 17) — rebuilding or re-wrapping the
                                // node both double-free under the seed's AOT.
                                let MethodCallExpr { object, method, args: margs, span: msp } = mc;
                                if method == "to_string" {
                                    let val = self.emit_value(object);
                                    let Val { op, kind, heap } = val;
                                    self.emit_println_val(op, kind, heap);
                                } else {
                                    let val = self.emit_method_value(object, method, margs);
                                    let Val { op, kind, heap } = val;
                                    self.emit_println_val(op, kind, heap);
                                }
                            }
                            other => {
                                let val = self.emit_value(other);
                                let Val { op, kind, heap } = val;
                                self.emit_println_val(op, kind, heap);
                            }
                        }
                    }
                } else {
                    // A user-function call in STATEMENT position (Slice 6):
                    // emit it and discard the result — freeing a discarded
                    // OWNED string result (Slice 10).
                    let si = self.sig_index(cname);
                    let mut alist = "".to_string();
                    let mut ai = 0;
                    let mut rt_ops: Vec[String] = Vec.new();
                    let mut rt_kinds: Vec[i64] = Vec.new();
                    for a in args {
                        let CallArg { label, mut_marker, value, span: asp } = a;
                        // `mut ref` params (Slice 20): the arg must be a local
                        // place — pass its SLOT POINTER, no evaluation.
                        let mut amut = false;
                        if si >= 0 {
                            if ai < self.sig_par_cnt[si] {
                                amut = self.sig_par_mut[self.sig_par_off[si] + ai];
                            }
                        }
                        if amut {
                            let mut aslot = 0 - 1;
                            match value {
                                Ident(mie) => {
                                    let IdentExpr { name: mn, span: msp2 } = mie;
                                    aslot = self.local_slot(mn);
                                }
                                _ => {}
                            }
                            if ai > 0 {
                                alist = alist + ", ";
                            }
                            alist = alist + "ptr %v" + aslot.to_string();
                            ai = ai + 1;
                            continue;
                        }
                        let v = self.emit_value(value);
                        let Val { op, kind, heap } = v;
                        let mut pk = 0;
                        let mut pref = false;
                        if si >= 0 {
                            if ai < self.sig_par_cnt[si] {
                                pk = self.sig_par_kinds[self.sig_par_off[si] + ai];
                                pref = self.sig_par_ref[self.sig_par_off[si] + ai];
                            }
                        }
                        let mut aop = op;
                        // A `ref` param takes the borrow bit-copy directly (Slice 19).
                        if pk == 2 and not pref and kind == 2 and not heap {
                            let mv = self.emit_materialize(aop.clone());
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            aop = mop;
                        }
                        if pk >= 10 and pk < 1000 and not pref and kind == pk and not heap {
                            // A borrowed heap-bearing struct arg moves in as a
                            // deep copy (Slice 15); a temp transfers.
                            if self.st_has_heap(pk - 10) {
                                let mv = self.emit_materialize_struct(aop.clone(), pk - 10);
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                aop = mop;
                            }
                        }
                        if pk >= 1000 and pk < 2000 and not pref and kind == pk and not heap {
                            // A borrowed str-enum arg moves in as a payload
                            // deep copy (Slice 23); a temp transfers.
                            if self.en_has_heap(pk - 1000) {
                                let mv = self.emit_materialize_enum(aop.clone(), pk - 1000);
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                aop = mop;
                            }
                        }
                        if (pk == 3 or pk == 4 or pk >= 2000)
                            and not pref
                            and kind == pk
                            and not heap
                        {
                            // A borrowed vec arg moves in as a deep copy
                            // (Slice 24); a temp transfers.
                            let mv = self.emit_materialize_vec(aop.clone(), pk);
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            aop = mop;
                        }
                        if pref and heap {
                            // Heap temp lent to a `ref` param (Slice 40):
                            // caller frees post-call.
                            rt_ops.push(aop.clone());
                            rt_kinds.push(pk);
                        }
                        if ai > 0 {
                            alist = alist + ", ";
                        }
                        alist = alist + self.ty_text(pk) + " " + aop;
                        ai = ai + 1;
                    }
                    if cname != "" {
                        let mut rk = 0;
                        if si >= 0 {
                            rk = self.sig_ret[si];
                        }
                        let r = self.fresh();
                        if rk == 1 {
                            self.body = self.body
                                + "  "
                                + r.clone()
                                + " = call i1 @u_"
                                + cname
                                + "("
                                + alist
                                + ")\n";
                        } else if rk == 2 {
                            self.body = self.body
                                + "  "
                                + r.clone()
                                + " = call { ptr, i64 } @u_"
                                + cname
                                + "("
                                + alist
                                + ")\n";
                            self.emit_free_val(r);
                        } else if rk == 3 or rk == 4 or rk == 5 or rk >= 10 {
                            self.body = self.body
                                + "  "
                                + r.clone()
                                + " = call "
                                + self.ty_text(rk)
                                + " @u_"
                                + cname
                                + "("
                                + alist
                                + ")\n";
                            if rk >= 10 and rk < 1000 and self.st_has_heap(rk - 10) {
                                self.emit_free_struct_val(r.clone(), rk - 10);
                            }
                            if rk >= 1000 and rk < 2000 and self.en_has_heap(rk - 1000) {
                                // A discarded str-enum result (Slice 23).
                                self.emit_free_enum_val(r.clone(), rk - 1000);
                            }
                            if rk == 3 or rk == 4 or rk >= 2000 {
                                // A discarded vec result (Slice 24).
                                self.emit_free_vec_val(r, rk);
                            }
                        } else {
                            self.body = self.body
                                + "  "
                                + r
                                + " = call i64 @u_"
                                + cname
                                + "("
                                + alist
                                + ")\n";
                        }
                        self.emit_ref_temp_frees(rt_ops, rt_kinds);
                    }
                }
            }
            Match(mn) => {
                let v = self.emit_match(mn, false);
                let Val { op: mo, kind: mk2, heap: mh2 } = v;
            }
            MethodCall(mcs) => {
                // A method call in STATEMENT position (Slice 13). `v.push(x)`
                // on a Vec[i64] local grows by exactly one element per push —
                // `realloc(ptr, (len+1)*8)` (realloc(null,·) is malloc), store
                // at [len], write back {ptr,len+1,len+1}. O(n) reallocs per
                // vec — observationally identical to the seed's amortized
                // doubling at corpus scale. Any other statement method call is
                // evaluated for effect and a heap temp result freed.
                let MethodCallExpr { object, method, args: margs, span: msp } = mcs;
                if method == "push" {
                    let mut slot = 0 - 1;
                    match object {
                        Ident(ie3) => {
                            let IdentExpr { name: on, span: osp } = ie3;
                            slot = self.local_slot(on);
                        }
                        _ => {}
                    }
                    if slot >= 0 and self.locals_kind[slot] >= 2000 {
                        // `v.push(<elem>)` on a Vec[<struct>] (Slice 18) or
                        // Vec[<enum>] (Slice 32): the vec owns the element —
                        // a fresh value transfers, a borrow materializes its
                        // heap in (tag-conditionally for enums). A
                        // sentinel-kinded Some/Ok/Err arg stores as-is: its
                        // widened layout matches the element type by design.
                        let vk4 = self.locals_kind[slot];
                        let mut sty = "".to_string();
                        let mut stride = 8;
                        let mut eei = 0 - 1;
                        if vk4 >= 4000 {
                            eei = vk4 - 4000;
                            sty = self.ty_text(1000 + eei);
                            stride = 16;
                            if (eei >= 2 and eei <= 5) or self.en_has_heap(eei) {
                                stride = 32;
                            }
                            if self.en_extra[eei] >= 0 {
                                // Struct-slot layout (Slice 39).
                                stride = 32 + self.st_stride(self.en_extra[eei] - 10);
                            }
                        } else {
                            let esi0 = vk4 - 2000;
                            sty = self.ty_text(10 + esi0);
                            stride = self.st_stride(esi0);
                        }
                        let mut ev = "zeroinitializer".to_string();
                        for ma in margs {
                            let CallArg { label, mut_marker, value, span: asp } = ma;
                            let av = self.emit_value(value);
                            let Val { op: aop, kind: ak, heap: ah } = av;
                            if ak >= 10 and ak < 1000 and not ah and self.st_has_heap(ak - 10) {
                                let mv = self.emit_materialize_struct(aop.clone(), ak - 10);
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                ev = mop;
                            } else if ak >= 1000
                                and ak < 2000
                                and not ah
                                and self.en_has_heap(ak - 1000)
                            {
                                let mv = self.emit_materialize_enum(aop.clone(), ak - 1000);
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                ev = mop;
                            } else {
                                ev = aop;
                            }
                        }
                        let sp = "%v" + slot.to_string();
                        let ag = self.fresh();
                        self.body = self.body
                            + "  "
                            + ag.clone()
                            + " = load { ptr, i64, i64 }, ptr "
                            + sp.clone()
                            + ", align 8\n";
                        let pr = self.fresh();
                        self.body = self.body
                            + "  "
                            + pr.clone()
                            + " = extractvalue { ptr, i64, i64 } "
                            + ag.clone()
                            + ", 0\n";
                        let ln = self.fresh();
                        self.body = self.body
                            + "  "
                            + ln.clone()
                            + " = extractvalue { ptr, i64, i64 } "
                            + ag
                            + ", 1\n";
                        let n1 = self.fresh();
                        self.body =
                            self.body + "  " + n1.clone() + " = add i64 " + ln.clone() + ", 1\n";
                        let by = self.fresh();
                        self.body = self.body
                            + "  "
                            + by.clone()
                            + " = mul i64 "
                            + n1.clone()
                            + ", "
                            + stride.to_string()
                            + "\n";
                        let np = self.fresh();
                        self.body = self.body
                            + "  "
                            + np.clone()
                            + " = call ptr @realloc(ptr "
                            + pr
                            + ", i64 "
                            + by
                            + ")\n";
                        let ep = self.fresh();
                        self.body = self.body
                            + "  "
                            + ep.clone()
                            + " = getelementptr "
                            + sty.clone()
                            + ", ptr "
                            + np.clone()
                            + ", i64 "
                            + ln
                            + "\n";
                        self.body = self.body
                            + "  store "
                            + sty
                            + " "
                            + ev
                            + ", ptr "
                            + ep
                            + ", align 8\n";
                        let a0 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a0.clone()
                            + " = insertvalue { ptr, i64, i64 } undef, ptr "
                            + np
                            + ", 0\n";
                        let a1 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a1.clone()
                            + " = insertvalue { ptr, i64, i64 } "
                            + a0
                            + ", i64 "
                            + n1.clone()
                            + ", 1\n";
                        let a2 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a2.clone()
                            + " = insertvalue { ptr, i64, i64 } "
                            + a1
                            + ", i64 "
                            + n1
                            + ", 2\n";
                        self.body = self.body
                            + "  store { ptr, i64, i64 } "
                            + a2
                            + ", ptr "
                            + sp
                            + ", align 8\n";
                    } else if slot >= 0 and self.locals_kind[slot] == 4 {
                        // `v.push(s)` on a Vec[String] (Slice 16): the vec OWNS
                        // its elements — a borrowed arg materializes in, a heap
                        // temp transfers. 16-byte {ptr,i64} elements.
                        let mut ev = "zeroinitializer".to_string();
                        for ma in margs {
                            let CallArg { label, mut_marker, value, span: asp } = ma;
                            let av = self.emit_value(value);
                            let Val { op: aop, kind: ak, heap: ah } = av;
                            if ak == 2 and not ah {
                                let mv = self.emit_materialize(aop.clone());
                                let Val { op: mop, kind: mk, heap: mh } = mv;
                                ev = mop;
                            } else {
                                ev = aop;
                            }
                        }
                        let sp = "%v" + slot.to_string();
                        let ag = self.fresh();
                        self.body = self.body
                            + "  "
                            + ag.clone()
                            + " = load { ptr, i64, i64 }, ptr "
                            + sp.clone()
                            + ", align 8\n";
                        let pr = self.fresh();
                        self.body = self.body
                            + "  "
                            + pr.clone()
                            + " = extractvalue { ptr, i64, i64 } "
                            + ag.clone()
                            + ", 0\n";
                        let ln = self.fresh();
                        self.body = self.body
                            + "  "
                            + ln.clone()
                            + " = extractvalue { ptr, i64, i64 } "
                            + ag
                            + ", 1\n";
                        let n1 = self.fresh();
                        self.body =
                            self.body + "  " + n1.clone() + " = add i64 " + ln.clone() + ", 1\n";
                        let by = self.fresh();
                        self.body =
                            self.body + "  " + by.clone() + " = mul i64 " + n1.clone() + ", 16\n";
                        let np = self.fresh();
                        self.body = self.body
                            + "  "
                            + np.clone()
                            + " = call ptr @realloc(ptr "
                            + pr
                            + ", i64 "
                            + by
                            + ")\n";
                        let ep = self.fresh();
                        self.body = self.body
                            + "  "
                            + ep.clone()
                            + " = getelementptr { ptr, i64 }, ptr "
                            + np.clone()
                            + ", i64 "
                            + ln
                            + "\n";
                        self.body = self.body
                            + "  store { ptr, i64 } "
                            + ev
                            + ", ptr "
                            + ep
                            + ", align 8\n";
                        let a0 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a0.clone()
                            + " = insertvalue { ptr, i64, i64 } undef, ptr "
                            + np
                            + ", 0\n";
                        let a1 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a1.clone()
                            + " = insertvalue { ptr, i64, i64 } "
                            + a0
                            + ", i64 "
                            + n1.clone()
                            + ", 1\n";
                        let a2 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a2.clone()
                            + " = insertvalue { ptr, i64, i64 } "
                            + a1
                            + ", i64 "
                            + n1
                            + ", 2\n";
                        self.body = self.body
                            + "  store { ptr, i64, i64 } "
                            + a2
                            + ", ptr "
                            + sp
                            + ", align 8\n";
                    } else if slot >= 0 and self.locals_kind[slot] == 3 {
                        let mut ev = "0".to_string();
                        for ma in margs {
                            let CallArg { label, mut_marker, value, span: asp } = ma;
                            let av = self.emit_value(value);
                            let Val { op: aop, kind: ak, heap: ah } = av;
                            ev = aop;
                        }
                        let sp = "%v" + slot.to_string();
                        let ag = self.fresh();
                        self.body = self.body
                            + "  "
                            + ag.clone()
                            + " = load { ptr, i64, i64 }, ptr "
                            + sp.clone()
                            + ", align 8\n";
                        let pr = self.fresh();
                        self.body = self.body
                            + "  "
                            + pr.clone()
                            + " = extractvalue { ptr, i64, i64 } "
                            + ag.clone()
                            + ", 0\n";
                        let ln = self.fresh();
                        self.body = self.body
                            + "  "
                            + ln.clone()
                            + " = extractvalue { ptr, i64, i64 } "
                            + ag
                            + ", 1\n";
                        let n1 = self.fresh();
                        self.body =
                            self.body + "  " + n1.clone() + " = add i64 " + ln.clone() + ", 1\n";
                        let by = self.fresh();
                        self.body =
                            self.body + "  " + by.clone() + " = mul i64 " + n1.clone() + ", 8\n";
                        let np = self.fresh();
                        self.body = self.body
                            + "  "
                            + np.clone()
                            + " = call ptr @realloc(ptr "
                            + pr
                            + ", i64 "
                            + by
                            + ")\n";
                        let ep = self.fresh();
                        self.body = self.body
                            + "  "
                            + ep.clone()
                            + " = getelementptr i64, ptr "
                            + np.clone()
                            + ", i64 "
                            + ln
                            + "\n";
                        self.body =
                            self.body + "  store i64 " + ev + ", ptr " + ep + ", align 8\n";
                        let a0 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a0.clone()
                            + " = insertvalue { ptr, i64, i64 } undef, ptr "
                            + np
                            + ", 0\n";
                        let a1 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a1.clone()
                            + " = insertvalue { ptr, i64, i64 } "
                            + a0
                            + ", i64 "
                            + n1.clone()
                            + ", 1\n";
                        let a2 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a2.clone()
                            + " = insertvalue { ptr, i64, i64 } "
                            + a1
                            + ", i64 "
                            + n1
                            + ", 2\n";
                        self.body = self.body
                            + "  store { ptr, i64, i64 } "
                            + a2
                            + ", ptr "
                            + sp
                            + ", align 8\n";
                    }
                } else {
                    let dv = self.emit_method_value(object, method, margs);
                    let Val { op: dop, kind: dk, heap: dh } = dv;
                    if dk == 2 and dh {
                        self.emit_free_val(dop);
                    } else if dh and dk >= 10 and dk < 1000 {
                        // Discarded heap results of user methods (Slice 27).
                        self.emit_free_struct_val(dop, dk - 10);
                    } else if dh and dk >= 1000 and dk < 2000 {
                        self.emit_free_enum_val(dop, dk - 1000);
                    } else if dh and (dk == 3 or dk == 4 or dk >= 2000) {
                        self.emit_free_vec_val(dop, dk);
                    }
                }
            }
            Return(re) => {
                // `return [expr]` (Slice 6): emit the value, `ret`, then OPEN A
                // FRESH DEAD BLOCK — an LLVM block has exactly one terminator, so
                // anything the walk emits after the return (the enclosing if's
                // rejoin `br`, later stmts) must land in a new (unreachable)
                // block to keep the module well-formed.
                let ReturnExpr { value, span } = re;
                let mut rv = "0".to_string();
                if self.cur_ret == 2 {
                    rv = "zeroinitializer".to_string();
                }
                match value {
                    Some(v) => {
                        let val = self.emit_value(v);
                        let Val { op, kind, heap } = val;
                        if self.cur_ret >= 10
                            and self.cur_ret < 1000
                            and kind == self.cur_ret
                            and not heap
                            and self.st_has_heap(self.cur_ret - 10)
                        {
                            let mv =
                                self.emit_materialize_struct(op.clone(), self.cur_ret - 10);
                            let Val { op: mop2, kind: mk2, heap: mh2 } = mv;
                            rv = mop2;
                        } else if self.cur_ret >= 1000
                            and self.cur_ret < 2000
                            and kind == self.cur_ret
                            and not heap
                            and self.en_has_heap(self.cur_ret - 1000)
                        {
                            // A mid-fn-returned str-enum BORROW (Slice 23).
                            let mv = self.emit_materialize_enum(op.clone(), self.cur_ret - 1000);
                            let Val { op: mop3, kind: mk3, heap: mh3 } = mv;
                            rv = mop3;
                        } else if (self.cur_ret == 3 or self.cur_ret == 4 or self.cur_ret >= 2000)
                            and kind == self.cur_ret
                            and not heap
                        {
                            // A mid-fn-returned vec BORROW (Slice 24).
                            let mv = self.emit_materialize_vec(op.clone(), self.cur_ret);
                            let Val { op: mop4, kind: mk4, heap: mh4 } = mv;
                            rv = mop4;
                        } else if self.cur_ret == 2 and kind == 2 and not heap {
                            // A returned BORROW (param/local) becomes an owned
                            // copy — the scope frees below release the original.
                            let mv = self.emit_materialize(op);
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            rv = mop;
                        } else {
                            rv = op;
                        }
                    }
                    None => {}
                }
                // Free owned slots BEFORE the ret (Slice 22) — the value above
                // is either a non-heap bit-copy or a materialized owned copy,
                // so releasing the fn's own storage here is drop-exact.
                self.emit_scope_frees();
                if self.in_main {
                    self.body = self.body + "  ret i32 0\n";
                } else {
                    if self.cur_ret == 1
                        or self.cur_ret == 2
                        or self.cur_ret == 3
                        or self.cur_ret == 4
                        or self.cur_ret == 5
                        or self.cur_ret >= 10
                    {
                        self.body =
                            self.body + "  ret " + self.ty_text(self.cur_ret) + " " + rv + "\n";
                    } else {
                        self.body = self.body + "  ret i64 " + rv + "\n";
                    }
                }
                let lid = self.nlbl;
                self.nlbl = self.nlbl + 1;
                self.body = self.body + "dead" + lid.to_string() + ":\n";
            }
            If(n) => {
                // `if cond { … } else { … }` in statement position (Slice 4):
                // evaluate the condition (i1), branch to fresh labels, emit each
                // arm, and re-join. The else branch is an `Expr` (a block, or a
                // nested `if` for `else if`), handled by recursion.
                let IfExpr { cond, then_block, else_branch, span } = n;
                let c = self.emit_value(cond);
                let Val { op: cop, kind: ck, heap: ch } = c;
                let lid = self.nlbl;
                self.nlbl = self.nlbl + 1;
                let lthen = "then" + lid.to_string();
                let lelse = "else" + lid.to_string();
                let lend = "endif" + lid.to_string();
                self.body = self.body
                    + "  br i1 "
                    + cop
                    + ", label %"
                    + lthen.clone()
                    + ", label %"
                    + lelse.clone()
                    + "\n";
                self.body = self.body + lthen + ":\n";
                self.emit_block(then_block);
                self.body = self.body + "  br label %" + lend.clone() + "\n";
                self.body = self.body + lelse + ":\n";
                match else_branch {
                    Some(eb) => {
                        self.emit_expr(eb);
                    }
                    None => {}
                }
                self.body = self.body + "  br label %" + lend.clone() + "\n";
                self.body = self.body + lend + ":\n";
            }
            For(fe) => {
                // `for b in <str>.bytes() { body }` (Slice 17): the lexer's
                // byte-walk idiom. Loop i over [0, len): load the i8 at
                // ptr+i, zext to i64, bind the loop var, emit the body. Only
                // the `.bytes()` iterable is lowered this slice.
                let ForExpr { label, var, iter, body: fbody, span } = fe;
                let mut sval = Val { op: "0".to_string(), kind: 0, heap: false };
                let mut is_bytes = false;
                match iter {
                    MethodCall(bmc) => {
                        let MethodCallExpr { object, method, args: bargs, span: bsp } = bmc;
                        if method == "bytes" {
                            sval = self.emit_value(object);
                            is_bytes = true;
                        }
                    }
                    _ => {}
                }
                let Val { op: sop, kind: sk2, heap: sh2 } = sval;
                if is_bytes and sk2 == 2 {
                    let sp2 = self.fresh();
                    self.body = self.body
                        + "  "
                        + sp2.clone()
                        + " = extractvalue { ptr, i64 } "
                        + sop.clone()
                        + ", 0\n";
                    let sl = self.fresh();
                    self.body = self.body
                        + "  "
                        + sl.clone()
                        + " = extractvalue { ptr, i64 } "
                        + sop.clone()
                        + ", 1\n";
                    // loop-var slot + index slot
                    let vidx = self.locals.len();
                    self.locals.push(var);
                    self.locals_kind.push(0);
                    self.locals_heap.push(false);
                    self.body =
                        self.body + "  %v" + vidx.to_string() + " = alloca i64, align 8\n";
                    let islot = self.fresh();
                    self.body = self.body + "  " + islot.clone() + " = alloca i64, align 8\n";
                    self.body =
                        self.body + "  store i64 0, ptr " + islot.clone() + ", align 8\n";
                    let lid = self.nlbl;
                    self.nlbl = self.nlbl + 1;
                    let lh = "bfor" + lid.to_string();
                    let lb = "bforb" + lid.to_string();
                    let le = "bfore" + lid.to_string();
                    self.body = self.body + "  br label %" + lh.clone() + "\n";
                    self.body = self.body + lh.clone() + ":\n";
                    let iv = self.fresh();
                    self.body = self.body
                        + "  "
                        + iv.clone()
                        + " = load i64, ptr "
                        + islot.clone()
                        + ", align 8\n";
                    let c = self.fresh();
                    self.body = self.body
                        + "  "
                        + c.clone()
                        + " = icmp slt i64 "
                        + iv.clone()
                        + ", "
                        + sl
                        + "\n";
                    self.body = self.body
                        + "  br i1 "
                        + c
                        + ", label %"
                        + lb.clone()
                        + ", label %"
                        + le.clone()
                        + "\n";
                    self.body = self.body + lb + ":\n";
                    let bp = self.fresh();
                    self.body = self.body
                        + "  "
                        + bp.clone()
                        + " = getelementptr i8, ptr "
                        + sp2
                        + ", i64 "
                        + iv.clone()
                        + "\n";
                    let b8 = self.fresh();
                    self.body =
                        self.body + "  " + b8.clone() + " = load i8, ptr " + bp + ", align 1\n";
                    let b64 = self.fresh();
                    self.body =
                        self.body + "  " + b64.clone() + " = zext i8 " + b8 + " to i64\n";
                    self.body = self.body
                        + "  store i64 "
                        + b64
                        + ", ptr %v"
                        + vidx.to_string()
                        + ", align 8\n";
                    self.emit_block(fbody);
                    let nx = self.fresh();
                    self.body = self.body + "  " + nx.clone() + " = add i64 " + iv + ", 1\n";
                    self.body =
                        self.body + "  store i64 " + nx + ", ptr " + islot + ", align 8\n";
                    self.body = self.body + "  br label %" + lh + "\n";
                    self.body = self.body + le + ":\n";
                    if sh2 {
                        self.emit_free_val(sop);
                    }
                }
            }
            While(w) => {
                // `while cond { body }` (Slice 5): a loop header re-evaluates the
                // condition each iteration — br to header, header computes cond
                // and branches to body or end, body jumps back to header.
                let WhileExpr { label, cond, body, span } = w;
                let lid = self.nlbl;
                self.nlbl = self.nlbl + 1;
                let lhead = "loop" + lid.to_string();
                let lbody = "body" + lid.to_string();
                let lend = "endloop" + lid.to_string();
                self.body = self.body + "  br label %" + lhead.clone() + "\n";
                self.body = self.body + lhead.clone() + ":\n";
                let c = self.emit_value(cond);
                let Val { op: cop, kind: ck, heap: ch } = c;
                self.body = self.body
                    + "  br i1 "
                    + cop
                    + ", label %"
                    + lbody.clone()
                    + ", label %"
                    + lend.clone()
                    + "\n";
                self.body = self.body + lbody + ":\n";
                self.emit_block(body);
                self.body = self.body + "  br label %" + lhead + "\n";
                self.body = self.body + lend + ":\n";
            }
            Blk(b) => {
                self.emit_block(b);
            }
            _ => {}
        }
    }

    // Intern a string literal as a global `@.strN` (byte-hex-escaped, trailing
    // NUL) and return its name + byte length.
    fn intern_str(mut ref self, sv: String) -> StrG {
        let sid = self.nstr;
        self.nstr = self.nstr + 1;
        let mut hex = "".to_string();
        let mut len = 0;
        for b in sv.bytes() {
            hex = hex + "\\" + hex2(b as i64);
            len = len + 1;
        }
        self.globals = self.globals
            + "@.str"
            + sid.to_string()
            + " = internal constant ["
            + (len + 1).to_string()
            + " x i8] c\""
            + hex
            + "\\00\"\n";
        StrG { name: "@.str" + sid.to_string(), len: len }
    }

    // Emit one `println(<literal>)`: intern + two `fwrite`s (string, newline).
    // Matches the seed's lowering (fwrite over @stdout).
    fn emit_println_str(mut ref self, sv: String) {
        let g = self.intern_str(sv);
        let StrG { name, len } = g;
        self.emit_write(name, len);
        self.emit_write("@.nl".to_string(), 1);
    }

    // Concatenate two string VALUES (`{ ptr, i64 }` aggregates): allocate the
    // combined buffer, copy both halves, return the fresh aggregate (Slice 8).
    fn emit_concat(mut ref self, lop: String, rop: String) -> Val {
        let lp = self.fresh();
        self.body =
            self.body + "  " + lp.clone() + " = extractvalue { ptr, i64 } " + lop.clone() + ", 0\n";
        let ll = self.fresh();
        self.body = self.body + "  " + ll.clone() + " = extractvalue { ptr, i64 } " + lop + ", 1\n";
        let rp = self.fresh();
        self.body =
            self.body + "  " + rp.clone() + " = extractvalue { ptr, i64 } " + rop.clone() + ", 0\n";
        let rl = self.fresh();
        self.body = self.body + "  " + rl.clone() + " = extractvalue { ptr, i64 } " + rop + ", 1\n";
        let n = self.fresh();
        self.body =
            self.body + "  " + n.clone() + " = add i64 " + ll.clone() + ", " + rl.clone() + "\n";
        let buf = self.fresh();
        self.body = self.body + "  " + buf.clone() + " = call ptr @malloc(i64 " + n.clone() + ")\n";
        let m1 = self.fresh();
        self.body = self.body
            + "  "
            + m1
            + " = call ptr @memcpy(ptr "
            + buf.clone()
            + ", ptr "
            + lp
            + ", i64 "
            + ll.clone()
            + ")\n";
        let dst = self.fresh();
        self.body = self.body
            + "  "
            + dst.clone()
            + " = getelementptr i8, ptr "
            + buf.clone()
            + ", i64 "
            + ll
            + "\n";
        let m2 = self.fresh();
        self.body = self.body
            + "  "
            + m2
            + " = call ptr @memcpy(ptr "
            + dst
            + ", ptr "
            + rp
            + ", i64 "
            + rl
            + ")\n";
        let a0 = self.fresh();
        self.body = self.body
            + "  "
            + a0.clone()
            + " = insertvalue { ptr, i64 } undef, ptr "
            + buf
            + ", 0\n";
        let a1 = self.fresh();
        self.body = self.body
            + "  "
            + a1.clone()
            + " = insertvalue { ptr, i64 } "
            + a0
            + ", i64 "
            + n
            + ", 1\n";
        Val { op: a1, kind: 2, heap: true }
    }

    // Materialize a BORROWED string value (global-backed literal or an ident
    // load) into a fresh OWNED heap copy — malloc(len) + memcpy (Slice 9).
    // Every string BINDING owns a private buffer (the seed's String semantics:
    // literals materialize owned Strings), so reassignment/scope-exit frees
    // are unconditional and loop-correct; the seed's move-optimization (no
    // copy on `let t = s`) is a later refinement, observationally identical.
    fn emit_materialize(mut ref self, val: String) -> Val {
        let pr = self.fresh();
        self.body =
            self.body + "  " + pr.clone() + " = extractvalue { ptr, i64 } " + val.clone() + ", 0\n";
        let ln = self.fresh();
        self.body = self.body + "  " + ln.clone() + " = extractvalue { ptr, i64 } " + val + ", 1\n";
        let buf = self.fresh();
        self.body =
            self.body + "  " + buf.clone() + " = call ptr @malloc(i64 " + ln.clone() + ")\n";
        let m = self.fresh();
        self.body = self.body
            + "  "
            + m
            + " = call ptr @memcpy(ptr "
            + buf.clone()
            + ", ptr "
            + pr
            + ", i64 "
            + ln.clone()
            + ")\n";
        let a0 = self.fresh();
        self.body = self.body
            + "  "
            + a0.clone()
            + " = insertvalue { ptr, i64 } undef, ptr "
            + buf
            + ", 0\n";
        let a1 = self.fresh();
        self.body = self.body
            + "  "
            + a1.clone()
            + " = insertvalue { ptr, i64 } "
            + a0
            + ", i64 "
            + ln
            + ", 1\n";
        Val { op: a1, kind: 2, heap: true }
    }

    // Lower a `match` over an ENUM scrutinee (Slice 14). Arms chain
    // compare-and-branch on the extracted tag; a TupleVariantPat binds its one
    // i64 payload; a BindingPat whose name IS a variant of the scrutinee's
    // enum matches that variant (the seed's rule — a bare `Red =>` arm parses
    // as a binding), otherwise it is a catch-all binding the WHOLE enum value;
    // WildcardPat is a bare catch-all. Arms after a catch-all emit into an
    // unreachable-but-well-formed block. In value form each arm body's i64
    // value routes through a result slot (the if-as-value pattern). Guards are
    // not lowered (corpus-free surface).
    fn emit_match(mut ref self, m: MatchExpr, want_value: bool) -> Val {
        let MatchExpr { scrutinee, arms, span } = m;
        let sv = self.emit_value(scrutinee);
        let Val { op: sop, kind: sk, heap: sh } = sv;
        if sk == 0 {
            // INT-LITERAL MATCH (Slice 26 — was a SILENT arm-dropper): an
            // icmp/branch chain per IntPat arm; a wildcard or binding pattern
            // is a catch-all (the binding gets an i64 slot). Value position
            // routes arm results through an i64 slot, like the enum path.
            let mid = self.nlbl;
            self.nlbl = self.nlbl + 1;
            let lend = "endmatch" + mid.to_string();
            let mut rslot = "".to_string();
            if want_value {
                rslot = self.fresh();
                self.body = self.body + "  " + rslot.clone() + " = alloca i64, align 8\n";
                self.body = self.body + "  store i64 0, ptr " + rslot.clone() + ", align 8\n";
            }
            let mut ai = 0;
            for arm in arms {
                let MatchArm { pattern, guard, body, span: asp } = arm;
                let mut has_lit = false;
                let mut lit = 0;
                let mut bind_name = "".to_string();
                let mut is_catch = false;
                match pattern {
                    IntPat(pi) => {
                        let PatInt { value, suffix, span: psp } = pi;
                        has_lit = true;
                        lit = value;
                    }
                    BindingPat(bp) => {
                        let BindingPattern { name: bn, span: bsp } = bp;
                        bind_name = bn;
                        is_catch = true;
                    }
                    WildcardPat(sn2) => {
                        is_catch = true;
                    }
                    _ => {}
                }
                if has_lit {
                    let lbody = "marm" + mid.to_string() + "_" + ai.to_string();
                    let lnext = "mnext" + mid.to_string() + "_" + ai.to_string();
                    let c = self.fresh();
                    self.body = self.body
                        + "  "
                        + c.clone()
                        + " = icmp eq i64 "
                        + sop.clone()
                        + ", "
                        + lit.to_string()
                        + "\n";
                    self.body = self.body
                        + "  br i1 "
                        + c
                        + ", label %"
                        + lbody.clone()
                        + ", label %"
                        + lnext.clone()
                        + "\n";
                    self.body = self.body + lbody + ":\n";
                    if want_value {
                        let bv = self.emit_value(body);
                        let Val { op: bop, kind: bk, heap: bh } = bv;
                        self.body = self.body
                            + "  store i64 "
                            + bop
                            + ", ptr "
                            + rslot.clone()
                            + ", align 8\n";
                    } else {
                        self.emit_expr(body);
                    }
                    self.body = self.body + "  br label %" + lend.clone() + "\n";
                    self.body = self.body + lnext + ":\n";
                } else {
                    if is_catch {
                        if bind_name != "" {
                            let idx = self.locals.len();
                            self.locals.push(bind_name);
                            self.locals_kind.push(0);
                            self.locals_heap.push(false);
                            self.body = self.body
                                + "  %v"
                                + idx.to_string()
                                + " = alloca i64, align 8\n";
                            self.body = self.body
                                + "  store i64 "
                                + sop.clone()
                                + ", ptr %v"
                                + idx.to_string()
                                + ", align 8\n";
                        }
                        if want_value {
                            let bv = self.emit_value(body);
                            let Val { op: bop, kind: bk, heap: bh } = bv;
                            self.body = self.body
                                + "  store i64 "
                                + bop
                                + ", ptr "
                                + rslot.clone()
                                + ", align 8\n";
                        } else {
                            self.emit_expr(body);
                        }
                        self.body = self.body + "  br label %" + lend.clone() + "\n";
                        let ldead = "mdead" + mid.to_string() + "_" + ai.to_string();
                        self.body = self.body + ldead + ":\n";
                    }
                }
                ai = ai + 1;
            }
            self.body = self.body + "  br label %" + lend.clone() + "\n";
            self.body = self.body + lend + ":\n";
            if want_value {
                let r = self.fresh();
                self.body =
                    self.body + "  " + r.clone() + " = load i64, ptr " + rslot + ", align 8\n";
                return Val { op: r, kind: 0, heap: false };
            }
            return Val { op: "0".to_string(), kind: 0, heap: false };
        }
        if sk < 1000 {
            return Val { op: "0".to_string(), kind: 0, heap: false };
        }
        let ei = sk - 1000;
        let ety = self.ty_text(sk);
        let tg = self.fresh();
        self.body = self.body
            + "  "
            + tg.clone()
            + " = extractvalue "
            + ety.clone()
            + " "
            + sop.clone()
            + ", 0\n";
        let mut rslot = "".to_string();
        if want_value {
            rslot = self.fresh();
            self.body = self.body + "  " + rslot.clone() + " = alloca i64, align 8\n";
        }
        let mid = self.nlbl;
        self.nlbl = self.nlbl + 1;
        let lend = "endmatch" + mid.to_string();
        let mut ai = 0;
        for arm in arms {
            let MatchArm { pattern, guard, body, span: asp } = arm;
            let mut tag = 0 - 1;
            let mut bind_payload = "".to_string();
            let mut bind_payload2 = "".to_string();
            let mut bind_whole = "".to_string();
            match pattern {
                TupleVariantPat(tvp) => {
                    let TupleVariantPattern { segments, elems, span: tsp } = tvp;
                    let li = segments.len() - 1;
                    let vn = segments[li];
                    tag = self.en_variant_tag(ei, vn);
                    let mut pei = 0;
                    for el in elems {
                        match el {
                            BindingPat(bp) => {
                                let BindingPattern { name: bn, span: bsp } = bp;
                                // POSITIONAL (Slice 35): elem 0 binds the
                                // first payload, elem 1 the second.
                                if pei == 0 {
                                    bind_payload = bn;
                                } else {
                                    bind_payload2 = bn;
                                }
                            }
                            _ => {}
                        }
                        pei = pei + 1;
                    }
                }
                BindingPat(bp) => {
                    let BindingPattern { name: bn, span: bsp } = bp;
                    let vt = self.en_variant_tag(ei, bn.clone());
                    if vt >= 0 {
                        tag = vt;
                    } else {
                        bind_whole = bn;
                    }
                }
                _ => {}
            }
            if tag >= 0 {
                let lbody = "marm" + mid.to_string() + "_" + ai.to_string();
                let lnext = "mnext" + mid.to_string() + "_" + ai.to_string();
                let c = self.fresh();
                self.body = self.body
                    + "  "
                    + c.clone()
                    + " = icmp eq i64 "
                    + tg.clone()
                    + ", "
                    + tag.to_string()
                    + "\n";
                self.body = self.body
                    + "  br i1 "
                    + c
                    + ", label %"
                    + lbody.clone()
                    + ", label %"
                    + lnext.clone()
                    + "\n";
                self.body = self.body + lbody + ":\n";
                if bind_payload != "" {
                    // The payload binds by KIND (Slice 23): i64 from slot 1,
                    // String from slot 2, a struct from slot 3 (Slice 39) —
                    // heap payloads bind as BORROWS (the scrutinee's owner
                    // keeps and frees the buffers).
                    let plk2 = self.en_var_pl[self.en_off[ei] + tag];
                    if plk2 >= 10 and plk2 < 1000 {
                        let plx = self.fresh();
                        self.body = self.body
                            + "  "
                            + plx.clone()
                            + " = extractvalue "
                            + ety.clone()
                            + " "
                            + sop.clone()
                            + ", 3\n";
                        let idxx = self.locals.len();
                        self.locals.push(bind_payload.clone());
                        self.locals_kind.push(plk2);
                        self.locals_heap.push(false);
                        let xty = self.ty_text(plk2);
                        self.body = self.body
                            + "  %v"
                            + idxx.to_string()
                            + " = alloca "
                            + xty.clone()
                            + ", align 8\n";
                        self.body = self.body
                            + "  store "
                            + xty
                            + " "
                            + plx
                            + ", ptr %v"
                            + idxx.to_string()
                            + ", align 8\n";
                    } else if plk2 == 2 {
                        let pl = self.fresh();
                        self.body = self.body
                            + "  "
                            + pl.clone()
                            + " = extractvalue "
                            + ety.clone()
                            + " "
                            + sop.clone()
                            + ", 2\n";
                        let idx = self.locals.len();
                        self.locals.push(bind_payload);
                        self.locals_kind.push(2);
                        self.locals_heap.push(false);
                        self.body = self.body
                            + "  %v"
                            + idx.to_string()
                            + " = alloca { ptr, i64 }, align 8\n";
                        self.body = self.body
                            + "  store { ptr, i64 } "
                            + pl
                            + ", ptr %v"
                            + idx.to_string()
                            + ", align 8\n";
                    } else {
                        let pl = self.fresh();
                        self.body = self.body
                            + "  "
                            + pl.clone()
                            + " = extractvalue "
                            + ety.clone()
                            + " "
                            + sop.clone()
                            + ", 1\n";
                        let idx = self.locals.len();
                        self.locals.push(bind_payload);
                        self.locals_kind.push(0);
                        self.locals_heap.push(false);
                        self.body =
                            self.body + "  %v" + idx.to_string() + " = alloca i64, align 8\n";
                        self.body = self.body
                            + "  store i64 "
                            + pl
                            + ", ptr %v"
                            + idx.to_string()
                            + ", align 8\n";
                    }
                }
                if bind_payload2 != "" {
                    // The SECOND payload (Slice 35), by its own recorded kind.
                    let plk3 = self.en_var_pl2[self.en_off[ei] + tag];
                    if plk3 == 2 {
                        let pl2 = self.fresh();
                        self.body = self.body
                            + "  "
                            + pl2.clone()
                            + " = extractvalue "
                            + ety.clone()
                            + " "
                            + sop.clone()
                            + ", 2\n";
                        let idx2 = self.locals.len();
                        self.locals.push(bind_payload2);
                        self.locals_kind.push(2);
                        self.locals_heap.push(false);
                        self.body = self.body
                            + "  %v"
                            + idx2.to_string()
                            + " = alloca { ptr, i64 }, align 8\n";
                        self.body = self.body
                            + "  store { ptr, i64 } "
                            + pl2
                            + ", ptr %v"
                            + idx2.to_string()
                            + ", align 8\n";
                    } else {
                        let pl2 = self.fresh();
                        self.body = self.body
                            + "  "
                            + pl2.clone()
                            + " = extractvalue "
                            + ety.clone()
                            + " "
                            + sop.clone()
                            + ", 1\n";
                        let idx2 = self.locals.len();
                        self.locals.push(bind_payload2);
                        self.locals_kind.push(0);
                        self.locals_heap.push(false);
                        self.body =
                            self.body + "  %v" + idx2.to_string() + " = alloca i64, align 8\n";
                        self.body = self.body
                            + "  store i64 "
                            + pl2
                            + ", ptr %v"
                            + idx2.to_string()
                            + ", align 8\n";
                    }
                }
                if want_value {
                    let bv = self.emit_value(body);
                    let Val { op: bop, kind: bk, heap: bh } = bv;
                    self.body = self.body
                        + "  store i64 "
                        + bop
                        + ", ptr "
                        + rslot.clone()
                        + ", align 8\n";
                } else {
                    self.emit_expr(body);
                }
                self.body = self.body + "  br label %" + lend.clone() + "\n";
                self.body = self.body + lnext + ":\n";
            } else {
                if bind_whole != "" {
                    let idx = self.locals.len();
                    self.locals.push(bind_whole);
                    self.locals_kind.push(sk);
                    self.locals_heap.push(false);
                    self.body = self.body
                        + "  %v"
                        + idx.to_string()
                        + " = alloca "
                        + ety.clone()
                        + ", align 8\n";
                    self.body = self.body
                        + "  store "
                        + ety.clone()
                        + " "
                        + sop.clone()
                        + ", ptr %v"
                        + idx.to_string()
                        + ", align 8\n";
                }
                if want_value {
                    let bv = self.emit_value(body);
                    let Val { op: bop, kind: bk, heap: bh } = bv;
                    self.body = self.body
                        + "  store i64 "
                        + bop
                        + ", ptr "
                        + rslot.clone()
                        + ", align 8\n";
                } else {
                    self.emit_expr(body);
                }
                self.body = self.body + "  br label %" + lend.clone() + "\n";
                let ldead = "mdead" + mid.to_string() + "_" + ai.to_string();
                self.body = self.body + ldead + ":\n";
            }
            ai = ai + 1;
        }
        self.body = self.body + "  br label %" + lend.clone() + "\n";
        self.body = self.body + lend + ":\n";
        if want_value {
            let r = self.fresh();
            self.body = self.body
                + "  "
                + r.clone()
                + " = load i64, ptr "
                + rslot
                + ", align 8\n";
            return Val { op: r, kind: 0, heap: false };
        }
        Val { op: "0".to_string(), kind: 0, heap: false }
    }

    // String equality (Slice 17): i1 = (len_l == len_r) and memcmp == 0.
    // Uses a select over the length check so the memcmp runs unconditionally
    // (safe: both pointers are valid for their own lengths; when lengths
    // differ the memcmp result is discarded).
    // Lexicographic three-way string compare (Slice 26): an i64 register
    // that is <0 / 0 / >0. memcmp over min(len_l, len_r); when the common
    // prefix ties, the length difference decides ("ab" < "abc").
    fn emit_str_cmp3(mut ref self, lop: String, rop: String) -> String {
        let lp = self.fresh();
        self.body =
            self.body + "  " + lp.clone() + " = extractvalue { ptr, i64 } " + lop.clone() + ", 0\n";
        let ll = self.fresh();
        self.body = self.body + "  " + ll.clone() + " = extractvalue { ptr, i64 } " + lop + ", 1\n";
        let rp = self.fresh();
        self.body =
            self.body + "  " + rp.clone() + " = extractvalue { ptr, i64 } " + rop.clone() + ", 0\n";
        let rl = self.fresh();
        self.body = self.body + "  " + rl.clone() + " = extractvalue { ptr, i64 } " + rop + ", 1\n";
        let lt = self.fresh();
        self.body = self.body
            + "  "
            + lt.clone()
            + " = icmp slt i64 "
            + ll.clone()
            + ", "
            + rl.clone()
            + "\n";
        let mn = self.fresh();
        self.body = self.body
            + "  "
            + mn.clone()
            + " = select i1 "
            + lt
            + ", i64 "
            + ll.clone()
            + ", i64 "
            + rl.clone()
            + "\n";
        let mc = self.fresh();
        self.body = self.body
            + "  "
            + mc.clone()
            + " = call i32 @memcmp(ptr "
            + lp
            + ", ptr "
            + rp
            + ", i64 "
            + mn
            + ")\n";
        let mcx = self.fresh();
        self.body = self.body + "  " + mcx.clone() + " = sext i32 " + mc.clone() + " to i64\n";
        let mz = self.fresh();
        self.body = self.body + "  " + mz.clone() + " = icmp eq i32 " + mc + ", 0\n";
        let ld = self.fresh();
        self.body = self.body + "  " + ld.clone() + " = sub i64 " + ll + ", " + rl + "\n";
        let r = self.fresh();
        self.body = self.body
            + "  "
            + r.clone()
            + " = select i1 "
            + mz
            + ", i64 "
            + ld
            + ", i64 "
            + mcx
            + "\n";
        r
    }

    fn emit_str_eq(mut ref self, lop: String, rop: String) -> Val {
        let lp = self.fresh();
        self.body =
            self.body + "  " + lp.clone() + " = extractvalue { ptr, i64 } " + lop.clone() + ", 0\n";
        let ll = self.fresh();
        self.body = self.body + "  " + ll.clone() + " = extractvalue { ptr, i64 } " + lop + ", 1\n";
        let rp = self.fresh();
        self.body =
            self.body + "  " + rp.clone() + " = extractvalue { ptr, i64 } " + rop.clone() + ", 0\n";
        let rl = self.fresh();
        self.body = self.body + "  " + rl.clone() + " = extractvalue { ptr, i64 } " + rop + ", 1\n";
        let leq = self.fresh();
        self.body = self.body
            + "  "
            + leq.clone()
            + " = icmp eq i64 "
            + ll.clone()
            + ", "
            + rl
            + "\n";
        // memcmp over min(len_l, len_r) = len_l when equal; use len_l gated by
        // leq via select to 0 so differing-length compares read zero bytes.
        let n = self.fresh();
        self.body = self.body
            + "  "
            + n.clone()
            + " = select i1 "
            + leq.clone()
            + ", i64 "
            + ll
            + ", i64 0\n";
        let mc = self.fresh();
        self.body = self.body
            + "  "
            + mc.clone()
            + " = call i32 @memcmp(ptr "
            + lp
            + ", ptr "
            + rp
            + ", i64 "
            + n
            + ")\n";
        let mz = self.fresh();
        self.body = self.body + "  " + mz.clone() + " = icmp eq i32 " + mc + ", 0\n";
        let r = self.fresh();
        self.body = self.body
            + "  "
            + r.clone()
            + " = and i1 "
            + leq
            + ", "
            + mz
            + "\n";
        Val { op: r, kind: 1, heap: false }
    }

    // True iff struct `si` has any direct String field (Slice 15 — the
    // heap-bearing test; Vec fields in structs are a deferred surface).
    // Free a VEC VALUE's buffers (Slice 24, value form of the old slot-only
    // logic): per-element frees for heap elements (Vec[String] / Vec[<struct
    // with String fields>]) via a label loop over [0, len), then the outer
    // buffer. free(null) makes the empty vec a no-op.
    fn emit_free_vec_val(mut ref self, ag: String, k: i64) {
        let ty = self.ty_text(k);
        let pr = self.fresh();
        self.body = self.body
            + "  "
            + pr.clone()
            + " = extractvalue "
            + ty.clone()
            + " "
            + ag.clone()
            + ", 0\n";
        let mut elem_heap = k == 4;
        let mut esi = 0 - 1;
        let mut eei = 0 - 1;
        if k >= 2000 and k < 4000 {
            esi = k - 2000;
            if self.st_has_heap(esi) {
                elem_heap = true;
            }
        }
        if k >= 4000 {
            // Vec[<enum>] (Slice 32): per-element tag-conditional frees.
            eei = k - 4000;
            if self.en_has_heap(eei) {
                elem_heap = true;
            }
        }
        if elem_heap {
            let mut ety = "{ ptr, i64 }".to_string();
            if esi >= 0 {
                ety = self.ty_text(10 + esi);
            }
            if eei >= 0 {
                ety = self.ty_text(1000 + eei);
            }
            let ln = self.fresh();
            self.body = self.body
                + "  "
                + ln.clone()
                + " = extractvalue "
                + ty.clone()
                + " "
                + ag.clone()
                + ", 1\n";
            let lid = self.nlbl;
            self.nlbl = self.nlbl + 1;
            let lh = "vfl" + lid.to_string();
            let lb = "vflb" + lid.to_string();
            let le = "vfle" + lid.to_string();
            let islot = self.fresh();
            self.body = self.body + "  " + islot.clone() + " = alloca i64, align 8\n";
            self.body = self.body + "  store i64 0, ptr " + islot.clone() + ", align 8\n";
            self.body = self.body + "  br label %" + lh.clone() + "\n";
            self.body = self.body + lh.clone() + ":\n";
            let iv = self.fresh();
            self.body =
                self.body + "  " + iv.clone() + " = load i64, ptr " + islot.clone() + ", align 8\n";
            let c = self.fresh();
            self.body = self.body + "  " + c.clone() + " = icmp slt i64 " + iv.clone() + ", " + ln + "\n";
            self.body = self.body
                + "  br i1 "
                + c
                + ", label %"
                + lb.clone()
                + ", label %"
                + le.clone()
                + "\n";
            self.body = self.body + lb + ":\n";
            let ep = self.fresh();
            self.body = self.body
                + "  "
                + ep.clone()
                + " = getelementptr "
                + ety.clone()
                + ", ptr "
                + pr.clone()
                + ", i64 "
                + iv.clone()
                + "\n";
            let el = self.fresh();
            self.body = self.body + "  " + el.clone() + " = load " + ety + ", ptr " + ep + ", align 8\n";
            if esi >= 0 {
                self.emit_free_struct_val(el, esi);
            } else if eei >= 0 {
                self.emit_free_enum_val(el, eei);
            } else {
                self.emit_free_val(el);
            }
            let nx = self.fresh();
            self.body = self.body + "  " + nx.clone() + " = add i64 " + iv + ", 1\n";
            self.body = self.body + "  store i64 " + nx + ", ptr " + islot + ", align 8\n";
            self.body = self.body + "  br label %" + lh + "\n";
            self.body = self.body + le + ":\n";
        }
        self.body = self.body + "  call void @free(ptr " + pr + ")\n";
    }

    // Deep-copy a BORROWED vec value into a fresh OWNED vec (Slice 24): malloc
    // len*stride, memcpy the raw elements, then for heap elements walk [0,len)
    // replacing each aliased element with its own materialized copy. The
    // result is {buf, len, len} — capacity collapses to len, which is valid:
    // push realloc's from len anyway.
    fn emit_materialize_vec(mut ref self, op: String, k: i64) -> Val {
        let ty = self.ty_text(k);
        let mut stride = 8;
        let mut esi = 0 - 1;
        let mut eei = 0 - 1;
        let mut elem_heap = false;
        if k == 4 {
            stride = 16;
            elem_heap = true;
        }
        if k >= 2000 and k < 4000 {
            esi = k - 2000;
            stride = self.st_stride(esi);
            if self.st_has_heap(esi) {
                elem_heap = true;
            }
        }
        if k >= 4000 {
            // Vec[<enum>] (Slice 32): 16B pure / 32B widened elements;
            // struct-slot layouts (Slice 39) add the struct's stride.
            eei = k - 4000;
            stride = 16;
            if (eei >= 2 and eei <= 5) or self.en_has_heap(eei) {
                stride = 32;
            }
            if self.en_extra[eei] >= 0 {
                stride = 32 + self.st_stride(self.en_extra[eei] - 10);
            }
            if self.en_has_heap(eei) {
                elem_heap = true;
            }
        }
        let sp = self.fresh();
        self.body = self.body
            + "  "
            + sp.clone()
            + " = extractvalue "
            + ty.clone()
            + " "
            + op.clone()
            + ", 0\n";
        let ln = self.fresh();
        self.body =
            self.body + "  " + ln.clone() + " = extractvalue " + ty.clone() + " " + op + ", 1\n";
        let by = self.fresh();
        self.body = self.body
            + "  "
            + by.clone()
            + " = mul i64 "
            + ln.clone()
            + ", "
            + stride.to_string()
            + "\n";
        let nb = self.fresh();
        self.body = self.body + "  " + nb.clone() + " = call ptr @malloc(i64 " + by.clone() + ")\n";
        let cp = self.fresh();
        self.body = self.body
            + "  "
            + cp.clone()
            + " = call ptr @memcpy(ptr "
            + nb.clone()
            + ", ptr "
            + sp
            + ", i64 "
            + by
            + ")\n";
        if elem_heap {
            // Each copied element still ALIASES the source's buffers — walk
            // the new buffer materializing each element in place.
            let mut ety = "{ ptr, i64 }".to_string();
            if esi >= 0 {
                ety = self.ty_text(10 + esi);
            }
            if eei >= 0 {
                ety = self.ty_text(1000 + eei);
            }
            let lid = self.nlbl;
            self.nlbl = self.nlbl + 1;
            let lh = "mvl" + lid.to_string();
            let lb = "mvlb" + lid.to_string();
            let le = "mvle" + lid.to_string();
            let islot = self.fresh();
            self.body = self.body + "  " + islot.clone() + " = alloca i64, align 8\n";
            self.body = self.body + "  store i64 0, ptr " + islot.clone() + ", align 8\n";
            self.body = self.body + "  br label %" + lh.clone() + "\n";
            self.body = self.body + lh.clone() + ":\n";
            let iv = self.fresh();
            self.body =
                self.body + "  " + iv.clone() + " = load i64, ptr " + islot.clone() + ", align 8\n";
            let c = self.fresh();
            self.body = self.body
                + "  "
                + c.clone()
                + " = icmp slt i64 "
                + iv.clone()
                + ", "
                + ln.clone()
                + "\n";
            self.body = self.body
                + "  br i1 "
                + c
                + ", label %"
                + lb.clone()
                + ", label %"
                + le.clone()
                + "\n";
            self.body = self.body + lb + ":\n";
            let ep = self.fresh();
            self.body = self.body
                + "  "
                + ep.clone()
                + " = getelementptr "
                + ety.clone()
                + ", ptr "
                + nb.clone()
                + ", i64 "
                + iv.clone()
                + "\n";
            let el = self.fresh();
            self.body = self.body
                + "  "
                + el.clone()
                + " = load "
                + ety.clone()
                + ", ptr "
                + ep.clone()
                + ", align 8\n";
            let mut mop2 = "".to_string();
            if esi >= 0 {
                let mv = self.emit_materialize_struct(el, esi);
                let Val { op: mo, kind: mk, heap: mh } = mv;
                mop2 = mo;
            } else if eei >= 0 {
                let mv = self.emit_materialize_enum(el, eei);
                let Val { op: mo, kind: mk, heap: mh } = mv;
                mop2 = mo;
            } else {
                let mv = self.emit_materialize(el);
                let Val { op: mo, kind: mk, heap: mh } = mv;
                mop2 = mo;
            }
            self.body = self.body
                + "  store "
                + ety
                + " "
                + mop2
                + ", ptr "
                + ep
                + ", align 8\n";
            let nx = self.fresh();
            self.body = self.body + "  " + nx.clone() + " = add i64 " + iv + ", 1\n";
            self.body = self.body + "  store i64 " + nx + ", ptr " + islot + ", align 8\n";
            self.body = self.body + "  br label %" + lh + "\n";
            self.body = self.body + le + ":\n";
        }
        let r0 = self.fresh();
        self.body = self.body
            + "  "
            + r0.clone()
            + " = insertvalue "
            + ty.clone()
            + " undef, ptr "
            + nb
            + ", 0\n";
        let r1 = self.fresh();
        self.body = self.body
            + "  "
            + r1.clone()
            + " = insertvalue "
            + ty.clone()
            + " "
            + r0
            + ", i64 "
            + ln.clone()
            + ", 1\n";
        let r2 = self.fresh();
        self.body = self.body
            + "  "
            + r2.clone()
            + " = insertvalue "
            + ty
            + " "
            + r1
            + ", i64 "
            + ln
            + ", 2\n";
        Val { op: r2, kind: k, heap: true }
    }

    // True iff any variant of enum `ei` carries a String payload (Slice 23) —
    // such enums widen to { i64, i64, { ptr, i64 } } and OWN their payload.
    fn en_has_heap(ref self, ei: i64) -> bool {
        let off = self.en_off[ei];
        let cnt = self.en_cnt[ei];
        let mut vi = 0;
        while vi < cnt {
            if self.en_var_pl[off + vi] == 2 or self.en_var_pl2[off + vi] == 2 {
                return true;
            }
            vi = vi + 1;
        }
        if self.en_extra[ei] >= 0 {
            // A heap-bearing STRUCT payload (Slice 39) makes the enum own
            // heap too.
            if self.st_has_heap(self.en_extra[ei] - 10) {
                return true;
            }
        }
        false
    }

    // i1 register testing whether tag `tg` names the STRUCT-payload variant
    // set of enum `ei` (Slice 39) — the guard for slot-3 copy/free.
    fn emit_enum_extratag_test(mut ref self, tg: String, ei: i64) -> String {
        let off = self.en_off[ei];
        let cnt = self.en_cnt[ei];
        let ex = self.en_extra[ei];
        let mut acc = "".to_string();
        let mut vi = 0;
        while vi < cnt {
            if self.en_var_pl[off + vi] == ex {
                let c = self.fresh();
                self.body = self.body
                    + "  "
                    + c.clone()
                    + " = icmp eq i64 "
                    + tg.clone()
                    + ", "
                    + vi.to_string()
                    + "\n";
                if acc == "" {
                    acc = c;
                } else {
                    let o = self.fresh();
                    self.body = self.body + "  " + o.clone() + " = or i1 " + acc + ", " + c + "\n";
                    acc = o;
                }
            }
            vi = vi + 1;
        }
        if acc == "" {
            acc = "false".to_string();
        }
        acc
    }

    // Emit an i1 register that tests whether tag `tg` names a String-payload
    // variant of enum `ei` (an icmp/or chain) — the guard for tag-conditional
    // payload copy/free (Slice 23).
    fn emit_enum_strtag_test(mut ref self, tg: String, ei: i64) -> String {
        let off = self.en_off[ei];
        let cnt = self.en_cnt[ei];
        let mut acc = "".to_string();
        let mut vi = 0;
        while vi < cnt {
            if self.en_var_pl[off + vi] == 2 or self.en_var_pl2[off + vi] == 2 {
                let c = self.fresh();
                self.body = self.body
                    + "  "
                    + c.clone()
                    + " = icmp eq i64 "
                    + tg.clone()
                    + ", "
                    + vi.to_string()
                    + "\n";
                if acc == "" {
                    acc = c;
                } else {
                    let o = self.fresh();
                    self.body = self.body + "  " + o.clone() + " = or i1 " + acc + ", " + c + "\n";
                    acc = o;
                }
            }
            vi = vi + 1;
        }
        if acc == "" {
            acc = "false".to_string();
        }
        acc
    }

    // Deep-copy a BORROWED str-enum value (Slice 23): if the runtime tag is a
    // String-payload variant, copy the payload buffer; otherwise the aggregate
    // passes through untouched (the payload slot is only read under the tag
    // guard, so unit/int variants never touch it). Result routed through a
    // stack slot — the copy is conditional, so no single SSA name works.
    fn emit_materialize_enum(mut ref self, op: String, ei: i64) -> Val {
        let ety = self.ty_text(1000 + ei);
        let slot = self.fresh();
        self.body = self.body + "  " + slot.clone() + " = alloca " + ety.clone() + ", align 8\n";
        self.body = self.body
            + "  store "
            + ety.clone()
            + " "
            + op.clone()
            + ", ptr "
            + slot.clone()
            + ", align 8\n";
        let tg = self.fresh();
        self.body = self.body
            + "  "
            + tg.clone()
            + " = extractvalue "
            + ety.clone()
            + " "
            + op.clone()
            + ", 0\n";
        let c = self.emit_enum_strtag_test(tg.clone(), ei);
        let lid = self.nlbl;
        self.nlbl = self.nlbl + 1;
        let lc = "emcp" + lid.to_string();
        let ld = "emdn" + lid.to_string();
        self.body =
            self.body + "  br i1 " + c + ", label %" + lc.clone() + ", label %" + ld.clone() + "\n";
        self.body = self.body + lc + ":\n";
        let s = self.fresh();
        self.body = self.body
            + "  "
            + s.clone()
            + " = extractvalue "
            + ety.clone()
            + " "
            + op.clone()
            + ", 2\n";
        let mv = self.emit_materialize(s);
        let Val { op: mop, kind: mk, heap: mh } = mv;
        let ag = self.fresh();
        self.body = self.body
            + "  "
            + ag.clone()
            + " = insertvalue "
            + ety.clone()
            + " "
            + op.clone()
            + ", { ptr, i64 } "
            + mop
            + ", 2\n";
        self.body = self.body
            + "  store "
            + ety.clone()
            + " "
            + ag
            + ", ptr "
            + slot.clone()
            + ", align 8\n";
        self.body = self.body + "  br label %" + ld.clone() + "\n";
        self.body = self.body + ld + ":\n";
        if self.en_extra[ei] >= 0 {
            // STRUCT-slot deep copy (Slice 39), tag-gated on the struct-
            // payload variants. Exclusive with the string leg per runtime
            // tag, so each leg loads/stores the result slot independently.
            if self.st_has_heap(self.en_extra[ei] - 10) {
                let c2 = self.emit_enum_extratag_test(tg, ei);
                let lid2 = self.nlbl;
                self.nlbl = self.nlbl + 1;
                let lc2 = "emxc" + lid2.to_string();
                let ld2 = "emxd" + lid2.to_string();
                self.body = self.body
                    + "  br i1 "
                    + c2
                    + ", label %"
                    + lc2.clone()
                    + ", label %"
                    + ld2.clone()
                    + "\n";
                self.body = self.body + lc2 + ":\n";
                let xs = self.fresh();
                self.body = self.body
                    + "  "
                    + xs.clone()
                    + " = extractvalue "
                    + ety.clone()
                    + " "
                    + op
                    + ", 3\n";
                let xmv = self.emit_materialize_struct(xs, self.en_extra[ei] - 10);
                let Val { op: xmop, kind: xmk, heap: xmh } = xmv;
                let cur3 = self.fresh();
                self.body = self.body
                    + "  "
                    + cur3.clone()
                    + " = load "
                    + ety.clone()
                    + ", ptr "
                    + slot.clone()
                    + ", align 8\n";
                let ag2 = self.fresh();
                self.body = self.body
                    + "  "
                    + ag2.clone()
                    + " = insertvalue "
                    + ety.clone()
                    + " "
                    + cur3
                    + ", "
                    + self.ty_text(self.en_extra[ei])
                    + " "
                    + xmop
                    + ", 3\n";
                self.body = self.body
                    + "  store "
                    + ety.clone()
                    + " "
                    + ag2
                    + ", ptr "
                    + slot.clone()
                    + ", align 8\n";
                self.body = self.body + "  br label %" + ld2.clone() + "\n";
                self.body = self.body + ld2 + ":\n";
            }
        }
        let r = self.fresh();
        self.body = self.body + "  " + r.clone() + " = load " + ety + ", ptr " + slot + ", align 8\n";
        Val { op: r, kind: 1000 + ei, heap: true }
    }

    // Free the payload buffer a STR-ENUM VALUE owns, tag-conditionally
    // (Slice 23).
    // Free a batch of heap TEMPS that were lent to `ref` params (Slice 40) —
    // emitted AFTER the call, kind-dispatched. Non-heap kinds are skipped
    // (recorded only when heap=true, so every entry frees something).
    fn emit_ref_temp_frees(mut ref self, ops: Vec[String], kinds: Vec[i64]) {
        let mut i = 0;
        while i < ops.len() {
            let op = ops[i];
            let k = kinds[i];
            if k == 2 {
                self.emit_free_val(op);
            } else if k == 3 or k == 4 or k >= 2000 {
                self.emit_free_vec_val(op, k);
            } else if k >= 10 and k < 1000 {
                self.emit_free_struct_val(op, k - 10);
            } else if k >= 1000 and k < 2000 {
                self.emit_free_enum_val(op, k - 1000);
            }
            i = i + 1;
        }
    }

    fn emit_free_enum_val(mut ref self, op: String, ei: i64) {
        let ety = self.ty_text(1000 + ei);
        let tg = self.fresh();
        self.body = self.body
            + "  "
            + tg.clone()
            + " = extractvalue "
            + ety.clone()
            + " "
            + op.clone()
            + ", 0\n";
        let c = self.emit_enum_strtag_test(tg.clone(), ei);
        let lid = self.nlbl;
        self.nlbl = self.nlbl + 1;
        let lf = "enfr" + lid.to_string();
        let ld = "enfd" + lid.to_string();
        self.body =
            self.body + "  br i1 " + c + ", label %" + lf.clone() + ", label %" + ld.clone() + "\n";
        self.body = self.body + lf + ":\n";
        let s = self.fresh();
        self.body = self.body
            + "  "
            + s.clone()
            + " = extractvalue "
            + ety.clone()
            + " "
            + op.clone()
            + ", 2\n";
        self.emit_free_val(s);
        self.body = self.body + "  br label %" + ld.clone() + "\n";
        self.body = self.body + ld + ":\n";
        if self.en_extra[ei] >= 0 {
            // Free the STRUCT slot's heap (Slice 39), tag-gated.
            if self.st_has_heap(self.en_extra[ei] - 10) {
                let c2 = self.emit_enum_extratag_test(tg, ei);
                let lid2 = self.nlbl;
                self.nlbl = self.nlbl + 1;
                let lf2 = "enxf" + lid2.to_string();
                let ld2 = "enxd" + lid2.to_string();
                self.body = self.body
                    + "  br i1 "
                    + c2
                    + ", label %"
                    + lf2.clone()
                    + ", label %"
                    + ld2.clone()
                    + "\n";
                self.body = self.body + lf2 + ":\n";
                let xs = self.fresh();
                self.body =
                    self.body + "  " + xs.clone() + " = extractvalue " + ety + " " + op + ", 3\n";
                self.emit_free_struct_val(xs, self.en_extra[ei] - 10);
                self.body = self.body + "  br label %" + ld2.clone() + "\n";
                self.body = self.body + ld2 + ":\n";
            }
        }
    }

    fn st_has_heap(ref self, si: i64) -> bool {
        let off = self.st_off[si];
        let cnt = self.st_cnt[si];
        let mut fi = 0;
        while fi < cnt {
            let fk = self.st_field_kinds[off + fi];
            if fk == 2 {
                return true;
            }
            if fk >= 10 and fk < 1000 {
                // Nested struct field (Slice 33): heap-ness is transitive.
                if self.st_has_heap(fk - 10) {
                    return true;
                }
            }
            if fk >= 1000 and fk < 2000 {
                if self.en_has_heap(fk - 1000) {
                    return true;
                }
            }
            fi = fi + 1;
        }
        false
    }

    // Byte stride of struct `si` as a Vec element (Slice 18): i64/enum-free
    // POD fields are 8 bytes, String fields 16 ({ptr,i64}); bool-field structs
    // are excluded from vec elements by corpus discipline (i1 packing).
    fn st_stride(ref self, si: i64) -> i64 {
        let off = self.st_off[si];
        let cnt = self.st_cnt[si];
        let mut n = 0;
        let mut fi = 0;
        while fi < cnt {
            let fk = self.st_field_kinds[off + fi];
            if fk == 2 {
                n = n + 16;
            } else if fk >= 10 and fk < 1000 {
                // Nested struct field (Slice 33): its own stride.
                n = n + self.st_stride(fk - 10);
            } else if fk >= 1000 and fk < 2000 {
                let mut es = 16;
                if (fk >= 1002 and fk <= 1005) or self.en_has_heap(fk - 1000) {
                    es = 32;
                }
                n = n + es;
            } else {
                n = n + 8;
            }
            fi = fi + 1;
        }
        n
    }

    // Deep-copy a BORROWED struct value's String fields into a fresh OWNED
    // aggregate (Slice 15): each String field routes through
    // `emit_materialize`; POD fields ride along in the original aggregate.
    fn emit_materialize_struct(mut ref self, op: String, si: i64) -> Val {
        let sty = self.ty_text(10 + si);
        let off = self.st_off[si];
        let cnt = self.st_cnt[si];
        let mut cur = op.clone();
        let mut fi = 0;
        while fi < cnt {
            let fk = self.st_field_kinds[off + fi];
            let mut deep = fk == 2;
            if fk >= 10 and fk < 1000 {
                // Nested struct field (Slice 33): recurse when heap-bearing.
                deep = self.st_has_heap(fk - 10);
            }
            if fk >= 1000 and fk < 2000 {
                deep = self.en_has_heap(fk - 1000);
            }
            if deep {
                let f = self.fresh();
                self.body = self.body
                    + "  "
                    + f.clone()
                    + " = extractvalue "
                    + sty.clone()
                    + " "
                    + op.clone()
                    + ", "
                    + fi.to_string()
                    + "\n";
                let mut mop2 = "".to_string();
                if fk == 2 {
                    let mv = self.emit_materialize(f);
                    let Val { op: mop, kind: mk, heap: mh } = mv;
                    mop2 = mop;
                } else if fk < 1000 {
                    let mv = self.emit_materialize_struct(f, fk - 10);
                    let Val { op: mop, kind: mk, heap: mh } = mv;
                    mop2 = mop;
                } else {
                    let mv = self.emit_materialize_enum(f, fk - 1000);
                    let Val { op: mop, kind: mk, heap: mh } = mv;
                    mop2 = mop;
                }
                let r = self.fresh();
                self.body = self.body
                    + "  "
                    + r.clone()
                    + " = insertvalue "
                    + sty.clone()
                    + " "
                    + cur
                    + ", "
                    + self.ty_text(fk)
                    + " "
                    + mop2
                    + ", "
                    + fi.to_string()
                    + "\n";
                cur = r;
            }
            fi = fi + 1;
        }
        Val { op: cur, kind: 10 + si, heap: true }
    }

    // Free every String field a struct VALUE owns (Slice 15).
    fn emit_free_struct_val(mut ref self, op: String, si: i64) {
        let sty = self.ty_text(10 + si);
        let off = self.st_off[si];
        let cnt = self.st_cnt[si];
        let mut fi = 0;
        while fi < cnt {
            let fk = self.st_field_kinds[off + fi];
            let mut deep = fk == 2;
            if fk >= 10 and fk < 1000 {
                deep = self.st_has_heap(fk - 10);
            }
            if fk >= 1000 and fk < 2000 {
                deep = self.en_has_heap(fk - 1000);
            }
            if deep {
                let f = self.fresh();
                self.body = self.body
                    + "  "
                    + f.clone()
                    + " = extractvalue "
                    + sty.clone()
                    + " "
                    + op.clone()
                    + ", "
                    + fi.to_string()
                    + "\n";
                if fk == 2 {
                    self.emit_free_val(f);
                } else if fk < 1000 {
                    // Nested struct field (Slice 33): recurse.
                    self.emit_free_struct_val(f, fk - 10);
                } else {
                    self.emit_free_enum_val(f, fk - 1000);
                }
            }
            fi = fi + 1;
        }
    }

    // Free the heap buffer a STRING VALUE owns (extract ptr, call free).
    fn emit_free_val(mut ref self, val: String) {
        let pr = self.fresh();
        self.body =
            self.body + "  " + pr.clone() + " = extractvalue { ptr, i64 } " + val + ", 0\n";
        self.body = self.body + "  call void @free(ptr " + pr + ")\n";
    }

    // Free the heap buffer OWNED by local slot `idx` (load the aggregate,
    // extract the buffer pointer — field 0 for both string {ptr,i64} and
    // Vec {ptr,len,cap} — free) — reassignment's old value and the scope-exit
    // epilogue (Slices 9 + 13). free(null) is a no-op, so an empty Vec (null
    // ptr from `Vec.new()`) is safe.
    fn emit_free_slot(mut ref self, idx: i64) {
        let k = self.locals_kind[idx];
        if k >= 10 and k < 1000 {
            // A struct slot (Slice 15): free each owned String field.
            let sty = self.ty_text(k);
            let ag2 = self.fresh();
            self.body = self.body
                + "  "
                + ag2.clone()
                + " = load "
                + sty
                + ", ptr %v"
                + idx.to_string()
                + ", align 8\n";
            self.emit_free_struct_val(ag2, k - 10);
            return;
        }
        if k >= 1000 and k < 2000 {
            // A str-enum slot (Slice 23): tag-conditional payload free. Pure
            // enums are POD — nothing to do.
            if self.en_has_heap(k - 1000) {
                let ety = self.ty_text(k);
                let ag3 = self.fresh();
                self.body = self.body
                    + "  "
                    + ag3.clone()
                    + " = load "
                    + ety
                    + ", ptr %v"
                    + idx.to_string()
                    + ", align 8\n";
                self.emit_free_enum_val(ag3, k - 1000);
            }
            return;
        }
        let ty = self.ty_text(k);
        let ag = self.fresh();
        self.body = self.body
            + "  "
            + ag.clone()
            + " = load "
            + ty.clone()
            + ", ptr %v"
            + idx.to_string()
            + ", align 8\n";
        if k == 3 or k == 4 or k >= 2000 {
            // Vec slots (Slices 13/16/18) route through the value-form free
            // (Slice 24): per-element frees for heap elements, then the buffer.
            self.emit_free_vec_val(ag, k);
            return;
        }
        let pr = self.fresh();
        self.body = self.body
            + "  "
            + pr.clone()
            + " = extractvalue "
            + ty.clone()
            + " "
            + ag.clone()
            + ", 0\n";
        self.body = self.body + "  call void @free(ptr " + pr + ")\n";
    }

    // Kind-dispatched print of an emitted value + newline; frees an UNBOUND
    // heap temp (`println("hi " + name)`) right after printing (Slice 9).
    fn emit_println_val(mut ref self, op: String, kind: i64, heap: bool) {
        if kind == 1 {
            self.emit_println_bool(op);
        } else {
            if kind == 2 {
                self.emit_println_strval(op.clone());
                if heap {
                    self.emit_free_val(op);
                }
            } else if kind == 5 {
                // f64 (Slice 36): format via the runtime, print, free.
                let sv = self.emit_f64_to_string(op);
                let Val { op: sop, kind: sk, heap: sh } = sv;
                self.emit_println_strval(sop.clone());
                self.emit_free_val(sop);
            } else {
                self.emit_println_int(op);
            }
        }
    }

    // Format an f64 VALUE via `karac_runtime_f64_to_str` (Slice 36) — the
    // Rust `format!(\"{val}\")` shortest-roundtrip semantics, so output
    // matches the seed exactly. Returns an OWNED heap string.
    fn emit_f64_to_string(mut ref self, op: String) -> Val {
        let buf = self.fresh();
        self.body = self.body + "  " + buf.clone() + " = call ptr @malloc(i64 32)\n";
        let n = self.fresh();
        self.body = self.body
            + "  "
            + n.clone()
            + " = call i64 @karac_runtime_f64_to_str(double "
            + op
            + ", ptr "
            + buf.clone()
            + ", i64 32)\n";
        let a0 = self.fresh();
        self.body = self.body
            + "  "
            + a0.clone()
            + " = insertvalue { ptr, i64 } undef, ptr "
            + buf
            + ", 0\n";
        let a1 = self.fresh();
        self.body = self.body
            + "  "
            + a1.clone()
            + " = insertvalue { ptr, i64 } "
            + a0
            + ", i64 "
            + n
            + ", 1\n";
        Val { op: a1, kind: 2, heap: true }
    }

    // Print a STRING VALUE (`{ ptr, i64 }` aggregate operand): extract the
    // pointer and length, fwrite, newline (Slice 7).
    fn emit_println_strval(mut ref self, val: String) {
        let pr = self.fresh();
        self.body = self.body
            + "  "
            + pr.clone()
            + " = extractvalue { ptr, i64 } "
            + val.clone()
            + ", 0\n";
        let ln = self.fresh();
        self.body = self.body
            + "  "
            + ln.clone()
            + " = extractvalue { ptr, i64 } "
            + val
            + ", 1\n";
        let st = self.fresh();
        self.body = self.body + "  " + st.clone() + " = load ptr, ptr @stdout, align 8\n";
        let r = self.fresh();
        self.body = self.body
            + "  "
            + r
            + " = call i64 @fwrite(ptr "
            + pr
            + ", i64 1, i64 "
            + ln
            + ", ptr "
            + st
            + ")\n";
        self.emit_write("@.nl".to_string(), 1);
    }

    // `%tA = load ptr @stdout; %tB = call fwrite(gname, 1, len, %tA)`.
    fn emit_write(mut ref self, gname: String, len: i64) {
        let t0 = self.ntmp;
        self.ntmp = self.ntmp + 1;
        let t1 = self.ntmp;
        self.ntmp = self.ntmp + 1;
        self.body = self.body
            + "  %t"
            + t0.to_string()
            + " = load ptr, ptr @stdout, align 8\n";
        self.body = self.body
            + "  %t"
            + t1.to_string()
            + " = call i64 @fwrite(ptr "
            + gname
            + ", i64 1, i64 "
            + len.to_string()
            + ", ptr %t"
            + t0.to_string()
            + ")\n";
    }

    // A fresh SSA temporary name (`%tN`).
    fn fresh(mut ref self) -> String {
        let t = self.ntmp;
        self.ntmp = self.ntmp + 1;
        "%t" + t.to_string()
    }

    // Emit a VALUE expression and return its operand + type (Slice 2 ints,
    // Slice 4 bools). Integer literals / local reads / `+ - *` are i64;
    // comparisons (`== != < <= > >=` — icmp on i64 operands), logical `and`/`or`
    // (on i1), bool literals, and `not` are i1. Sub-expressions are emitted
    // before the combining instruction, so operands are always in scope.
    fn emit_value(mut ref self, e: Expr) -> Val {
        match e {
            Int(n) => {
                let IntLit { value, suffix, span } = n;
                Val { op: value.to_string(), kind: 0, heap: false }
            }
            Char(cl) => {
                // A char literal (Slice 37): int-backed — the Unicode scalar
                // value in an i64. Comparisons/enum payloads ride the int
                // machinery; PRINTING a char (UTF-8 encode parity) is a
                // deferred surface — corpus discipline is compare-only.
                let CharLit { value, span: clsp } = cl;
                Val {
                    op: (value as i64).to_string(),
                    kind: 0,
                    heap: false,
                }
            }
            Byte(bl) => {
                // A byte literal (Slice 37): int-backed, same as the u8
                // values `s.bytes()` already yields.
                let ByteLit { value, span: blsp } = bl;
                Val {
                    op: (value as i64).to_string(),
                    kind: 0,
                    heap: false,
                }
            }
            Float(fl) => {
                // A float literal (Slice 36): emitted as the EXACT hex bit
                // pattern — LLVM rejects inexact decimal FP text.
                let FloatLit { value, suffix, span: flsp } = fl;
                Val {
                    op: "0x".to_string() + hex_u64(value.to_bits() as i64),
                    kind: 5,
                    heap: false,
                }
            }
            Str(sl) => {
                // A string literal as a VALUE (Slice 7): intern the global and
                // build the `{ ptr, i64 }` aggregate via insertvalue.
                let StrLit { value: sv, span } = sl;
                let g = self.intern_str(sv);
                let StrG { name, len } = g;
                let t0 = self.fresh();
                self.body = self.body
                    + "  "
                    + t0.clone()
                    + " = insertvalue { ptr, i64 } undef, ptr "
                    + name
                    + ", 0\n";
                let t1 = self.fresh();
                self.body = self.body
                    + "  "
                    + t1.clone()
                    + " = insertvalue { ptr, i64 } "
                    + t0
                    + ", i64 "
                    + len.to_string()
                    + ", 1\n";
                Val { op: t1, kind: 2, heap: false }
            }
            Bool(n) => {
                let BoolLit { value, span } = n;
                if value {
                    Val { op: "true".to_string(), kind: 1, heap: false }
                } else {
                    Val { op: "false".to_string(), kind: 1, heap: false }
                }
            }
            SelfVal(sn) => {
                // `self` in a method body (Slice 27): a BORROW load of the
                // receiver slot — exactly an Ident read of the slot named
                // "self" (mut-ref receivers alias through the no-op GEP).
                let sname = "self".to_string();
                let idx = self.local_slot(sname);
                if idx < 0 {
                    return Val { op: "0".to_string(), kind: 0, heap: false };
                }
                let k = self.locals_kind[idx];
                let ty = self.ty_text(k);
                let r = self.fresh();
                self.body = self.body
                    + "  "
                    + r.clone()
                    + " = load "
                    + ty
                    + ", ptr %v"
                    + idx.to_string()
                    + ", align 8\n";
                Val { op: r, kind: k, heap: false }
            }
            Ident(ie) => {
                // A local variable read (Slice 3; typed slots Slice 7): load
                // from the slot with the slot's own type and kind.
                let IdentExpr { name, span } = ie;
                let idx = self.local_slot(name);
                if idx < 0 {
                    if name == "None" {
                        // `None` (Slice 29): zeroinitializer (tag 0) under a
                        // SENTINEL kind (-9, NEGATIVE so it passes none of
                        // the range checks — a positive sentinel would trip
                        // the >= 2000 vec legs) — the consuming context (let
                        // annotation / return type / param kind) supplies the
                        // concrete Option kind; zeroinit is valid for both
                        // layouts.
                        return Val { op: "zeroinitializer".to_string(), kind: 0 - 9, heap: false };
                    }
                    return Val { op: "0".to_string(), kind: 0, heap: false };
                }
                let k = self.locals_kind[idx];
                let ty = self.ty_text(k);
                let r = self.fresh();
                self.body = self.body
                    + "  "
                    + r.clone()
                    + " = load "
                    + ty
                    + ", ptr %v"
                    + idx.to_string()
                    + ", align 8\n";
                Val { op: r, kind: k, heap: false }
            }
            Unary(u) => {
                // `not b` (Slice 4): xor the i1 with true.
                let UnaryExpr { op, operand, span } = u;
                let inner = self.emit_value(operand);
                let Val { op: iop, kind: ik, heap: ih } = inner;
                let is_not = match op {
                    Not => true,
                    _ => false,
                };
                if is_not {
                    let r = self.fresh();
                    self.body =
                        self.body + "  " + r.clone() + " = xor i1 " + iop + ", true\n";
                    return Val { op: r, kind: 1, heap: false };
                }
                Val { op: iop, kind: ik, heap: false }
            }
            Binary(b) => {
                let BinaryExpr { op, left, right, span } = b;
                // ONE match on `op` (BinOp is not Copy) yields both the class
                // and the instruction text: comparison → `icmp <cc>` on i64 →
                // i1; logical → SHORT-CIRCUIT `and`/`or` (Slice 19 — the right
                // operand is evaluated inside a branch: the old non-short-
                // circuit lowering read `toks[p]` past the end in the parser's
                // `p < len and toks[p] == …` guard, an OOB read valgrind
                // caught); else arithmetic on i64.
                let bi = bin_ir(op);
                let BinIr { kind, text } = bi;
                if kind == 2 {
                    let lv2 = self.emit_value(left);
                    let Val { op: lop2, kind: lk2, heap: lh2 } = lv2;
                    let slot = self.fresh();
                    self.body = self.body + "  " + slot.clone() + " = alloca i1, align 1\n";
                    self.body = self.body
                        + "  store i1 "
                        + lop2.clone()
                        + ", ptr "
                        + slot.clone()
                        + ", align 1\n";
                    let lid = self.nlbl;
                    self.nlbl = self.nlbl + 1;
                    let lrhs = "sc" + lid.to_string();
                    let lend = "scend" + lid.to_string();
                    if text == "and" {
                        // and: evaluate rhs only when lhs is TRUE.
                        self.body = self.body
                            + "  br i1 "
                            + lop2
                            + ", label %"
                            + lrhs.clone()
                            + ", label %"
                            + lend.clone()
                            + "\n";
                    } else {
                        // or: evaluate rhs only when lhs is FALSE.
                        self.body = self.body
                            + "  br i1 "
                            + lop2
                            + ", label %"
                            + lend.clone()
                            + ", label %"
                            + lrhs.clone()
                            + "\n";
                    }
                    self.body = self.body + lrhs + ":\n";
                    let rv2 = self.emit_value(right);
                    let Val { op: rop2, kind: rk2, heap: rh2 } = rv2;
                    self.body = self.body
                        + "  store i1 "
                        + rop2
                        + ", ptr "
                        + slot.clone()
                        + ", align 1\n";
                    self.body = self.body + "  br label %" + lend.clone() + "\n";
                    self.body = self.body + lend + ":\n";
                    let r2 = self.fresh();
                    self.body = self.body
                        + "  "
                        + r2.clone()
                        + " = load i1, ptr "
                        + slot
                        + ", align 1\n";
                    return Val { op: r2, kind: 1, heap: false };
                }
                let lv = self.emit_value(left);
                let rv = self.emit_value(right);
                let Val { op: lop, kind: lk, heap: lh } = lv;
                let Val { op: rop, kind: rk, heap: rh } = rv;
                if kind == 1 and lk == 2 and rk == 2 {
                    // String ==/!= (Slice 17): length compare + memcmp.
                    if text == "eq" or text == "ne" {
                        let r = self.emit_str_eq(lop.clone(), rop.clone());
                        let Val { op: eop, kind: ek, heap: eh } = r;
                        if lh {
                            self.emit_free_val(lop);
                        }
                        if rh {
                            self.emit_free_val(rop);
                        }
                        if text == "ne" {
                            let n = self.fresh();
                            self.body =
                                self.body + "  " + n.clone() + " = xor i1 " + eop + ", true\n";
                            return Val { op: n, kind: 1, heap: false };
                        }
                        return Val { op: eop, kind: 1, heap: false };
                    }
                    // String ORDERING < <= > >= (Slice 26): lexicographic
                    // byte compare — memcmp over min(len) three-way, length
                    // difference breaks ties (was a SILENT constant-false).
                    let c3 = self.emit_str_cmp3(lop.clone(), rop.clone());
                    if lh {
                        self.emit_free_val(lop);
                    }
                    if rh {
                        self.emit_free_val(rop);
                    }
                    let r = self.fresh();
                    self.body = self.body
                        + "  "
                        + r.clone()
                        + " = icmp "
                        + text
                        + " i64 "
                        + c3
                        + ", 0\n";
                    return Val { op: r, kind: 1, heap: false };
                }
                if kind == 0 and text == "add" and lk == 2 and rk == 2 {
                    // String CONCATENATION (Slice 8): malloc(l1+l2), memcpy
                    // both halves, build the fresh { ptr, i64 } aggregate.
                    // Concat CONSUMES its operands (Slice 9): a heap-owned
                    // operand (an unbound temp — a nested concat like
                    // `"a" + "b" + "c"`) is freed right after the copies;
                    // binding-owned strings arrive as borrows (heap=false)
                    // and are freed by their binder.
                    let out = self.emit_concat(lop.clone(), rop.clone());
                    if lh {
                        self.emit_free_val(lop);
                    }
                    if rh {
                        self.emit_free_val(rop);
                    }
                    return out;
                }
                if lk == 5 and rk == 5 {
                    // f64 arithmetic + ORDERED comparisons (Slice 36).
                    let r5 = self.fresh();
                    if kind == 1 {
                        let mut cc5 = "oeq".to_string();
                        if text == "ne" {
                            cc5 = "one".to_string();
                        }
                        if text == "slt" {
                            cc5 = "olt".to_string();
                        }
                        if text == "sle" {
                            cc5 = "ole".to_string();
                        }
                        if text == "sgt" {
                            cc5 = "ogt".to_string();
                        }
                        if text == "sge" {
                            cc5 = "oge".to_string();
                        }
                        self.body = self.body
                            + "  "
                            + r5.clone()
                            + " = fcmp "
                            + cc5
                            + " double "
                            + lop
                            + ", "
                            + rop
                            + "\n";
                        return Val { op: r5, kind: 1, heap: false };
                    }
                    let mut op5 = "fadd".to_string();
                    if text == "sub" {
                        op5 = "fsub".to_string();
                    }
                    if text == "mul" {
                        op5 = "fmul".to_string();
                    }
                    if text == "sdiv" {
                        op5 = "fdiv".to_string();
                    }
                    if text == "srem" {
                        op5 = "frem".to_string();
                    }
                    self.body = self.body
                        + "  "
                        + r5.clone()
                        + " = "
                        + op5
                        + " double "
                        + lop
                        + ", "
                        + rop
                        + "\n";
                    return Val { op: r5, kind: 5, heap: false };
                }
                let r = self.fresh();
                if kind == 1 {
                    self.body = self.body
                        + "  "
                        + r.clone()
                        + " = icmp "
                        + text
                        + " i64 "
                        + lop
                        + ", "
                        + rop
                        + "\n";
                    return Val { op: r, kind: 1, heap: false };
                }

                self.body =
                    self.body + "  " + r.clone() + " = " + text + " i64 " + lop + ", " + rop + "\n";
                Val { op: r, kind: 0, heap: false }
            }
            Call(cn) => {
                // A user-function call in VALUE position (Slice 6).
                let CallExpr { callee, args, span } = cn;
                let mut cname = "".to_string();
                let mut vec_new = false;
                let mut enum_ei = 0 - 1;
                let mut enum_tag = 0 - 1;
                match callee {
                    Ident(ie) => {
                        let IdentExpr { name, span: isp } = ie;
                        cname = name;
                    }
                    Path(pe) => {
                        // `Vec.new()` / `Enum.Variant(payload)` both parse as a
                        // CALL with a PATH callee (Slices 13 + 14).
                        let PathExpr { segments, span: psp } = pe;
                        if segments.len() == 2 {
                            if segments[0] == "Vec" and segments[1] == "new" {
                                vec_new = true;
                            } else {
                                let ei2 = self.en_index(segments[0]);
                                if ei2 >= 0 {
                                    enum_ei = ei2;
                                    enum_tag = self.en_variant_tag(ei2, segments[1]);
                                } else {
                                    // `Type.assoc(...)` (Slice 27): a NoSelf
                                    // impl fn — sig key "<Type>.<name>", the
                                    // symbol mangles via sym_of below.
                                    let sti2 = self.st_index(segments[0]);
                                    if sti2 >= 0 {
                                        cname = segments[0] + "." + segments[1];
                                    }
                                }
                            }
                        }
                    }
                    _ => {}
                }
                if vec_new {
                    return Val { op: "zeroinitializer".to_string(), kind: 3, heap: true };
                }
                if cname == "Some" {
                    // `Some(x)` (Slice 29): construct the synthetic Option
                    // enum picked by the payload's kind (0 → Option$i /
                    // kind 1000, 2 → Option$s / kind 1001). Tag 1 = Some.
                    let mut pv2 = "0".to_string();
                    let mut pk3 = 0;
                    let mut ph2 = false;
                    for a in args {
                        let CallArg { label, mut_marker, value, span: asp } = a;
                        let av = self.emit_value(value);
                        let Val { op: aop, kind: ak, heap: ah } = av;
                        pv2 = aop;
                        pk3 = ak;
                        ph2 = ah;
                    }
                    if pk3 == 2 {
                        let ety2 = self.ty_text(1001);
                        let a0 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a0.clone()
                            + " = insertvalue "
                            + ety2.clone()
                            + " zeroinitializer, i64 1, 0\n";
                        let mut sv2 = pv2;
                        if not ph2 {
                            let mv = self.emit_materialize(sv2.clone());
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            sv2 = mop;
                        }
                        let a1 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a1.clone()
                            + " = insertvalue "
                            + ety2
                            + " "
                            + a0
                            + ", { ptr, i64 } "
                            + sv2
                            + ", 2\n";
                        return Val { op: a1, kind: 1001, heap: true };
                    }
                    let a0 = self.fresh();
                    self.body = self.body
                        + "  "
                        + a0.clone()
                        + " = insertvalue { i64, i64 } zeroinitializer, i64 1, 0\n";
                    let a1 = self.fresh();
                    self.body = self.body
                        + "  "
                        + a1.clone()
                        + " = insertvalue { i64, i64 } "
                        + a0
                        + ", i64 "
                        + pv2
                        + ", 1\n";
                    return Val { op: a1, kind: 1000, heap: false };
                }
                if cname == "Ok" or cname == "Err" {
                    // `Ok(x)` / `Err(e)` (Slice 30): construct into the
                    // uniform widened Result layout — payload slot by the
                    // arg's kind, tag 0/1 — under the Result sentinel kind
                    // (-10); the consuming context picks the instantiation.
                    let mut rtag = 0;
                    if cname == "Err" {
                        rtag = 1;
                    }
                    let mut pv3 = "0".to_string();
                    let mut pk4 = 0;
                    let mut ph3 = false;
                    for a in args {
                        let CallArg { label, mut_marker, value, span: asp } = a;
                        let av = self.emit_value(value);
                        let Val { op: aop, kind: ak, heap: ah } = av;
                        pv3 = aop;
                        pk4 = ak;
                        ph3 = ah;
                    }
                    let rty3 = "{ i64, i64, { ptr, i64 } }".to_string();
                    let a0 = self.fresh();
                    self.body = self.body
                        + "  "
                        + a0.clone()
                        + " = insertvalue "
                        + rty3.clone()
                        + " zeroinitializer, i64 "
                        + rtag.to_string()
                        + ", 0\n";
                    if pk4 == 2 {
                        let mut sv3 = pv3;
                        if not ph3 {
                            let mv = self.emit_materialize(sv3.clone());
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            sv3 = mop;
                        }
                        let a1 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a1.clone()
                            + " = insertvalue "
                            + rty3
                            + " "
                            + a0
                            + ", { ptr, i64 } "
                            + sv3
                            + ", 2\n";
                        return Val { op: a1, kind: 0 - 10, heap: true };
                    }
                    let a1 = self.fresh();
                    self.body = self.body
                        + "  "
                        + a1.clone()
                        + " = insertvalue "
                        + rty3
                        + " "
                        + a0
                        + ", i64 "
                        + pv3
                        + ", 1\n";
                    return Val { op: a1, kind: 0 - 10, heap: false };
                }
                if enum_ei >= 0 and enum_tag >= 0 {
                    // Payload-carrying construction (Slice 14; String payloads
                    // Slice 23; TWO-payload variants Slice 35). Args route by
                    // KIND into the widened layout: i64 → slot 1, String →
                    // slot 2 (materialized in if borrowed). Base is
                    // zeroinitializer so untouched payload slots hold null/0
                    // — the tag-guarded free/copy paths never read them, and
                    // free(null) is a no-op besides.
                    let ety = self.ty_text(1000 + enum_ei);
                    let mut iv2 = "".to_string();
                    let mut sv2 = "".to_string();
                    let mut sh2 = false;
                    let mut xv2 = "".to_string();
                    let mut xk2 = 0 - 1;
                    let mut xh2 = false;
                    for a in args {
                        let CallArg { label, mut_marker, value, span: asp } = a;
                        let av = self.emit_value(value);
                        let Val { op: aop, kind: ak, heap: ah } = av;
                        if ak == 2 {
                            sv2 = aop;
                            sh2 = ah;
                        } else if ak >= 10 and ak < 1000 {
                            // A STRUCT payload (Slice 39) → slot 3.
                            xv2 = aop;
                            xk2 = ak;
                            xh2 = ah;
                        } else {
                            iv2 = aop;
                        }
                    }
                    let a0 = self.fresh();
                    self.body = self.body
                        + "  "
                        + a0.clone()
                        + " = insertvalue "
                        + ety.clone()
                        + " zeroinitializer, i64 "
                        + enum_tag.to_string()
                        + ", 0\n";
                    let mut cur2 = a0;
                    let mut has_str = false;
                    if iv2 != "" {
                        let a1 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a1.clone()
                            + " = insertvalue "
                            + ety.clone()
                            + " "
                            + cur2
                            + ", i64 "
                            + iv2
                            + ", 1\n";
                        cur2 = a1;
                    }
                    if sv2 != "" {
                        has_str = true;
                        let mut sv = sv2;
                        if not sh2 {
                            let mv = self.emit_materialize(sv.clone());
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            sv = mop;
                        }
                        let a2 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a2.clone()
                            + " = insertvalue "
                            + ety.clone()
                            + " "
                            + cur2
                            + ", { ptr, i64 } "
                            + sv
                            + ", 2\n";
                        cur2 = a2;
                    }
                    if xk2 >= 0 {
                        // Struct payload → slot 3 (Slice 39): a borrowed
                        // heap-bearing struct deep-copies in; a temp
                        // transfers.
                        let mut xv = xv2;
                        if not xh2 and self.st_has_heap(xk2 - 10) {
                            let mv = self.emit_materialize_struct(xv.clone(), xk2 - 10);
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            xv = mop;
                        }
                        if self.st_has_heap(xk2 - 10) {
                            has_str = true;
                        }
                        let a3 = self.fresh();
                        self.body = self.body
                            + "  "
                            + a3.clone()
                            + " = insertvalue "
                            + ety
                            + " "
                            + cur2
                            + ", "
                            + self.ty_text(xk2)
                            + " "
                            + xv
                            + ", 3\n";
                        cur2 = a3;
                    }
                    return Val { op: cur2, kind: 1000 + enum_ei, heap: has_str };
                }
                let si = self.sig_index(cname);
                let mut alist = "".to_string();
                let mut ai = 0;
                // Heap TEMPS passed to `ref` params (Slice 40): the callee is
                // non-owning, so the CALLER frees them AFTER the call (a
                // binding-owned arg is heap=false and its binder frees it —
                // nothing to do). Collected op+kind, freed post-call.
                let mut rt_ops: Vec[String] = Vec.new();
                let mut rt_kinds: Vec[i64] = Vec.new();
                for a in args {
                    let CallArg { label, mut_marker, value, span: asp } = a;
                    let v = self.emit_value(value);
                    let Val { op, kind, heap } = v;
                    // Param kind from the signature table (Slice 10): a String
                    // param takes an OWNED aggregate — a borrowed arg (ident /
                    // literal) is materialized into a private copy (args move
                    // in; the binder keeps and later frees its own buffer), a
                    // heap temp transfers ownership directly.
                    let mut pk = 0;
                    let mut pref = false;
                    if si >= 0 {
                        if ai < self.sig_par_cnt[si] {
                            pk = self.sig_par_kinds[self.sig_par_off[si] + ai];
                            pref = self.sig_par_ref[self.sig_par_off[si] + ai];
                        }
                    }
                    let mut aop = op;
                    // A `ref` param takes the borrow bit-copy directly (Slice 19).
                    if pk == 2 and not pref and kind == 2 and not heap {
                        let mv = self.emit_materialize(aop.clone());
                        let Val { op: mop, kind: mk, heap: mh } = mv;
                        aop = mop;
                    }
                    if pk >= 10 and pk < 1000 and not pref and kind == pk and not heap {
                        // A borrowed heap-bearing struct arg moves in as a
                        // deep copy (Slice 15); a temp transfers.
                        if self.st_has_heap(pk - 10) {
                            let mv = self.emit_materialize_struct(aop.clone(), pk - 10);
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            aop = mop;
                        }
                    }
                    if pk >= 1000 and pk < 2000 and not pref and kind == pk and not heap {
                        // A borrowed str-enum arg moves in as a payload deep
                        // copy (Slice 23); a temp transfers.
                        if self.en_has_heap(pk - 1000) {
                            let mv = self.emit_materialize_enum(aop.clone(), pk - 1000);
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            aop = mop;
                        }
                    }
                    if (pk == 3 or pk == 4 or pk >= 2000) and not pref and kind == pk and not heap {
                        // A borrowed vec arg moves in as a deep copy (Slice
                        // 24); a temp transfers.
                        let mv = self.emit_materialize_vec(aop.clone(), pk);
                        let Val { op: mop, kind: mk, heap: mh } = mv;
                        aop = mop;
                    }
                    if pref and heap {
                        // A heap temp lent to a `ref` param (Slice 40): record
                        // it for a post-call free (nobody else owns it).
                        rt_ops.push(aop.clone());
                        rt_kinds.push(pk);
                    }
                    if ai > 0 {
                        alist = alist + ", ";
                    }
                    alist = alist + self.ty_text(pk) + " " + aop;
                    ai = ai + 1;
                }
                if cname == "" {
                    return Val { op: "0".to_string(), kind: 0, heap: false };
                }
                // The emitted symbol (Slice 27): a dotted sig name ("Type.fn",
                // an associated fn) mangles to u_Type_m_fn; free fns pass
                // through as u_<name>.
                let csym = "u_".to_string() + self.sym_of(cname);
                let mut rk = 0;
                if si >= 0 {
                    rk = self.sig_ret[si];
                }
                let r = self.fresh();
                if rk == 1 {
                    self.body = self.body
                        + "  "
                        + r.clone()
                        + " = call i1 @"
                        + csym
                        + "("
                        + alist
                        + ")\n";
                    self.emit_ref_temp_frees(rt_ops, rt_kinds);
                    return Val { op: r, kind: 1, heap: false };
                }
                if rk == 2 {
                    self.body = self.body
                        + "  "
                        + r.clone()
                        + " = call { ptr, i64 } @"
                        + csym
                        + "("
                        + alist
                        + ")\n";
                    self.emit_ref_temp_frees(rt_ops, rt_kinds);
                    return Val { op: r, kind: 2, heap: true };
                }
                if rk == 3 or rk == 4 or rk == 5 or rk >= 10 {
                    self.body = self.body
                        + "  "
                        + r.clone()
                        + " = call "
                        + self.ty_text(rk)
                        + " @"
                        + csym
                        + "("
                        + alist
                        + ")\n";
                    self.emit_ref_temp_frees(rt_ops, rt_kinds);
                    let mut rh = false;
                    if rk >= 10 and rk < 1000 {
                        rh = self.st_has_heap(rk - 10);
                    }
                    if rk >= 1000 and rk < 2000 {
                        rh = self.en_has_heap(rk - 1000);
                    }
                    if rk == 3 or rk == 4 or rk >= 2000 {
                        // A vec result is always caller-owned (Slice 24).
                        rh = true;
                    }
                    return Val { op: r, kind: rk, heap: rh };
                }
                self.body = self.body
                    + "  "
                    + r.clone()
                    + " = call i64 @"
                    + csym
                    + "("
                    + alist
                    + ")\n";
                self.emit_ref_temp_frees(rt_ops, rt_kinds);
                Val { op: r, kind: 0, heap: false }
            }
            If(n) => {
                // `if` in VALUE position (Slice 6): route each branch's tail
                // value through a result slot, then load it at the join — the
                // slot stands in for a phi without block-predecessor tracking.
                let IfExpr { cond, then_block, else_branch, span } = n;
                let slot = self.fresh();
                self.body = self.body + "  " + slot.clone() + " = alloca i64, align 8\n";
                let c = self.emit_value(cond);
                let Val { op: cop, kind: ck, heap: ch } = c;
                let lid = self.nlbl;
                self.nlbl = self.nlbl + 1;
                let lthen = "vthen" + lid.to_string();
                let lelse = "velse" + lid.to_string();
                let lend = "vend" + lid.to_string();
                self.body = self.body
                    + "  br i1 "
                    + cop
                    + ", label %"
                    + lthen.clone()
                    + ", label %"
                    + lelse.clone()
                    + "\n";
                self.body = self.body + lthen + ":\n";
                let tv = self.emit_block_value(then_block);
                let Val { op: top, kind: tk, heap: th } = tv;
                self.body =
                    self.body + "  store i64 " + top + ", ptr " + slot.clone() + ", align 8\n";
                self.body = self.body + "  br label %" + lend.clone() + "\n";
                self.body = self.body + lelse + ":\n";
                match else_branch {
                    Some(eb) => {
                        let ev = self.emit_value(eb);
                        let Val { op: eop, kind: ek, heap: eh } = ev;
                        self.body = self.body
                            + "  store i64 "
                            + eop
                            + ", ptr "
                            + slot.clone()
                            + ", align 8\n";
                    }
                    None => {
                        self.body =
                            self.body + "  store i64 0, ptr " + slot.clone() + ", align 8\n";
                    }
                }
                self.body = self.body + "  br label %" + lend.clone() + "\n";
                self.body = self.body + lend + ":\n";
                let r = self.fresh();
                self.body =
                    self.body + "  " + r.clone() + " = load i64, ptr " + slot + ", align 8\n";
                Val { op: r, kind: 0, heap: false }
            }
            Match(mn) => self.emit_match(mn, true),
            Path(pe) => {
                // A bare qualified path `Enum.Variant` (payload-less
                // construction, Slice 14): { tag, 0 }.
                let PathExpr { segments, span } = pe;
                if segments.len() == 2 {
                    let ei = self.en_index(segments[0]);
                    if ei >= 0 {
                        let tag = self.en_variant_tag(ei, segments[1]);
                        if tag >= 0 {
                            // Zeroinitializer base (Slice 23): a str-enum's
                            // untouched payload slot must hold null, not undef
                            // — every payload read is tag-guarded anyway.
                            let ety = self.ty_text(1000 + ei);
                            let a0 = self.fresh();
                            self.body = self.body
                                + "  "
                                + a0.clone()
                                + " = insertvalue "
                                + ety
                                + " zeroinitializer, i64 "
                                + tag.to_string()
                                + ", 0\n";
                            return Val { op: a0, kind: 1000 + ei, heap: false };
                        }
                    }
                }
                Val { op: "0".to_string(), kind: 0, heap: false }
            }
            Index(ix) => {
                // `v[i]` (Slice 13, Vec[i64] elements): extract the buffer
                // pointer, gep, load. In-bounds by corpus discipline — the
                // seed's bounds-check panic is a deferred parity surface.
                let IndexExpr { object, index, span } = ix;
                let ov = self.emit_value(object);
                let Val { op: oop, kind: ok, heap: oh } = ov;
                let iv = self.emit_value(index);
                let Val { op: iop2, kind: ik2, heap: ih2 } = iv;
                if ok >= 2000 {
                    // `v[i]` on a Vec[<struct>] (Slice 18) or Vec[<enum>]
                    // (Slice 32): load the element as a BORROW — the vec
                    // keeps ownership; a binding deep-copies via the
                    // matching materialize path.
                    let mut ek5 = 10 + (ok - 2000);
                    if ok >= 4000 {
                        ek5 = 1000 + (ok - 4000);
                    }
                    let sty = self.ty_text(ek5);
                    let prs = self.fresh();
                    self.body = self.body
                        + "  "
                        + prs.clone()
                        + " = extractvalue { ptr, i64, i64 } "
                        + oop
                        + ", 0\n";
                    let eps = self.fresh();
                    self.body = self.body
                        + "  "
                        + eps.clone()
                        + " = getelementptr "
                        + sty.clone()
                        + ", ptr "
                        + prs
                        + ", i64 "
                        + iop2
                        + "\n";
                    let rs = self.fresh();
                    self.body = self.body
                        + "  "
                        + rs.clone()
                        + " = load "
                        + sty
                        + ", ptr "
                        + eps
                        + ", align 8\n";
                    return Val { op: rs, kind: ek5, heap: false };
                }
                if ok == 4 {
                    // `v[i]` on a Vec[String] (Slice 16): the element is a
                    // BORROW — the vec keeps ownership; a binding materializes.
                    let pr4 = self.fresh();
                    self.body = self.body
                        + "  "
                        + pr4.clone()
                        + " = extractvalue { ptr, i64, i64 } "
                        + oop
                        + ", 0\n";
                    let ep4 = self.fresh();
                    self.body = self.body
                        + "  "
                        + ep4.clone()
                        + " = getelementptr { ptr, i64 }, ptr "
                        + pr4
                        + ", i64 "
                        + iop2
                        + "\n";
                    let r4 = self.fresh();
                    self.body = self.body
                        + "  "
                        + r4.clone()
                        + " = load { ptr, i64 }, ptr "
                        + ep4
                        + ", align 8\n";
                    return Val { op: r4, kind: 2, heap: false };
                }
                if ok != 3 {
                    return Val { op: "0".to_string(), kind: 0, heap: false };
                }
                let pr = self.fresh();
                self.body = self.body
                    + "  "
                    + pr.clone()
                    + " = extractvalue { ptr, i64, i64 } "
                    + oop
                    + ", 0\n";
                let ep = self.fresh();
                self.body = self.body
                    + "  "
                    + ep.clone()
                    + " = getelementptr i64, ptr "
                    + pr
                    + ", i64 "
                    + iop2
                    + "\n";
                let r = self.fresh();
                self.body =
                    self.body + "  " + r.clone() + " = load i64, ptr " + ep + ", align 8\n";
                Val { op: r, kind: 0, heap: false }
            }
            Blk(b) => self.emit_block_value(b),
            StructLit(sl) => {
                // POD struct CONSTRUCTION (Slice 12): evaluate literal fields
                // in LITERAL order (the seed's evaluation order), then chain
                // insertvalue in DECLARED order via name matching.
                // Literal fields evaluate in LITERAL order (the seed's
                // order) via the consuming for+destructure loop — the emitter's
                // proven pattern; the indexed-Expr-copy variant
                // (`emit_value(fields[li].value)`) double-freed under AOT
                // (run-vs-build, the indexed-enum-payload-copy class).
                let StructLitExpr { name, fields, spread, span } = sl;
                let si = self.st_index(name);
                if si < 0 {
                    return Val { op: "0".to_string(), kind: 0, heap: false };
                }
                let mut lit_names = Vec.new();
                let mut lit_ops = Vec.new();
                for lf in fields {
                    let StructLitField { name: fname, value, shorthand, span: fsp } = lf;
                    let v = self.emit_value(value);
                    let Val { op, kind, heap } = v;
                    let mut fop2 = op;
                    if kind == 2 and not heap {
                        // The literal OWNS its String fields (Slice 15):
                        // materialize a borrowed value in; a heap temp
                        // transfers directly.
                        let mv = self.emit_materialize(fop2.clone());
                        let Val { op: mop, kind: mk, heap: mh } = mv;
                        fop2 = mop;
                    }
                    if kind >= 10 and kind < 1000 and not heap {
                        // A borrowed nested-struct field value (Slice 33)
                        // deep-copies in.
                        if self.st_has_heap(kind - 10) {
                            let mv = self.emit_materialize_struct(fop2.clone(), kind - 10);
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            fop2 = mop;
                        }
                    }
                    if kind >= 1000 and kind < 2000 and not heap {
                        // A borrowed enum field value (Slice 33):
                        // tag-conditional deep copy.
                        if self.en_has_heap(kind - 1000) {
                            let mv = self.emit_materialize_enum(fop2.clone(), kind - 1000);
                            let Val { op: mop, kind: mk, heap: mh } = mv;
                            fop2 = mop;
                        }
                    }
                    lit_names.push(fname);
                    lit_ops.push(fop2);
                }
                let off = self.st_off[si];
                let cnt = self.st_cnt[si];
                let sty = self.ty_text(10 + si);
                let mut cur = "undef".to_string();
                let mut fi = 0;
                while fi < cnt {
                    let want = self.st_field_names[off + fi];
                    let mut fop = "0".to_string();
                    let mut li = 0;
                    while li < lit_names.len() {
                        if lit_names[li] == want {
                            fop = lit_ops[li];
                        }
                        li = li + 1;
                    }
                    let r = self.fresh();
                    self.body = self.body
                        + "  "
                        + r.clone()
                        + " = insertvalue "
                        + sty.clone()
                        + " "
                        + cur
                        + ", "
                        + self.ty_text(self.st_field_kinds[off + fi])
                        + " "
                        + fop
                        + ", "
                        + fi.to_string()
                        + "\n";
                    cur = r;
                    fi = fi + 1;
                }
                Val {
                    op: cur,
                    kind: 10 + si,
                    heap: self.st_has_heap(si),
                }
            }
            Field(fa) => {
                // POD struct FIELD READ (Slice 12): extractvalue by declared
                // index; the result carries the field's kind.
                let FieldAccessExpr { object, field, span } = fa;
                let v = self.emit_value(object);
                let Val { op, kind, heap } = v;
                if kind < 10 or kind >= 1000 {
                    return Val { op: "0".to_string(), kind: 0, heap: false };
                }
                let si = kind - 10;
                let off = self.st_off[si];
                let cnt = self.st_cnt[si];
                let mut fi = 0;
                let mut idx = 0 - 1;
                let mut fk = 0;
                while fi < cnt {
                    if self.st_field_names[off + fi] == field {
                        idx = fi;
                        fk = self.st_field_kinds[off + fi];
                    }
                    fi = fi + 1;
                }
                if idx < 0 {
                    return Val { op: "0".to_string(), kind: 0, heap: false };
                }
                let r = self.fresh();
                self.body = self.body
                    + "  "
                    + r.clone()
                    + " = extractvalue "
                    + self.ty_text(kind)
                    + " "
                    + op
                    + ", "
                    + idx.to_string()
                    + "\n";
                Val { op: r, kind: fk, heap: false }
            }
            MethodCall(mc) => {
                let MethodCallExpr { object, method, args: margs, span: msp } = mc;
                self.emit_method_value(object, method, margs)
            }
            _ => Val { op: "0".to_string(), kind: 0, heap: false },
        }
    }

    // Method-call VALUE dispatch (Slices 11/13/17), taking the DESTRUCTURED
    // node parts — callers never rebuild a MethodCallExpr (reconstruction and
    // re-wrapping a match payload both double-free under the seed's AOT).
    // `<expr>.to_string()`: an i64 formats into a fresh heap buffer via
    // snprintf — an OWNED temp; a bool selects the `@.true`/`@.false` globals
    // — a BORROW; a string passes through. `Vec.new` / `len` / `substring`
    // as documented at their arms. Other methods stay unsupported (0).
    fn emit_method_value(
        mut ref self,
        object: Expr,
        method: String,
        margs: Vec[CallArg],
    ) -> Val {
        // USER METHOD DISPATCH (Slice 27). A name-only pre-scan (does ANY
        // "<Type>.<method>" sig exist?) decides the path WITHOUT consuming
        // `object` — matching the receiver first would move it away from the
        // builtin paths below (the B-2026-07-18-29 no-rebuild discipline).
        // Corpus discipline: user methods don't reuse builtin names
        // (len/push/substring/bytes/to_string/new).
        let mut is_user = false;
        let mlen = method.len();
        let mut si2 = 0;
        while si2 < self.sig_names.len() {
            let sn4 = self.sig_names[si2];
            if sn4.len() > mlen + 1 {
                let dot = sn4.substring(sn4.len() - mlen - 1, sn4.len() - mlen);
                let tail = sn4.substring(sn4.len() - mlen, sn4.len());
                if dot == "." and tail == method {
                    is_user = true;
                }
            }
            si2 = si2 + 1;
        }
        if is_user {
            // Receiver must be a SLOT (an Ident local/param or `self`) — the
            // three self modes all address the receiver through its slot.
            let mut ridx = 0 - 1;
            match object {
                Ident(rie) => {
                    let IdentExpr { name: rn, span: rsp } = rie;
                    ridx = self.local_slot(rn);
                }
                SelfVal(rsn) => {
                    let sname3 = "self".to_string();
                    ridx = self.local_slot(sname3);
                }
                _ => {}
            }
            if ridx < 0 {
                return Val { op: "0".to_string(), kind: 0, heap: false };
            }
            let rck = self.locals_kind[ridx];
            if rck < 10 or rck >= 2000 {
                return Val { op: "0".to_string(), kind: 0, heap: false };
            }
            let mut tn = "".to_string();
            if rck < 1000 {
                tn = self.st_names[rck - 10];
            } else {
                // Enum receiver (Slice 31).
                tn = self.en_names[rck - 1000];
            }
            let key = tn.clone() + "." + method.clone();
            let si = self.sig_index(key);
            if si < 0 {
                return Val { op: "0".to_string(), kind: 0, heap: false };
            }
            let smode = self.sig_self_mode[si];
            let mut alist = "".to_string();
            if smode == 2 {
                // `mut ref self`: pass the receiver's slot pointer.
                alist = "ptr %v" + ridx.to_string();
            } else {
                let sty3 = self.ty_text(rck);
                let rv2 = self.fresh();
                self.body = self.body
                    + "  "
                    + rv2.clone()
                    + " = load "
                    + sty3.clone()
                    + ", ptr %v"
                    + ridx.to_string()
                    + ", align 8\n";
                let mut rop2 = rv2;
                if smode == 0 and rck < 1000 and self.st_has_heap(rck - 10) {
                    // Owned self MOVES IN: the borrow deep-copies (the
                    // binder keeps + frees its own buffers).
                    let mv = self.emit_materialize_struct(rop2.clone(), rck - 10);
                    let Val { op: mop, kind: mk, heap: mh } = mv;
                    rop2 = mop;
                }
                if smode == 0 and rck >= 1000 and self.en_has_heap(rck - 1000) {
                    // Owned ENUM self (Slice 31): tag-conditional deep copy.
                    let mv = self.emit_materialize_enum(rop2.clone(), rck - 1000);
                    let Val { op: mop, kind: mk, heap: mh } = mv;
                    rop2 = mop;
                }
                alist = sty3 + " " + rop2;
            }
            let mut ai = 1;
            let mut rt_ops: Vec[String] = Vec.new();
            let mut rt_kinds: Vec[i64] = Vec.new();
            for ma in margs {
                let CallArg { label, mut_marker, value, span: masp } = ma;
                let av = self.emit_value(value);
                let Val { op: aop0, kind: ak, heap: ah } = av;
                let mut aop = aop0;
                let mut pk = 0;
                let mut pref = false;
                if ai - 1 < self.sig_par_cnt[si] {
                    pk = self.sig_par_kinds[self.sig_par_off[si] + (ai - 1)];
                    pref = self.sig_par_ref[self.sig_par_off[si] + (ai - 1)];
                }
                if pk == 2 and not pref and ak == 2 and not ah {
                    let mv = self.emit_materialize(aop.clone());
                    let Val { op: mop, kind: mk, heap: mh } = mv;
                    aop = mop;
                }
                if pk >= 10 and pk < 1000 and not pref and ak == pk and not ah {
                    if self.st_has_heap(pk - 10) {
                        let mv = self.emit_materialize_struct(aop.clone(), pk - 10);
                        let Val { op: mop, kind: mk, heap: mh } = mv;
                        aop = mop;
                    }
                }
                if (pk == 3 or pk == 4 or pk >= 2000) and not pref and ak == pk and not ah {
                    let mv = self.emit_materialize_vec(aop.clone(), pk);
                    let Val { op: mop, kind: mk, heap: mh } = mv;
                    aop = mop;
                }
                if pref and ah {
                    // Heap temp lent to a `ref` method param (Slice 40).
                    rt_ops.push(aop.clone());
                    rt_kinds.push(pk);
                }
                alist = alist + ", " + self.ty_text(pk) + " " + aop;
                ai = ai + 1;
            }
            let rk = self.sig_ret[si];
            let sym = "@u_" + tn + "_m_" + method;
            let r = self.fresh();
            let mut rty2 = "i64".to_string();
            if rk == 1 or rk == 2 or rk == 3 or rk == 4 or rk == 5 or rk >= 10 {
                rty2 = self.ty_text(rk);
            }
            self.body = self.body
                + "  "
                + r.clone()
                + " = call "
                + rty2
                + " "
                + sym
                + "("
                + alist
                + ")\n";
            self.emit_ref_temp_frees(rt_ops, rt_kinds);
            let mut rh = false;
            if rk == 2 or rk == 3 or rk == 4 or rk >= 2000 {
                rh = true;
            }
            if rk >= 10 and rk < 1000 {
                rh = self.st_has_heap(rk - 10);
            }
            if rk >= 1000 and rk < 2000 {
                rh = self.en_has_heap(rk - 1000);
            }
            if rk < 0 {
                return Val { op: "0".to_string(), kind: 0, heap: false };
            }
            return Val { op: r, kind: rk, heap: rh };
        }
        if method == "is_some" or method == "is_none" or method == "is_ok" or method == "is_err" {
            // Option/Result tag predicates (Slice 34): extract the tag and
            // compare against 0 — None=0/Some=1, Ok=0/Err=1, so is_none and
            // is_ok test eq while is_some and is_err test ne.
            let ov9 = self.emit_value(object);
            let Val { op: oop9, kind: ok9, heap: oh9 } = ov9;
            if ok9 >= 1000 and ok9 < 2000 {
                let ety9 = self.ty_text(ok9);
                let tg9 = self.fresh();
                self.body = self.body
                    + "  "
                    + tg9.clone()
                    + " = extractvalue "
                    + ety9
                    + " "
                    + oop9
                    + ", 0\n";
                let mut cc = "ne".to_string();
                if method == "is_none" or method == "is_ok" {
                    cc = "eq".to_string();
                }
                let r9 = self.fresh();
                self.body =
                    self.body + "  " + r9.clone() + " = icmp " + cc + " i64 " + tg9 + ", 0\n";
                return Val { op: r9, kind: 1, heap: false };
            }
            return Val { op: "false".to_string(), kind: 1, heap: false };
        }
        if method == "unwrap" {
            // `o.unwrap()` (Slice 34): extract the Some/Ok payload by its
            // recorded kind — a String payload is a BORROW (the receiver's
            // owner keeps and frees the buffer). NO tag check: the corpus
            // discipline is unwrap-only-verified-Some/Ok (the seed panics on
            // None/Err — panic parity is a deferred surface).
            let ov9 = self.emit_value(object);
            let Val { op: oop9, kind: ok9, heap: oh9 } = ov9;
            if ok9 >= 1000 and ok9 < 2000 {
                let ei9 = ok9 - 1000;
                // Variant 1 for Option (Some), variant 0 for Result (Ok).
                let mut vtag = 1;
                if ok9 >= 1002 and ok9 <= 1005 {
                    vtag = 0;
                }
                let plk9 = self.en_var_pl[self.en_off[ei9] + vtag];
                let ety9 = self.ty_text(ok9);
                if plk9 == 2 {
                    let r9 = self.fresh();
                    self.body = self.body
                        + "  "
                        + r9.clone()
                        + " = extractvalue "
                        + ety9
                        + " "
                        + oop9
                        + ", 2\n";
                    return Val { op: r9, kind: 2, heap: false };
                }
                let r9 = self.fresh();
                self.body = self.body
                    + "  "
                    + r9.clone()
                    + " = extractvalue "
                    + ety9
                    + " "
                    + oop9
                    + ", 1\n";
                return Val { op: r9, kind: 0, heap: false };
            }
            return Val { op: "0".to_string(), kind: 0, heap: false };
        }
        {
            {
                if method == "new" {
                    // `Vec.new()` (Slice 13): an empty {ptr,len,cap} — null
                    // buffer, zero len/cap. `realloc(null, n)` is malloc and
                    // `free(null)` a no-op, so the empty Vec needs no special
                    // casing anywhere downstream.
                    let is_vec = match object {
                        Ident(ie2) => {
                            let IdentExpr { name: on, span: osp } = ie2;
                            on == "Vec"
                        }
                        _ => false,
                    };
                    if is_vec {
                        return Val { op: "zeroinitializer".to_string(), kind: 3, heap: true };
                    }
                    return Val { op: "0".to_string(), kind: 0, heap: false };
                }
                if method == "len" {
                    // `v.len()` (Slice 13): extract the len field.
                    let ov = self.emit_value(object);
                    let Val { op: oop, kind: ok, heap: oh } = ov;
                    if ok == 3 or ok == 4 or ok >= 2000 {
                        let r = self.fresh();
                        self.body = self.body
                            + "  "
                            + r.clone()
                            + " = extractvalue { ptr, i64, i64 } "
                            + oop
                            + ", 1\n";
                        return Val { op: r, kind: 0, heap: false };
                    }
                    if ok == 2 {
                        let r = self.fresh();
                        self.body = self.body
                            + "  "
                            + r.clone()
                            + " = extractvalue { ptr, i64 } "
                            + oop
                            + ", 1\n";
                        return Val { op: r, kind: 0, heap: false };
                    }
                    return Val { op: "0".to_string(), kind: 0, heap: false };
                }
                if method == "substring" {
                    // `s.substring(a, b)` (Slice 17): a fresh OWNED copy of
                    // bytes [a, b) — malloc(b-a) + memcpy from ptr+a. The
                    // seed's token-text extraction primitive.
                    let ov2 = self.emit_value(object);
                    let Val { op: oop2, kind: ok2, heap: oh2 } = ov2;
                    if ok2 != 2 {
                        return Val { op: "0".to_string(), kind: 0, heap: false };
                    }
                    let mut a0v = "0".to_string();
                    let mut a1v = "0".to_string();
                    let mut mi = 0;
                    for ma in margs {
                        let CallArg { label, mut_marker, value, span: masp } = ma;
                        let av = self.emit_value(value);
                        let Val { op: aop, kind: ak, heap: ah } = av;
                        if mi == 0 {
                            a0v = aop;
                        } else {
                            a1v = aop;
                        }
                        mi = mi + 1;
                    }
                    let sp3 = self.fresh();
                    self.body = self.body
                        + "  "
                        + sp3.clone()
                        + " = extractvalue { ptr, i64 } "
                        + oop2.clone()
                        + ", 0\n";
                    let n = self.fresh();
                    self.body = self.body
                        + "  "
                        + n.clone()
                        + " = sub i64 "
                        + a1v
                        + ", "
                        + a0v.clone()
                        + "\n";
                    let src2 = self.fresh();
                    self.body = self.body
                        + "  "
                        + src2.clone()
                        + " = getelementptr i8, ptr "
                        + sp3
                        + ", i64 "
                        + a0v
                        + "\n";
                    let buf = self.fresh();
                    self.body = self.body
                        + "  "
                        + buf.clone()
                        + " = call ptr @malloc(i64 "
                        + n.clone()
                        + ")\n";
                    let m = self.fresh();
                    self.body = self.body
                        + "  "
                        + m
                        + " = call ptr @memcpy(ptr "
                        + buf.clone()
                        + ", ptr "
                        + src2
                        + ", i64 "
                        + n.clone()
                        + ")\n";
                    let g0 = self.fresh();
                    self.body = self.body
                        + "  "
                        + g0.clone()
                        + " = insertvalue { ptr, i64 } undef, ptr "
                        + buf
                        + ", 0\n";
                    let g1 = self.fresh();
                    self.body = self.body
                        + "  "
                        + g1.clone()
                        + " = insertvalue { ptr, i64 } "
                        + g0
                        + ", i64 "
                        + n
                        + ", 1\n";
                    if oh2 {
                        self.emit_free_val(oop2);
                    }
                    return Val { op: g1, kind: 2, heap: true };
                }
                if method != "to_string" {
                    return Val { op: "0".to_string(), kind: 0, heap: false };
                }
                let v = self.emit_value(object);
                let Val { op, kind, heap } = v;
                if kind == 2 {
                    return Val { op: op, kind: 2, heap: heap };
                }
                if kind == 5 {
                    // f64.to_string() (Slice 36): the runtime's Rust-Display
                    // formatter — exact parity with the seed's output.
                    return self.emit_f64_to_string(op);
                }
                if kind == 1 {
                    let pr = self.fresh();
                    self.body = self.body
                        + "  "
                        + pr.clone()
                        + " = select i1 "
                        + op.clone()
                        + ", ptr @.true, ptr @.false\n";
                    let ln = self.fresh();
                    self.body = self.body
                        + "  "
                        + ln.clone()
                        + " = select i1 "
                        + op
                        + ", i64 4, i64 5\n";
                    let a0 = self.fresh();
                    self.body = self.body
                        + "  "
                        + a0.clone()
                        + " = insertvalue { ptr, i64 } undef, ptr "
                        + pr
                        + ", 0\n";
                    let a1 = self.fresh();
                    self.body = self.body
                        + "  "
                        + a1.clone()
                        + " = insertvalue { ptr, i64 } "
                        + a0
                        + ", i64 "
                        + ln
                        + ", 1\n";
                    return Val { op: a1, kind: 2, heap: false };
                }
                let buf = self.fresh();
                self.body = self.body + "  " + buf.clone() + " = call ptr @malloc(i64 24)\n";
                let w = self.fresh();
                self.body = self.body
                    + "  "
                    + w.clone()
                    + " = call i32 (ptr, i64, ptr, ...) @snprintf(ptr "
                    + buf.clone()
                    + ", i64 24, ptr @.fmt_i, i64 "
                    + op
                    + ")\n";
                let ln = self.fresh();
                self.body = self.body + "  " + ln.clone() + " = zext i32 " + w + " to i64\n";
                let a0 = self.fresh();
                self.body = self.body
                    + "  "
                    + a0.clone()
                    + " = insertvalue { ptr, i64 } undef, ptr "
                    + buf
                    + ", 0\n";
                let a1 = self.fresh();
                self.body = self.body
                    + "  "
                    + a1.clone()
                    + " = insertvalue { ptr, i64 } "
                    + a0
                    + ", i64 "
                    + ln
                    + ", 1\n";
                Val { op: a1, kind: 2, heap: true }
            }
        }
    }

    // Print an i1 as `true`/`false` + newline: select the global + its length.
    fn emit_println_bool(mut ref self, val: String) {
        let p = self.fresh();
        self.body = self.body
            + "  "
            + p.clone()
            + " = select i1 "
            + val.clone()
            + ", ptr @.true, ptr @.false\n";
        let l = self.fresh();
        self.body =
            self.body + "  " + l.clone() + " = select i1 " + val + ", i64 4, i64 5\n";
        let st = self.fresh();
        self.body = self.body + "  " + st.clone() + " = load ptr, ptr @stdout, align 8\n";
        let r = self.fresh();
        self.body = self.body
            + "  "
            + r
            + " = call i64 @fwrite(ptr "
            + p
            + ", i64 1, i64 "
            + l
            + ", ptr "
            + st
            + ")\n";
        self.emit_write("@.nl".to_string(), 1);
    }

    // Format an i64 operand with `snprintf` into a stack buffer and print it (the
    // buffer is written directly — no heap String, since it is consumed
    // immediately), then a newline. Output-equivalent to the seed's heap-String
    // `to_string` + `write_console` path.
    fn emit_println_int(mut ref self, val: String) {
        let buf = self.fresh();
        self.body = self.body + "  " + buf.clone() + " = alloca [64 x i8], align 1\n";
        let w = self.fresh();
        self.body = self.body
            + "  "
            + w.clone()
            + " = call i32 (ptr, i64, ptr, ...) @snprintf(ptr "
            + buf.clone()
            + ", i64 64, ptr @.fmt_i, i64 "
            + val
            + ")\n";
        let len = self.fresh();
        self.body = self.body + "  " + len.clone() + " = zext i32 " + w + " to i64\n";
        let s = self.fresh();
        self.body = self.body + "  " + s.clone() + " = load ptr, ptr @stdout, align 8\n";
        let r = self.fresh();
        self.body = self.body
            + "  "
            + r
            + " = call i64 @fwrite(ptr "
            + buf
            + ", i64 1, i64 "
            + len
            + ", ptr "
            + s
            + ")\n";
        self.emit_write("@.nl".to_string(), 1);
    }
}

// A binary operator's lowering, computed in ONE match (BinOp is not Copy):
// `kind` 0 = arithmetic (text = the i64 opcode), 1 = comparison (text = the
// signed icmp condition code), 2 = logical (text = the i1 opcode).
// The 16-hex-digit form of an i64 bit pattern (Slice 36): LLVM double
// constants use `0x<bits>` — exact by construction, unlike decimal FP text
// (which LLVM rejects when inexact). The `& 15` mask cleans the arithmetic
// shift's sign extension, so negative bit patterns (sign-bit doubles) work.
fn hex_u64(bits: i64) -> String {
    let mut s = "".to_string();
    let mut i = 0;
    while i < 16 {
        let nib = (bits >> ((15 - i) * 4)) & 15;
        s = s + hex_digit(nib);
        i = i + 1;
    }
    s
}

struct BinIr {
    kind: i64,
    text: String,
}

fn bin_ir(op: BinOp) -> BinIr {
    match op {
        Add => BinIr { kind: 0, text: "add".to_string() },
        Sub => BinIr { kind: 0, text: "sub".to_string() },
        Mul => BinIr { kind: 0, text: "mul".to_string() },
        Div => BinIr { kind: 0, text: "sdiv".to_string() },
        Mod => BinIr { kind: 0, text: "srem".to_string() },
        Eq => BinIr { kind: 1, text: "eq".to_string() },
        NotEq => BinIr { kind: 1, text: "ne".to_string() },
        Lt => BinIr { kind: 1, text: "slt".to_string() },
        LtEq => BinIr { kind: 1, text: "sle".to_string() },
        Gt => BinIr { kind: 1, text: "sgt".to_string() },
        GtEq => BinIr { kind: 1, text: "sge".to_string() },
        And => BinIr { kind: 2, text: "and".to_string() },
        Or => BinIr { kind: 2, text: "or".to_string() },
        _ => BinIr { kind: 0, text: "add".to_string() },
    }
}

// The LLVM type text for a value kind (0 i64, 1 i1, 2 string aggregate,
// 3 Vec[i64] {ptr,len,cap} — Slice 13).
fn kind_ty(kind: i64) -> String {
    if kind == 1 {
        return "i1".to_string();
    }
    if kind == 2 {
        return "{ ptr, i64 }".to_string();
    }
    if kind == 3 or kind == 4 {
        return "{ ptr, i64, i64 }".to_string();
    }
    if kind == 5 {
        // f64 (Slice 36).
        return "double".to_string();
    }
    "i64".to_string()
}

// A peeled parameter type (Slice 19): the value kind plus whether the
// declared type was a `ref` borrow.
struct RefKind {
    kind: i64,
    is_ref: bool,
    is_mut: bool,
}

// An interned string global: its symbol name and byte length.
struct StrG {
    name: String,
    len: i64,
}

// A byte as two lowercase hex digits (LLVM `c"..."` `\NN` escape body).
fn hex2(b: i64) -> String {
    hex_digit(b / 16) + hex_digit(b % 16)
}

fn hex_digit(d: i64) -> String {
    if d < 10 {
        return d.to_string();
    }
    if d == 10 {
        return "a".to_string();
    }
    if d == 11 {
        return "b".to_string();
    }
    if d == 12 {
        return "c".to_string();
    }
    if d == 13 {
        return "d".to_string();
    }
    if d == 14 {
        return "e".to_string();
    }
    "f".to_string()
}

// resolver.kara — name resolution / scope analysis for the self-hosted
// compiler (Phase 12, Resolver port Slice 1). Depends on span + ast
// (DAG: span <- token <- ast <- resolver). Mirrors the MINIMAL core of
// `src/resolver.rs` + `src/resolver/{resolve_items,resolve_block,resolve_refs}.rs`:
//
//   * `SymbolTable` scope machinery (push/pop, define, define_shadowable,
//     lookup) — a FLAT `Vec` + linear scan (Kāra has no HashMap, and codegen
//     can't `.push()` onto a nested receiver), the same idiom
//     `Parser.label_known` uses.
//   * Seeds the FULL prelude (Slice 2c) — the 16 `PRELUDE_PRIMITIVES` plus
//     every `PRELUDE_{FUNCTIONS,TYPES,TRAITS,VARIANTS,EFFECT_RESOURCES}` name
//     and the magic modules / comptime pseudotypes / stdlib module aliases the
//     seed's `register_primitives` registers — so the corpus may reference real
//     prelude names (`Vec` / `Option` / `println` / `Some` / ...) exactly as
//     the seed resolves them.
//   * Resolves a single top-level `fn`: generics (bare type params), `self`,
//     params + param-types, return type, and the body block — walking
//     Let/Assign/Exp statements and the reachable `Expr` forms, pushing a
//     scope per block / if / loop / match-arm. Emits UndefinedName (0),
//     UndefinedType (1), DuplicateDefinition (2), ReservedIdentifier (3).
//
// AST nodes are consumed BY VALUE and destructured (the `ast_render` idiom):
// a match-bound `ref` to a nested node reads its `Vec` fields as empty under
// codegen, so the walk owns each node and moves its fields out. Recursive
// `Expr` / `TypeExpr` children are `shared` (RC handles), walked by `ref`.
//
// The oracle renders ONLY (kind, offset, length) per error — messages,
// fuzzy "did you mean" suggestions, and the resolution map are deferred.

import span.Span;
import ast.{
    Item,
    FnDefNode,
    StructDefNode,
    UnionDefNode,
    StructFieldNode,
    EnumDefNode,
    VariantNode,
    VariantTag,
    TypeAliasNode,
    ConstDeclNode,
    TraitDefNode,
    TraitMethodNode,
    ImplBlockNode,
    GenericParamsNode,
    GenericParamNode,
    SelfMode,
    FnParamNode,
    Block,
    Stmt,
    LetStmt,
    AssignStmt,
    ExprStmt,
    Expr,
    IdentExpr,
    SpanNode,
    BinaryExpr,
    UnaryExpr,
    TupleExpr,
    CallExpr,
    CallArg,
    MethodCallExpr,
    FieldAccessExpr,
    TupleIndexExpr,
    IndexExpr,
    PathExpr,
    StructLitField,
    StructLitExpr,
    IfExpr,
    ReturnExpr,
    WhileExpr,
    ForExpr,
    LoopExpr,
    BreakExpr,
    ContinueExpr,
    MatchExpr,
    MatchArm,
    Pattern,
    BindingPattern,
    TuplePattern,
    TupleVariantPattern,
    StructFieldPat,
    StructPattern,
    OrPattern,
    TypeExpr,
    PathType,
    TupleType,
    PointerType,
    FnTypeNode,
    WrapType,
    clone_span,
};

// ── State ──
//
// Scopes are FLAT: every binding lives in one `binds` vec tagged with its
// owning scope id, and `parents[scope_id]` gives each scope's parent (-1 for
// the global scope). `line` drives the prelude carve-out — a binding at
// synthetic line 0 is a seeded prelude entry, silently shadowable by a user
// definition (mirrors `resolver.rs:373-375`'s `span.line==0 && column==0`).
struct NameBinding {
    name: String,
    line: i64,
    scope: i64,
}

// A resolve error: `kind` is 0=UndefinedName, 1=UndefinedType,
// 2=DuplicateDefinition, 3=ReservedIdentifier, 4=UndefinedLabel; `off`/`len`
// are the byte span.
pub struct ResolveError {
    kind: i64,
    off: i64,
    len: i64,
}

struct Resolver {
    binds: Vec[NameBinding],
    parents: Vec[i64],
    current: i64,
    errors: Vec[ResolveError],
    // In-scope loop labels (innermost last), pushed on entry to a labeled
    // `while`/`for`/`loop` and popped on exit. Mirrors the seed's `loop_labels`
    // stack (`resolve_block.rs`): a `continue <label>` referring to a name NOT
    // on the stack is an UndefinedLabel. The selfhost AST has no labeled-BLOCK
    // form, so every entry is a loop label — `continue` to any in-scope label is
    // valid (the seed's `ContinueOnBlockLabel` case is unreachable here).
    labels: Vec[String],
}

// ── Entry points ──
//
// Resolve a single top-level item and return its resolve errors in traversal
// order. The two-pass shape collapsed to one item: COLLECT the item's name into
// the global scope, then RESOLVE its body — so a self-referential field /
// variant / const value / recursive call still resolves.
pub fn resolve_item(item: Item) -> Vec[ResolveError] with panics {
    let mut r = Resolver {
        binds: Vec.new(),
        parents: Vec.new(),
        current: 0,
        errors: Vec.new(),
        labels: Vec.new(),
    };
    r.seed_global();
    r.collect_item(item);
    r.walk_item(item);
    let Resolver { binds, parents, current, errors, labels } = r;
    errors
}

// Resolve a whole program (a `Vec[Item]`) and return its resolve errors in
// traversal order. Mirrors the seed's `resolve()`: PASS 1 (`collect`) registers
// every top-level declaration's name in the global scope, then PASS 2
// (`resolve_items`) resolves each item's body against that fully-populated
// scope — so FORWARD references across items (`fn a() { b() }` before `fn b`, a
// field typed by a struct declared later, mutually-recursive types) resolve,
// and a repeated top-level name is a DuplicateDefinition. Collect errors
// (pass 1) precede resolve errors (pass 2), matching the seed's two-phase
// ordering. Pass 1 walks the items BY REF (borrowing) so pass 2 can still
// consume them.
pub fn resolve_program(items: Vec[Item]) -> Vec[ResolveError] with panics {
    let mut r = Resolver {
        binds: Vec.new(),
        parents: Vec.new(),
        current: 0,
        errors: Vec.new(),
        labels: Vec.new(),
    };
    r.seed_global();
    // Pass 1 borrows `items` (a `ref Vec` param inside `collect_all`, the only
    // by-ref iteration form) so pass 2 can still consume them.
    r.collect_all(items);
    for it in items {
        r.walk_item(it);
    }
    let Resolver { binds, parents, current, errors, labels } = r;
    errors
}

impl Resolver {
    // Global scope (parent = -1) seeded with the FULL prelude — the 16
    // PRELUDE_PRIMITIVES plus every PRELUDE_{FUNCTIONS,TYPES,TRAITS,VARIANTS,
    // EFFECT_RESOURCES} name and the magic modules / comptime pseudotypes /
    // stdlib module aliases the seed's `register_primitives` (resolver.rs:209)
    // registers — all at synthetic line 0 (shadowable by user definitions). The
    // Kāra resolver is kind-agnostic (lookup checks name presence only; the use
    // site picks UndefinedName vs UndefinedType), so seeding names alone suffices.
    fn seed_global(mut ref self) {
